{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },

    "ReverseProxy": {
    "Routes": {
      "AuthServiceGetUserBookRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Book/GetUserBook"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-ID",
            "Append": "auth-gateway"
          },
          { "PathSet": "/api/auth-service/Book/GetUserBook" }
        ]
      },
      "AuthServiceRefreshAccessTokenRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Secret/RefreshAccessToken"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Secret/RefreshAccessToken" }
        ]
      },
      "AuthServiceCancelAccessTokenRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Secret/CancelAccessToken"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Secret/CancelAccessToken" }
        ]
      },
      "AuthServiceSLoginRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Secret/SLogin"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Secret/SLogin" }
        ]
      },
      "AuthServiceEditPwdRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Secret/EditPwd"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Secret/EditPwd" }
        ]
      },
      "AuthServiceResetPwdRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Secret/ResetPwd"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Secret/ResetPwd" }
        ]
      },
      "AuthServiceGetUserMenuRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/System/GetUserMenu"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/System/GetUserMenu" }
        ]
      },
      "AuthServiceGetUserOrgInfoRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/System/GetUserOrgInfo"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/System/GetUserOrgInfo" }
        ]
      },
      "AuthServiceGetUserAuthorizeListRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/System/GetUserAuthorizeList"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/System/GetUserAuthorizeList" }
        ]
      },
      "AuthServiceGetSystemSwitchRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Anonymous/GetSystemSwitch"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Anonymous/GetSystemSwitch" }
        ]
      },
      "AuthServiceGetSysConfigRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Anonymous/GetSysConfig"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Anonymous/GetSysConfig" }
        ]
      },
      "AuthServiceCaptchaRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Anonymous/Captcha"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Anonymous/Captcha" }
        ]
      },
      "AuthServiceCaptchaValidateRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Anonymous/CaptchaValidate"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Anonymous/CaptchaValidate" }
        ]
      },


      "AuthServiceSelfRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 2,
        "Match": {
          "Path": "/api/auth-service/{**catchAll}"
        }
      },
      "HRP30ServiceRoute": {
        "ClusterId": "HRP30ServiceCluster",
        "Order": 10,
        "Match": {
          "Path": "/api/hrp30/{**catchAll}"
        }
      },
      "PlatFallbackRoute": {
        "ClusterId": "PlatServiceCluster",
        "Order": 100,
        "Match": {
          "Path": "/api/{**catchAll}"
        }
      }
    },

    "Clusters": {
      "AuthServiceCluster": {
        "Destinations": {
          "d1": { "Address": "http://192.168.16.19:20002" },
          "d2": { "Address": "http://192.168.16.19:20003" }
        }
      },
      "PlatServiceCluster": {
        "Destinations": { "d1": { "Address": "http://192.168.16.19:20000" } }
      },
      "HRP30ServiceCluster": {
        "Destinations": { "d1": { "Address": "http://192.168.16.19:20001" } }
      }
    }
  },

  "Gateway": {
    "Dashboard": {
      //"EnableProxyLogging": false,
      "AuthMode": "DefaultJwt",
      "JwtPassword": "demo123"
    }
  },
  "Urls": "http://localhost:5000"
}
