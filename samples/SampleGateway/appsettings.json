{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },

  "ReverseProxy": {
    "Routes": {
      "AuthServiceGetUserBookRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Book/GetUserBook"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-ID",
            "Append": "auth-gateway"
          },
          { "PathSet": "/api/auth-service/Book/GetUserBook" }
        ]
      },
      "AuthServiceGetSystemSwitchRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 1,
        "Match": {
          "Path": "/api/Anonymous/GetSystemSwitch"
        },
        "Transforms": [
          { "PathSet": "/api/auth-service/Anonymous/GetSystemSwitch" }
        ]
      },
      "AuthServiceSelfRoute": {
        "ClusterId": "AuthServiceCluster",
        "Order": 2,
        "Match": {
          "Path": "/api/auth-service/{**catchAll}"
        }
      },
      "PlatFallbackRoute": {
        "ClusterId": "PlatServiceCluster",
        "Order": 100,
        "Match": {
          "Path": "/api/{**catchAll}"
        }
      }
    },

    "Clusters": {
      "AuthServiceCluster": {
        "Destinations": {
          "d1": { "Address": "http://192.168.16.19:20002" },
          "d2": { "Address": "http://192.168.16.19:20003" }
        }
      },
      "PlatServiceCluster": {
        "Destinations": { "d1": { "Address": "http://192.168.16.19:20000" } }
      }
    }
  },

  "Gateway": {
    "Dashboard": {
      "RoutePrefix": "aneiang",
      //"EnableProxyLogging": false,
      "AuthMode": "DefaultJwt",
      "JwtPassword": "demo123"
    },
    "Storage": {
      "Provider": "Sqlite", // "Sqlite" | "Redis"
      "Sqlite": { "ConnectionString": "Data Source=gateway-store.db" },
      "Redis": {
        "ConnectionString": "localhost:6379",
        "Prefix": "aneiang:",
        "Database": 0
      }
    }
  },
  "Urls": "http://0.0.0.0:5200"
}
