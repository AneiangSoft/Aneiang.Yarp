{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "Yarp.ReverseProxy": "Debug"
    }
  },
  "Gateway": {
    "Dashboard": {
      "RoutePrefix": "aneiang",
      //"EnableProxyLogging": false,
      "AuthMode": "DefaultJwt",
      "JwtPassword": "demo123",
      "AI": {
        "Enabled": true,
        "Provider": "deepseek",
        "ApiKey": "sk-fe71070d45b445dda0f7390f835deb1f",
        "BaseUrl": "https://api.deepseek.com",
        "ChatModel": "deepseek-chat",
        "AnalysisModel": "deepseek-chat",
        "MaxTokens": 4096,
        "Temperature": 0.3,
        "MaxConversationHistory": 20,
        "EnableBackgroundAnalysis": true,
        "AnalysisInterval": "01:00:00",
        "EnhanceNotifications": true,
        "NotificationEnhanceCooldownSeconds": 60
      }
    },
    "Storage": {
      "Provider": "Sqlite", // "Sqlite" | "Redis"
      "Sqlite": { "ConnectionString": "Data Source=gateway-store.db;Password=123456" },
      "Redis": {
        "ConnectionString": "localhost:6379",
        "Prefix": "aneiang:",
        "Database": 0
      }
    },
    "Deployment": {
      "Mode": "Split",
      "EndpointRoles": {
        "Proxy": "Proxy",
        "Dashboard": "Dashboard"
      },
      "RequireLoopbackForDashboard": false,
      "HealthCheck": { "Enabled": true },
      "HotReload": { "Enabled": true }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Proxy": { "Url": "http://0.0.0.0:5202" },
      "Dashboard": { "Url": "http://0.0.0.0:5200" }
    }
  }
  //"Urls": "http://0.0.0.0:5200"
}
