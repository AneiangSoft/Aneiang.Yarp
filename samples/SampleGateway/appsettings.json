{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "Gateway": {
    "Dashboard": {
      "RoutePrefix": "aneiang",
      //"EnableProxyLogging": false,
      "AuthMode": "DefaultJwt",
      "JwtPassword": "demo123"
    },
    "Storage": {
      "Provider": "Sqlite", // "Sqlite" | "Redis"
      "Sqlite": { "ConnectionString": "Data Source=gateway-store.db;Password=123456" },
      "Redis": {
        "ConnectionString": "localhost:6379",
        "Prefix": "aneiang:",
        "Database": 0
      }
    },
    "Deployment": {
      "Mode": "Split",
      "EndpointRoles": {
        "Proxy": "Proxy",
        "Dashboard": "Dashboard"
      },
      "RequireLoopbackForDashboard": false,
      "HealthCheck": { "Enabled": true },
      "HotReload": { "Enabled": true }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Proxy": { "Url": "http://0.0.0.0:5202" },
      "Dashboard": { "Url": "http://0.0.0.0:5200" }
    }
  }
  //"Urls": "http://0.0.0.0:5200"
}
