{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },

  "ReverseProxy": {
    "Routes": {
      "downstream-route": {
        "ClusterId": "downstream-cluster",
        "Match": {
          "Path": "/api/downstream/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "downstream-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5001/"
          }
        }
      }
    }
  },

  "GatewayRegistration": {
    "Enabled": false,
    "GatewayUrl": "http://localhost:5000",
    "RouteName": "sample-gateway-route",
    "ClusterName": "sample-gateway-cluster",
    "MatchPath": "/api/downstream/{**catch-all}",
    "DestinationAddress": "http://localhost:5000",
    "Order": 50
  },

  "Dashboard": {
    "AuthMode": "DefaultJwt",
    "JwtPassword": "demo123"
  },

  "Urls": "http://localhost:5000"
}
