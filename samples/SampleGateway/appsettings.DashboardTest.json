{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },

  "ReverseProxy": {
    "Routes": {
      "MockTestRoute": {
        "ClusterId": "MockCluster",
        "Order": 1,
        "Match": {
          "Path": "/test/{**catchAll}"
        }
      },
      "MockHealthRoute": {
        "ClusterId": "MockCluster",
        "Order": 2,
        "Match": {
          "Path": "/health"
        }
      }
    },
    "Clusters": {
      "MockCluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5201/api/mock",
          }
        }
      }
    }
  },

  "Gateway": {
    "Dashboard": {
      "RoutePrefix": "aneiang",
      "EnableProxyLogging": true,
      "AuthMode": "DefaultJwt",
      "JwtPassword": "demo123"
    },
    "Storage": {
      "Provider": "Sqlite",
      "Sqlite": { "ConnectionString": "Data Source=gateway-store.db" }
    }
  },

  "Urls": "http://0.0.0.0:5200"
}
