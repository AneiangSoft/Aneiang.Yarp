{
  "_comment": "场景 3: 单进程多端口含健康检查。Proxy 80 / Dashboard 5000 / Health 5002。",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Proxy":     { "Url": "http://0.0.0.0:80" },
      "Dashboard": { "Url": "http://127.0.0.1:5000" },
      "Health":    { "Url": "http://0.0.0.0:5002" }
    }
  },
  "Gateway": {
    "Deployment": {
      "Mode": "Split",
      "EndpointRoles": {
        "Proxy":     "Proxy",
        "Dashboard": "Dashboard",
        "Health":    "Health"
      },
      "RequireLoopbackForDashboard": true,
      "HealthCheck": {
        "Enabled":           true,
        "Path":              "/health",
        "ReadyPath":         "/ready",
        "LivePath":          "/live",
        "AllowedIps":        [],
        "CheckDatabase":     true,
        "CheckConfigLoaded": true
      },
      "HotReload": {
        "Enabled":              true,
        "DebounceMilliseconds": 500,
        "FallbackPollSeconds":  30,
        "RollbackOnFailure":    true,
        "MaxSnapshots":         5
      }
    },
    "Dashboard": {
      "RoutePrefix": "aneiang",
      "AuthMode": "DefaultJwt",
      "JwtPassword": "demo123"
    },
    "Storage": {
      "Provider": "Sqlite",
      "Sqlite": { "ConnectionString": "Data Source=gateway-store.db;Password=123456" }
    }
  }
}
