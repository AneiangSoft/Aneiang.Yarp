{
  "_comment": "场景 4: 仅代理模式 - 80 端口代理转发 + 5001 端口仅本机 Admin。无 Dashboard UI。",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Proxy": { "Url": "http://0.0.0.0:80" },
      "Admin": { "Url": "http://127.0.0.1:5001" }
    }
  },
  "Gateway": {
    "Deployment": {
      "Mode": "ProxyOnly",
      "EndpointRoles": {
        "Proxy": "Proxy",
        "Admin": "Admin"
      },
      "RequireLoopbackForAdmin": true,
      "HealthCheck": {
        "Enabled": true
      }
    },
    "Storage": {
      "Provider": "Sqlite",
      "Sqlite": { "ConnectionString": "Data Source=gateway-store.db;Password=123456" }
    }
  }
}
