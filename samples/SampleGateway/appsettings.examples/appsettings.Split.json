{
  "_comment": "场景 2: 单进程双端口 - 80 端口处理代理转发，5000 端口仅本机 Dashboard。",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Proxy": {
        "Url": "http://0.0.0.0:80",
        "Protocols": "Http1AndHttp2"
      },
      "Dashboard": {
        "Url": "http://127.0.0.1:5000"
      }
    }
  },
  "Gateway": {
    "Deployment": {
      "Mode": "Split",
      "EndpointRoles": {
        "Proxy": "Proxy",
        "Dashboard": "Dashboard"
      },
      "RequireLoopbackForDashboard": true
    },
    "Dashboard": {
      "RoutePrefix": "aneiang",
      "AuthMode": "DefaultJwt",
      "JwtPassword": "demo123"
    },
    "Storage": {
      "Provider": "Sqlite",
      "Sqlite": { "ConnectionString": "Data Source=gateway-store.db;Password=123456" }
    }
  }
}
