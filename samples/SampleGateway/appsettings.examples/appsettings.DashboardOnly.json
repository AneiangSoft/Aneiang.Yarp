{
  "_comment": "场景 5: 仅 Dashboard 模式 - 5000 端口仅本机 Dashboard，无代理转发。适合控制面独立部署。",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Dashboard": { "Url": "http://127.0.0.1:5000" }
    }
  },
  "Gateway": {
    "Deployment": {
      "Mode": "DashboardOnly",
      "EndpointRoles": {
        "Dashboard": "Dashboard"
      },
      "RequireLoopbackForDashboard": true,
      "HealthCheck": {
        "Enabled": true,
        "Path": "/health",
        "ReadyPath": "/ready",
        "LivePath": "/live"
      },
      "HotReload": { "Enabled": true }
    },
    "Dashboard": {
      "RoutePrefix": "aneiang",
      "AuthMode": "DefaultJwt",
      "JwtPassword": "CHANGE_ME_STRONG_PASSWORD"
    },
    "Storage": {
      "Provider": "Sqlite",
      "Sqlite": { "ConnectionString": "Data Source=gateway-store.db;Password=CHANGE_ME_DB_PASSWORD" }
    }
  }
}
