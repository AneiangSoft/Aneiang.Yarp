  "_comment_ip_isolation": "────────── IP 隔离示例（启用后无需路径前缀，前端无感知） ──────────",
  "_example_ip": "取消下方注释即可启用 IP 隔离，多个开发者各自启动服务时自动按客户端 IP 路由到对应实例",
  "Gateway": {
    "Registration": {
      "GatewayUrl": "http://localhost:5000",
      "RouteName": "sample-local-service",
      "MatchPath": "/api/local-service/{**catch-all}",
      "UseIpIsolation": true,
      "Order": "0"
    }
  },

  "_comment_extended": "────────── 可选配置（有智能默认值） ──────────",
  "_routeName": "默认：入口程序集名称",
  "_clusterName": "默认：同 routeName",
  "_matchPath": "默认：/{**catch-all}",
  "_destinationAddress": "默认：自动从 Kestrel 绑定地址获取",
  "_order": "默认：50",
  "_enabled": "默认：设置了 GatewayUrl 即自动启用",

  //"Urls": "http://0.0.0.0:5001",

  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://localhost:5001"
      },
      "Https": {
        "Url": "https://localhost:5002"
      }
    }
