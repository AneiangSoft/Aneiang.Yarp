[
  {
    "id": "load-balancing",
    "name": "负载均衡",
    "icon": "bi-arrow-repeat",
    "category": "可靠性",
    "summary": "5种负载均衡策略，在多个后端之间分配请求流量",
    "keyPoints": ["PowerOfTwoChoices", "RoundRobin", "LeastRequests", "Random", "FirstAlphabetical"],
    "configLocation": "Cluster.LoadBalancingPolicy",
    "exampleConfig": "{\n  \"loadBalancingPolicy\": \"PowerOfTwoChoices\",\n  \"destinations\": {\n    \"node1\": { \"address\": \"http://10.0.0.1:8080\" },\n    \"node2\": { \"address\": \"http://10.0.0.2:8080\" }\n  }\n}",
    "docUrl": "https://microsoft.github.io/reverse-proxy/articles/load-balancing.html",
    "configPageUrl": "/apigateway/clusters",
    "isPlugin": false,
    "options": [
      { "value": "PowerOfTwoChoices", "description": "选择两个随机目的地，挑请求少的（推荐）" },
      { "value": "RoundRobin", "description": "轮询分配，依次循环" },
      { "value": "LeastRequests", "description": "选择当前请求数最少的" },
      { "value": "Random", "description": "随机选择目的地" },
      { "value": "FirstAlphabetical", "description": "按字母顺序选第一个（仅测试用）" }
    ]
  },
  {
    "id": "health-check",
    "name": "健康检查",
    "icon": "bi-heart-pulse",
    "category": "可靠性",
    "summary": "主动和被动健康检查，自动剔除不健康节点",
    "keyPoints": ["Active Health Check", "Passive Health Check", "ConsecutiveFailures", "TransportFailureRate"],
    "configLocation": "Cluster.HealthCheck",
    "exampleConfig": "{\n  \"healthCheck\": {\n    \"active\": {\n      \"enabled\": true,\n      \"interval\": \"00:00:15\",\n      \"timeout\": \"00:00:10\",\n      \"path\": \"/health\"\n    }\n  }\n}",
    "docUrl": "https://microsoft.github.io/reverse-proxy/articles/health-checks.html",
    "configPageUrl": "/apigateway/clusters",
    "isPlugin": false,
    "options": []
  },
  {
    "id": "circuit-breaker",
    "name": "熔断器",
    "icon": "bi-lightning-charge",
    "category": "可靠性",
    "summary": "监控连续失败自动断开故障链路，防止级联故障",
    "keyPoints": ["Closed/Open/HalfOpen", "FailureThreshold", "RecoveryTimeout", "策略系统管理"],
    "configLocation": "ClusterPolicy.CircuitBreaker",
    "exampleConfig": "{\n  \"failureThreshold\": 5,\n  \"recoveryTimeoutSeconds\": 30,\n  \"halfOpenMaxAttempts\": 3\n}",
    "docUrl": "https://microsoft.github.io/reverse-proxy/articles/circuit-breaker.html",
    "configPageUrl": "/apigateway/policies",
    "isPlugin": true,
    "pluginId": "circuit-breaker",
    "options": []
  },
  {
    "id": "request-retry",
    "name": "请求重试",
    "icon": "bi-arrow-clockwise",
    "category": "可靠性",
    "summary": "临时故障时自动重发请求，提高容错能力",
    "keyPoints": ["MaxRetries", "BackoffDelay", "仅幂等请求", "策略系统管理"],
    "configLocation": "RoutePolicy.Retry",
    "exampleConfig": "{\n  \"retry\": {\n    \"enabled\": true,\n    \"maxRetries\": 3,\n    \"backoffDelayMs\": 200\n  }\n}",
    "configPageUrl": "/apigateway/policies",
    "isPlugin": true,
    "pluginId": "request-retry",
    "options": []
  },
  {
    "id": "rate-limiting",
    "name": "限流",
    "icon": "bi-speedometer2",
    "category": "安全",
    "summary": "限制单位时间请求数量，防止过载和滥用",
    "keyPoints": ["FixedWindow", "SlidingWindow", "TokenBucket", "Concurrency", "IpAddress/UserId/Route/Global"],
    "configLocation": "RoutePolicy.RateLimit",
    "exampleConfig": "{\n  \"rateLimit\": {\n    \"enabled\": true,\n    \"algorithm\": \"FixedWindow\",\n    \"permitLimit\": 100,\n    \"window\": \"1m\",\n    \"partitionKey\": \"IpAddress\"\n  }\n}",
    "configPageUrl": "/apigateway/policies",
    "isPlugin": true,
    "pluginId": "rate-limit",
    "options": [
      { "value": "FixedWindow", "description": "固定时间窗口计数" },
      { "value": "SlidingWindow", "description": "滑动窗口计数（更平滑）" },
      { "value": "TokenBucket", "description": "令牌桶（允许突发）" },
      { "value": "Concurrency", "description": "并发数限制" }
    ]
  },
  {
    "id": "waf",
    "name": "WAF 防火墙",
    "icon": "bi-shield-lock",
    "category": "安全",
    "summary": "检测并拦截 SQL注入、XSS、路径遍历等 Web 攻击",
    "keyPoints": ["SQL注入检测", "XSS检测", "路径遍历检测", "IP黑白名单", "请求体大小限制"],
    "configLocation": "WafSettings",
    "exampleConfig": "{\n  \"enabled\": true,\n  \"enableSqlInjectionDetection\": true,\n  \"enableXssDetection\": true,\n  \"enablePathTraversalDetection\": true,\n  \"maxRequestBodySize\": 10485760\n}",
    "docUrl": "https://microsoft.github.io/reverse-proxy/articles/security.html",
    "configPageUrl": "/apigateway/waf",
    "isPlugin": true,
    "pluginId": "waf",
    "options": []
  },
  {
    "id": "transforms",
    "name": "路由转换",
    "icon": "bi-arrow-left-right",
    "category": "配置",
    "summary": "25+种请求/响应转换，修改路径、头部、查询参数",
    "keyPoints": ["PathPattern", "RequestHeader", "ResponseHeader", "X-Forwarded", "QueryValueParameter"],
    "configLocation": "Route.Transforms",
    "exampleConfig": "{\n  \"transforms\": [\n    { \"PathPattern\": \"/api/{**remainder}\" },\n    { \"X-Forwarded\": \"Set\", \"For\": \"Set\", \"Proto\": \"Set\" }\n  ]\n}",
    "docUrl": "https://microsoft.github.io/reverse-proxy/articles/transforms.html",
    "configPageUrl": "/apigateway/routes",
    "isPlugin": false,
    "options": []
  },
  {
    "id": "policies",
    "name": "策略管理",
    "icon": "bi-shield",
    "category": "配置",
    "summary": "路由策略和集群策略的创建、应用、取消",
    "keyPoints": ["RoutePolicy", "ClusterPolicy", "一键创建并应用", "策略可复用"],
    "configLocation": "Policy",
    "exampleConfig": "{\n  \"name\": \"order-service-policy\",\n  \"retry\": { \"enabled\": true, \"maxRetries\": 3 },\n  \"rateLimit\": { \"enabled\": true, \"permitLimit\": 100 }\n}",
    "configPageUrl": "/apigateway/policies",
    "isPlugin": false,
    "options": []
  },
  {
    "id": "notifications",
    "name": "通知告警",
    "icon": "bi-bell",
    "category": "运维",
    "summary": "Webhook通知、事件规则、告警级别",
    "keyPoints": ["Webhook", "事件规则", "告警级别", "冷却期"],
    "configLocation": "Notification",
    "exampleConfig": "{\n  \"channels\": [{ \"type\": \"Webhook\", \"url\": \"https://example.com/hook\" }],\n  \"rules\": [{ \"eventType\": \"CircuitBreakerOpen\", \"severity\": \"Critical\" }]\n}",
    "configPageUrl": "/apigateway/notifications",
    "isPlugin": false,
    "options": []
  }
]
