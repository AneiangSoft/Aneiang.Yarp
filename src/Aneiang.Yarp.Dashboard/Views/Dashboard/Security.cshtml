@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Security Events" : "安全事件";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div id="security-app">
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-shield-lock me-2" style="color:#ef4444;"></i><span data-i18n="security.title">WAF 安全事件</span></span>
            <div class="card-header-actions">
                <span id="security-refresh-time" class="refresh-badge"></span>
                <button class="btn btn-sm btn-outline-danger me-1" id="sec-test-event-btn" title="生成测试事件">
                    <i class="bi bi-bug"></i> <span data-i18n="waf.testEvent">模拟攻击</span>
                </button>
                <button class="btn btn-sm btn-outline-danger me-1" onclick="SecurityModule.clearAll()" title="清空">
                    <i class="bi bi-trash"></i> <span data-i18n="security.clear">清空</span>
                </button>
                <button class="btn btn-sm btn-outline-secondary btn-icon-only" onclick="SecurityModule.load()" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
        <div id="security-content" class="card-body">
            <div class="loading-state">
                <div class="loading-spinner"></div>
                <div class="loading-text" data-i18n="security.loading">加载中...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-security.js?v=@v"></script>

@await Html.PartialAsync("_DashboardPageInit")

<script>
    (async function() {
        if (window.DashboardUtils) DashboardUtils.init();
        if (window.DashboardApi) DashboardApi.init();
        if (window.DashboardState) DashboardState.init();
        if (window.DashboardI18n) DashboardI18n.init();
        if (window.DashboardStorage) DashboardStorage.init();
        if (window.DashboardModals) DashboardModals.init();
        if (window.DashboardEvents) DashboardEvents.setup();
        await SecurityModule.load();
        document.dispatchEvent(new CustomEvent('dashboard:ready'));
    })();
</script>
}
