@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Routes" : "路由配置";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Stat bar (compact) -->
<div id="stat-bar" class="row g-3 mb-3">
    <div class="col-12">
        <div class="info-bar">
            <div class="info-bar-content">
                <span><i class="bi bi-signpost-split"></i><span data-i18n="index.stat.routes">路由规则：</span><strong id="stat-routes">-</strong></span>
            </div>
            <div class="info-bar-actions">
                <div class="btn-group btn-group-sm" style="border:1px solid var(--border-color);border-radius:8px;overflow:hidden;">
                    <button class="btn px-2 py-1 view-toggle active" data-view="cards" onclick="RoutesView.toggle('cards')" title="卡片视图" style="font-size:13px;background:var(--primary-color);color:#fff;border:none;">
                        <i class="bi bi-grid-3x3-gap"></i>
                    </button>
                    <button class="btn px-2 py-1 view-toggle" data-view="table" onclick="RoutesView.toggle('table')" title="表格视图" style="font-size:13px;background:var(--card-bg);color:var(--text-secondary);border:none;">
                        <i class="bi bi-list-ul"></i>
                    </button>
                </div>
                <button class="btn btn-icon btn-outline-primary" onclick="routesRefresh(this)" data-i18n-title="index.btn.refresh" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Route panel -->
<div id="route-panel" class="card-panel mb-3">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2"></i><span data-i18n="index.route.title">路由规则列表</span></span>
        <div class="d-flex align-items-center" style="gap:6px 16px;white-space:nowrap;">
            <span class="refresh-badge" id="route-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.route.showing">Showing </span><strong id="route-display-count">0</strong><span data-i18n="index.route.of"> / </span><span id="route-total-count">0</span><span data-i18n="index.route.entries"> entries</span></span>
        </div>
    </div>
    
    <!-- Filter toolbar container -->
    <div id="route-filter-container"></div>

    <!-- Cards view -->
    <div id="route-cards-view" class="card-body"></div>

    <!-- Table view (hidden by default) -->
    <div id="route-table-view" style="display:none;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:36px"></th>
                        <th style="width:56px"><span data-i18n="index.route.orderCol">优先级</span></th>
                        <th style="width:22%"><span data-i18n="index.route.th.name">路由名称</span></th>
                        <th><span data-i18n="index.route.th.path">匹配路径</span></th>
                        <th style="width:140px"><span data-i18n="index.route.clusterCol">集群</span></th>
                        <th style="width:120px"><span data-i18n="index.route.methodCol">方法</span></th>
                        <th style="width:80px"><span data-i18n="index.route.th.actions">操作</span></th>
                    </tr>
                </thead>
                <tbody id="route-tbody">
                    <tr><td colspan="7" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<!-- Page config (shared scripts now in _DashboardLayout.cshtml) -->
<script>
    window.__dashboard = window.__dashboard || {};
    var dash = window.__dashboard;
    dash.basePath = '/' + '@ViewBag.DashboardRoutePrefix';
    dash.token = localStorage.getItem('dashboard_token');
    dash.CURRENT_LOCALE = '@ViewBag.Locale';
    dash.I18N = @Html.Raw(ViewBag.AllI18nJson ?? "{}");
    dash.logPanelEnabled = @(ViewBag.EnableProxyLogging != false ? "true" : "false");
    dash.currentPage = 'routes';
</script>

<script>
    // View toggle for routes
    window.RoutesView = {
        current: localStorage.getItem('routes_view') || 'cards',
        toggle: function(view) {
            this.current = view;
            localStorage.setItem('routes_view', view);
            var cardsView = document.getElementById('route-cards-view');
            var tableView = document.getElementById('route-table-view');
            var btns = document.querySelectorAll('.view-toggle');
            btns.forEach(function(b) {
                if (b.dataset.view === view) {
                    b.style.background = 'var(--primary-color)';
                    b.style.color = '#fff';
                    b.classList.add('active');
                } else {
                    b.style.background = 'var(--card-bg)';
                    b.style.color = 'var(--text-secondary)';
                    b.classList.remove('active');
                }
            });
            if (cardsView) cardsView.style.display = view === 'cards' ? '' : 'none';
            if (tableView) tableView.style.display = view === 'table' ? '' : 'none';
        }
    };
    document.addEventListener('DOMContentLoaded', function() {
        var saved = localStorage.getItem('routes_view') || 'cards';
        RoutesView.toggle(saved);
    });
</script>

<script>
    (async function() {
        DashboardApi.init();
        if (window.DashboardApp?.modules?.routes?.init) await DashboardApp.modules.routes.init();
        if (window.DashboardApp?.modules?.routes?.loadRoutes) await DashboardApp.modules.routes.loadRoutes();
        document.dispatchEvent(new CustomEvent('dashboard:ready'));
    })();

    window.routesRefresh = async function(btn) {
        var originalText = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-1"></i>';
        btn.disabled = true;
        try {
            await window.DashboardApp?.modules?.routes?.loadRoutes?.();
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    };
</script>

<style>
@@keyframes spin { to { transform: rotate(360deg); } }
.spin { display:inline-block; animation: spin .6s linear infinite; }
</style>
}
