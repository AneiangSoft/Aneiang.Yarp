@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Routes" : "路由配置";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Route panel -->
<div id="route-panel" class="card-panel mb-4">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2" style="color:#f59e0b;"></i><span data-i18n="index.route.title">路由规则列表</span></span>
        <div class="card-header-actions">
            <button class="btn btn-sm btn-outline-primary" onclick="DashboardWizard.open(window._clusters || [])">
                <i class="bi bi-magic"></i> <span data-i18n="route.wizard">使用向导</span>
            </button>
            <span class="refresh-badge" id="route-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.route.showing">显示 </span><strong id="route-display-count">0</strong><span data-i18n="index.route.of"> / </span><span id="route-total-count">0</span><span data-i18n="index.route.entries"> 个</span></span>
        </div>
    </div>
    
    <!-- Filter toolbar container -->
    <div id="route-filter-container"></div>

    <!-- Table view -->
    <div id="route-table-view">
        <div class="table-responsive">
            <table class="table table-hover table-striped-custom align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:36px"></th>
                        <th style="width:80px;white-space:nowrap"><span data-i18n="index.route.orderCol">优先级</span></th>
                        <th style="width:22%"><span data-i18n="index.route.th.name">路由名称</span></th>
                        <th><span data-i18n="index.route.th.path">匹配路径</span></th>
                        <th style="width:140px"><span data-i18n="index.route.clusterCol">集群</span></th>
                        <th style="width:120px"><span data-i18n="index.route.methodCol">方法</span></th>
                        <th style="width:80px"><span data-i18n="index.route.th.actions">操作</span></th>
                    </tr>
                </thead>
                <tbody id="route-tbody">
                    <tr><td colspan="7" class="text-center py-4">
                        <div style="padding:4px 0;">
                            <div class="skeleton skeleton-line long"></div>
                            <div class="skeleton skeleton-line medium"></div>
                            <div class="skeleton skeleton-line short"></div>
                        </div>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- cURL Export Modal -->
<div class="modal fade" id="curl-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-terminal"></i> cURL 命令</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small">使用此 cURL 命令测试路由配置是否生效。</p>
                <div class="mb-2">
                    <label class="form-label small">HTTP 方法</label>
                    <select class="form-select form-select-sm" id="curl-method" onchange="DashboardCurl.generate()">
                        <option value="GET">GET</option>
                        <option value="POST">POST</option>
                        <option value="PUT">PUT</option>
                        <option value="DELETE">DELETE</option>
                        <option value="PATCH">PATCH</option>
                    </select>
                </div>
                <div class="mb-2">
                    <label class="form-label small">测试路径</label>
                    <input type="text" class="form-control form-control-sm" id="curl-path" oninput="DashboardCurl.generate()">
                </div>
                <div class="mb-3">
                    <label class="form-label small">cURL 命令</label>
                    <pre class="bg-dark text-light p-3 rounded" style="max-height:200px;overflow:auto;"><code id="curl-output"></code></pre>
                </div>
                <button class="btn btn-sm btn-outline-primary w-100" onclick="DashboardCurl.copy()"><i class="bi bi-clipboard"></i> 复制到剪贴板</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-schema-service.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-schema-validator.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/lazy-monaco-loader.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-monaco-editor.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-config-editor.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-form-builder.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-diff-panel.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-validation-panel.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-routes.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-wizard.js?v=@v"></script>
<!-- Page config (shared scripts now in _DashboardLayout.cshtml) -->
@await Html.PartialAsync("_DashboardPageInit")

<script>
    (async function() {
        DashboardApi.init();
        if (window.DashboardApp?.modules?.routes?.init) await DashboardApp.modules.routes.init();
        if (window.DashboardApp?.modules?.routes?.loadRoutes) await DashboardApp.modules.routes.loadRoutes();

        // Load clusters for wizard
        try {
            var clusterData = await DashboardApi.endpoints.getClusters();
            window._clusters = clusterData || [];
        } catch(e) { window._clusters = []; }

        // Empty state guidance
        var routeCount = document.getElementById('route-total-count');
        if (routeCount && parseInt(routeCount.textContent) === 0) {
            var tbody = document.getElementById('route-tbody');
            if (tbody) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center py-5">' +
                    '<div class="mb-3"><i class="bi bi-signpost-split" style="font-size:48px;color:#dee2e6;"></i></div>' +
                    '<h5>还没有配置任何路由</h5>' +
                    '<p class="text-muted">开始使用：</p>' +
                    '<div class="d-flex justify-content-center gap-2">' +
                    '<a href="/apigateway/templates" class="btn btn-outline-primary"><i class="bi bi-file-earmark-code"></i> 从模板创建</a>' +
                    '<button class="btn btn-primary" onclick="DashboardWizard.open(window._clusters || [])"><i class="bi bi-magic"></i> 使用向导</button>' +
                    '</div>' +
                    '<div class="mt-2 small text-muted"><i class="bi bi-lightbulb"></i> 建议：点击"使用向导"快速开始</div>' +
                    '</td></tr>';
            }
        }

        document.dispatchEvent(new CustomEvent('dashboard:ready'));
    })();

    window.routesRefresh = async function(btn) {
        var originalText = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-1"></i>';
        btn.disabled = true;
        try {
            await window.DashboardApp?.modules?.routes?.loadRoutes?.();
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    };

    // cURL Export
    window.DashboardCurl = {
        currentRoute: null,

        showForRoute: function(routeId, path, methods) {
            this.currentRoute = { routeId: routeId, path: path, methods: methods };
            var testPath = path ? path.replace(/\{[^}]+\}/g, 'test') : '/';
            document.getElementById('curl-path').value = testPath;
            var methodSelect = document.getElementById('curl-method');
            if (methods && methods.length > 0) {
                methodSelect.value = methods[0];
            } else {
                methodSelect.value = 'GET';
            }
            this.generate();
            new bootstrap.Modal(document.getElementById('curl-modal')).show();
        },

        generate: function() {
            var method = document.getElementById('curl-method').value;
            var path = document.getElementById('curl-path').value || '/';
            if (!path.startsWith('/')) path = '/' + path;
            var origin = window.location.origin;

            var curl = 'curl -X ' + method + ' \'' + origin + path + '\'';
            if (method === 'POST' || method === 'PUT' || method === 'PATCH') {
                curl += ' \\\n  -H \'Content-Type: application/json\' \\\n  -d \'{"key":"value"}\'';
            }
            curl += ' \\\n  -w \'\\nHTTP Status: %{http_code}\\nTime: %{time_total}s\\n\'';

            document.getElementById('curl-output').textContent = curl;
        },

        copy: function() {
            var text = document.getElementById('curl-output').textContent;
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text).then(function() {
                    if (window.DashboardModals) window.DashboardModals.showSuccess('已复制到剪贴板');
                });
            } else {
                var textarea = document.createElement('textarea');
                textarea.value = text;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                document.body.removeChild(textarea);
                if (window.DashboardModals) window.DashboardModals.showSuccess('已复制到剪贴板');
            }
        }
    };

    // Global function for route table buttons
    window.showCurlForRoute = function(routeId, path, methods) {
        DashboardCurl.showForRoute(routeId, path, methods);
    };
</script>
}
