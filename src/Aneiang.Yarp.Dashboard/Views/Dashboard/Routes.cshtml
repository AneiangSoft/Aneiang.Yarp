@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Routes" : "路由配置";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Route panel -->
<div id="route-panel" class="card-panel mb-4">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2" style="color:#f59e0b;"></i><span data-i18n="index.route.title">路由规则列表</span></span>
        <div class="card-header-actions">
            <span class="refresh-badge" id="route-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.route.showing">显示 </span><strong id="route-display-count">0</strong><span data-i18n="index.route.of"> / </span><span id="route-total-count">0</span><span data-i18n="index.route.entries"> 个</span></span>
        </div>
    </div>
    
    <!-- Filter toolbar container -->
    <div id="route-filter-container"></div>

    <!-- Table view -->
    <div id="route-table-view">
        <div class="table-responsive">
            <table class="table table-hover table-striped-custom align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:36px"></th>
                        <th style="width:80px;white-space:nowrap"><span data-i18n="index.route.orderCol">优先级</span></th>
                        <th style="width:22%"><span data-i18n="index.route.th.name">路由名称</span></th>
                        <th><span data-i18n="index.route.th.path">匹配路径</span></th>
                        <th style="width:140px"><span data-i18n="index.route.clusterCol">集群</span></th>
                        <th style="width:120px"><span data-i18n="index.route.methodCol">方法</span></th>
                        <th style="width:80px"><span data-i18n="index.route.th.actions">操作</span></th>
                    </tr>
                </thead>
                <tbody id="route-tbody">
                    <tr><td colspan="7" class="text-center py-4">
                        <div style="padding:4px 0;">
                            <div class="skeleton skeleton-line long"></div>
                            <div class="skeleton skeleton-line medium"></div>
                            <div class="skeleton skeleton-line short"></div>
                        </div>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
@{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-schema-service.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-schema-validator.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/lazy-monaco-loader.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-monaco-editor.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-config-editor.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-form-builder.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-diff-panel.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-validation-panel.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-routes.js?v=@v"></script>
<!-- Page config (shared scripts now in _DashboardLayout.cshtml) -->
@await Html.PartialAsync("_DashboardPageInit")

<script>
    (async function() {
        DashboardApi.init();
        if (window.DashboardApp?.modules?.routes?.init) await DashboardApp.modules.routes.init();
        if (window.DashboardApp?.modules?.routes?.loadRoutes) await DashboardApp.modules.routes.loadRoutes();
        document.dispatchEvent(new CustomEvent('dashboard:ready'));
    })();

    window.routesRefresh = async function(btn) {
        var originalText = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-1"></i>';
        btn.disabled = true;
        try {
            await window.DashboardApp?.modules?.routes?.loadRoutes?.();
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    };
</script>

<style>
@@keyframes spin { to { transform: rotate(360deg); } }
.spin { display:inline-block; animation: spin .6s linear infinite; }
</style>
}
