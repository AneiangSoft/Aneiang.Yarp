@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Logs" : "日志";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    /* ── Log filter toolbar ── */
    #log-filter-container .card-body { padding: 10px 16px !important; }
    #log-filter-container .row { gap: 6px 10px; }

    /* ── Log scroll container ── */
    .log-scroll-wrap {
        height: calc(100vh - 280px); min-height: 300px; overflow-y: auto;
        padding: 4px 8px;
    }
    @@media (max-width: 768px) {
        .log-scroll-wrap { height: calc(100vh - 220px); }
    }
    #log-entries { display: flex; flex-direction: column; gap: 6px; }

    /* ── Log item row (each entry) ── */
    .log-item { border-radius: 6px; border: 1px solid transparent; }
    .log-item .log-row {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 12px; cursor: pointer;
        transition: background .15s;
    }
    .log-item .log-row:hover { background: rgba(148,163,184,.08); }

    /* ── Badges & small elements ── */
    .log-row .badge { padding: 2px 7px; font-size: 11px; line-height: 1.4; }
    .log-row code { font-size: 12px !important; padding: 2px 8px !important; }
    .log-row .log-event-tag { font-size: 11px; white-space: nowrap; }

    /* ── Paired request/response detail ── */
    .log-detail { padding: 12px 16px; background: #f8fafc; border-top: 1px solid var(--border-color,#e2e8f0); }
    .log-flow { display: flex; flex-direction: column; gap: 10px; }
    .log-flow-section { padding: 8px 12px; border-radius: 6px; background: #fff; border: 1px solid #e2e8f0; }
    .log-flow-title { font-weight: 600; font-size: 12px; margin-bottom: 6px; color: #475569; }
    .log-flow-body { font-size: 12px; color: #334155; }
    .log-flow-body > div { margin-bottom: 3px; }
    .log-meta-row { display: flex; gap: 14px; flex-wrap: wrap; padding: 4px 0; font-size: 12px; }
    .log-flow-arrow { text-align: center; font-size: 14px; color: #94a3b8; padding: 2px 0; }
</style>

<!-- Log panel -->
<div id="log-panel" class="card-panel mb-4">
    <div class="card-header">
        <span><i class="bi bi-journal-text me-2" style="color:#8b5cf6;"></i><span data-i18n="index.log.title">YARP 实时日志</span></span>
        <div class="card-header-actions">
            <span class="pulse-dot me-1"></span>
            <span class="refresh-badge" id="log-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.log.showing">显示 </span><strong id="log-display-count">0</strong><span data-i18n="index.log.of"> / </span><span id="log-total-count">0</span><span data-i18n="index.log.entries"> 条</span></span>
        </div>
    </div>
    
    <!-- Filter toolbar container -->
    <div id="log-filter-container"></div>
    
    <div class="log-scroll-wrap" id="log-scroll-container">
        <div id="log-entries" class="log-entries-container">
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-journal-text"></i></div>
                <div class="empty-state-title" data-i18n="index.log.empty">暂无日志</div>
                <div class="empty-state-desc">等待请求流量进入网关后，日志将实时显示此处</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-logs.js?v=@v"></script>

@await Html.PartialAsync("_DashboardPageInit")

<script>
    (async function() {
        if (window.DashboardUtils) DashboardUtils.init();
        if (window.DashboardApi) DashboardApi.init();
        if (window.DashboardState) DashboardState.init();
        if (window.DashboardStorage) DashboardStorage.init();
        if (window.DashboardModals) DashboardModals.init();
        if (window.DashboardEvents) DashboardEvents.setup();

        if (window.DashboardApp?.modules?.logs?.init) await DashboardApp.modules.logs.init();
        if (window.DashboardApp?.modules?.logs?.loadLogs) await DashboardApp.modules.logs.loadLogs();

        document.dispatchEvent(new CustomEvent('dashboard:ready'));
    })();
</script>
}
