@{
    ViewData["Title"] = (ViewBag.Locale as string) == "en-US" ? "Overview" : "总览";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Stat cards (visible on all tabs) -->
<div id="stat-bar" class="row g-3 mb-4">
    <!-- Gateway info -->
    <div class="col-12 mb-1">
        <div class="card-panel px-4 py-3 d-flex flex-wrap gap-4 align-items-center" style="font-size:13px;color:#475569;">
            <span><i class="bi bi-cpu me-1"></i><span data-i18n="index.label.version">版本：</span><strong id="info-version">-</strong></span>
            <span><i class="bi bi-cloud me-1"></i><span data-i18n="index.label.env">环境：</span><strong id="info-env">-</strong></span>
            <span><i class="bi bi-play-circle me-1"></i><span data-i18n="index.label.start">启动：</span><strong id="info-start">-</strong></span>
            <span><i class="bi bi-clock-history me-1"></i><span data-i18n="index.label.uptime">运行：</span><strong id="info-uptime">-</strong></span>
            <span><i class="bi bi-memory me-1"></i><span data-i18n="index.label.memory">内存：</span><strong id="info-memory">-</strong></span>
            <span><i class="bi bi-pc-display me-1"></i><span data-i18n="index.label.host">主机：</span><strong id="info-machine">-</strong></span>
            <span class="ms-auto">
                <button class="btn btn-sm btn-outline-primary" onclick="manualRefresh(this)">
                    <i class="bi bi-arrow-clockwise me-1"></i><span data-i18n="index.btn.refresh">刷新</span>
                </button>
            </span>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-clusters">-</div>
                    <div class="stat-label" data-i18n="index.stat.clusters">服务集群</div>
                </div>
                <div class="stat-icon" style="background:#eff6ff;color:#3b82f6;"><i class="bi bi-diagram-3"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-healthy" style="color:#22c55e;">-</div>
                    <div class="stat-label" data-i18n="index.stat.health">健康 / 未知 / 异常</div>
                </div>
                <div class="stat-icon" style="background:#f0fdf4;color:#22c55e;"><i class="bi bi-heart-pulse"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-routes">-</div>
                    <div class="stat-label" data-i18n="index.stat.routes">路由规则</div>
                </div>
                <div class="stat-icon" style="background:#fefce8;color:#eab308;"><i class="bi bi-signpost-split"></i></div>
            </div>
        </div>
    </div>
</div>

<!-- Cluster panel -->
<div id="cluster-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-hdd-stack me-2"></i><span data-i18n="index.cluster.title">集群 &amp; 目标节点状态</span></span>
        <div class="d-flex align-items-center gap-3">
            <span class="refresh-badge" id="cluster-refresh-time"></span>
            <button class="btn btn-sm btn-outline-secondary" onclick="manualRefresh(this)">
                <i class="bi bi-arrow-clockwise me-1"></i><span data-i18n="index.btn.refresh">刷新</span>
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width:22%"><span data-i18n="index.cluster.th.name">集群名称</span></th>
                    <th style="width:12%"><span data-i18n="index.cluster.th.dest">节点名</span></th>
                    <th style="width:28%"><span data-i18n="index.cluster.th.address">目标地址</span></th>
                    <th style="width:14%"><span data-i18n="index.cluster.th.active">主动健康</span></th>
                    <th style="width:14%"><span data-i18n="index.cluster.th.passive">被动健康</span></th>
                    <th style="width:10%"><span data-i18n="index.cluster.th.policy">均衡策略</span></th>
                </tr>
            </thead>
            <tbody id="cluster-tbody">
                <tr><td colspan="6" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Route panel -->
<div id="route-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2"></i><span data-i18n="index.route.title">路由规则列表</span></span>
        <div class="d-flex align-items-center gap-3">
            <span class="refresh-badge" id="route-refresh-time"></span>
            <button class="btn btn-sm btn-outline-secondary" onclick="manualRefresh(this)">
                <i class="bi bi-arrow-clockwise me-1"></i><span data-i18n="index.btn.refresh">刷新</span>
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width:8%"><span data-i18n="index.route.th.order">优先级</span></th>
                    <th style="width:22%"><span data-i18n="index.route.th.name">路由名称</span></th>
                    <th style="width:35%"><span data-i18n="index.route.th.path">匹配路径</span></th>
                    <th style="width:20%"><span data-i18n="index.route.th.cluster">关联集群</span></th>
                    <th style="width:15%"><span data-i18n="index.route.th.methods">允许方法</span></th>
                </tr>
            </thead>
            <tbody id="route-tbody">
                <tr><td colspan="5" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Log panel -->
<div id="log-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-journal-text me-2"></i><span data-i18n="index.log.title">YARP 实时日志</span></span>
        <div class="d-flex align-items-center flex-wrap" style="gap:6px 16px;">
            <!-- filter -->
            <label class="mb-0" style="cursor:pointer;user-select:none;">
                <input type="checkbox" id="log-gateway-only" onchange="onGatewayOnlyChange()" style="margin-right:4px;">
                <small data-i18n="index.log.gatewayOnly">仅请求日志</small>
            </label>
            <span class="refresh-badge" id="log-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.log.showing">显示 </span><strong id="log-display-count">0</strong><span data-i18n="index.log.of"> / </span><span id="log-total-count">0</span><span data-i18n="index.log.entries"> 条</span></span>
            <!-- action buttons -->
            <button class="btn btn-sm btn-outline-success" id="log-listen-btn" onclick="toggleListening()">
                <i class="bi bi-play-circle me-1"></i><span data-i18n="index.log.startListen">开启监听</span>
            </button>
            <button class="btn btn-sm btn-outline-secondary" onclick="loadLogs()">
                <i class="bi bi-arrow-clockwise me-1"></i><span data-i18n="index.btn.refresh">刷新</span>
            </button>
            <button class="btn btn-sm btn-outline-danger" onclick="clearLogs()">
                <i class="bi bi-trash me-1"></i><span data-i18n="index.log.clear">清空</span>
            </button>
        </div>
    </div>
    <div style="max-height:600px;overflow-y:auto;" id="log-scroll-container">
        <div id="log-entries" style="padding:0;">
            <div class="text-center text-muted py-4" data-i18n="index.log.empty">暂无日志</div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const basePath = '/' + '@ViewBag.DashboardRoutePrefix';
    const token = localStorage.getItem('dashboard_token');

    // Log listening state
    let listeningEnabled = false;
    let logPollTimer = null;

    // Fetch wrapper with JWT authorization + 401 redirect
    async function authFetch(url, options) {
        options = options || {};
        options.headers = options.headers || {};
        if (token) {
            options.headers['Authorization'] = 'Bearer ' + token;
            options.headers['X-Requested-With'] = 'XMLHttpRequest';
        }
        const res = await fetch(url, options);
        if (res.status === 401) {
            localStorage.removeItem('dashboard_token');
            window.location.href = basePath + '/login';
            throw new Error('Unauthorized');
        }
        return res;
    }

   const logPanelEnabled = @(ViewBag.EnableProxyLogging != false ? "true" : "false");

    // ===== Tab panel visibility (stat-bar always visible) =====
    const tabPanels = {
        overview: [],
        services: ['cluster-panel'],
        routes:   ['route-panel']
    };
    if (logPanelEnabled) {
        tabPanels.logs = ['log-panel'];
    }
    const allPanels = ['cluster-panel', 'route-panel'];
    if (logPanelEnabled) {
        allPanels.push('log-panel');
    }

    function switchTab(tabName) {
        // Update sidebar active state
        document.querySelectorAll('.sidebar .nav-link[data-tab]').forEach(l => {
            l.classList.toggle('active', l.dataset.tab === tabName);
        });
        // Show/hide panels
        allPanels.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.style.display = (tabPanels[tabName] || []).includes(id) ? '' : 'none';
        });
    }

    document.querySelectorAll('.sidebar .nav-link[data-tab]').forEach(link => {
        link.addEventListener('click', e => {
            e.preventDefault();
            switchTab(link.dataset.tab);
        });
    });

    // ===== Utility functions =====
    function timeStr() {
        return new Date().toLocaleTimeString(CURRENT_LOCALE === 'en-US' ? 'en-US' : 'zh-CN', { hour12: false });
    }

    function healthDot(status) {
        const s = (status || '').toLowerCase();
        if (s === 'healthy')   return '<span class="health-dot healthy"></span><span style="color:#22c55e;">' + __('index.health.healthy') + '</span>';
        if (s === 'unhealthy') return '<span class="health-dot unhealthy"></span><span style="color:#ef4444;">' + __('index.health.unhealthy') + '</span>';
        return '<span class="health-dot unknown"></span><span style="color:#f59e0b;">' + __('index.health.unknown') + '</span>';
    }

    // ===== Load gateway info =====
    async function loadInfo() {
        try {
            const res  = await authFetch(basePath + '/info');
            const json = await res.json();
            if (json.code !== 200) return;
            const d = json.data;
            document.getElementById('info-version').textContent = d.version;
            document.getElementById('info-env').textContent     = d.environment;
            document.getElementById('info-start').textContent   = d.startTime;
            document.getElementById('info-uptime').textContent  = d.uptime;
            document.getElementById('info-memory').textContent  = d.memoryMb + ' MB';
            document.getElementById('info-machine').textContent = d.machineName;
        } catch (e) { console.error(__('index.js.loadInfoFailed'), e); }
    }

    // ===== Load cluster data =====
    async function loadClusters() {
        try {
            const res  = await authFetch(basePath + '/clusters');
            const json = await res.json();
            if (json.code !== 200) return;
            const clusters = json.data;

            let totalHealthy = 0, totalUnknown = 0, totalUnhealthy = 0;
            let html = '';
            clusters.forEach(c => {
                totalHealthy   += c.healthyCount   || 0;
                totalUnknown   += c.unknownCount   || 0;
                totalUnhealthy += c.unhealthyCount || 0;

                const rowspan = c.destinations.length || 1;
                c.destinations.forEach((d, i) => {
                    html += '<tr class="cluster-row" data-cluster="' + escapeHtml(c.clusterId) + '" style="cursor:pointer;">';
                    if (i === 0) {
                        html += '<td rowspan="' + rowspan + '" style="font-weight:600;vertical-align:middle;"><span class="cluster-expand-icon" style="display:inline-block;width:16px;">\u25B6</span> ' + c.clusterId + '</td>';
                    }
                    html += '<td><code>' + d.name + '</code></td>';
                    html += '<td><a href="' + d.address + '" target="_blank" class="text-decoration-none">' + d.address + '</a></td>';
                    if (d.health) html += '<td><span style="color:#64748b;">' + escapeHtml(d.health) + '</span></td>';
                    else html += '<td>' + healthDot(d.activeHealth || 'Unknown') + '</td>';
                    html += '<td>' + healthDot(d.passiveHealth || 'Unknown') + '</td>';
                    if (i === 0) {
                        html += '<td rowspan="' + rowspan + '" style="vertical-align:middle;"><span class="badge bg-secondary">' + c.loadBalancingPolicy + '</span></td>';
                    }
                    html += '</tr>';
                });

                // Expandable detail row
                html += '<tr class="cluster-detail" data-cluster="' + escapeHtml(c.clusterId) + '" style="display:none;">';
                html += '<td colspan="6" style="padding:0;">';
                html += '<div style="padding:14px 20px;background:#f8fafc;border-bottom:2px solid #e2e8f0;font-size:13px;line-height:1.8;">';

                // ClusterId + LoadBalancingPolicy
                html += '<div style="display:flex;flex-wrap:wrap;gap:8px 24px;margin-bottom:6px;">';
                html += '<span><strong>ClusterId:</strong> ' + escapeHtml(c.clusterId) + '</span>';
                html += '<span><strong>LoadBalancingPolicy:</strong> <span class="badge bg-secondary">' + escapeHtml(c.loadBalancingPolicy) + '</span></span>';
                html += '</div>';

                // Destinations detail
                if (c.destinations && c.destinations.length > 0) {
                    html += '<div style="margin-top:6px;margin-bottom:4px;"><strong>' + __('index.detail.destinations') + ' (' + c.destinations.length + '):</strong></div>';
                    html += '<table style="margin:0 0 6px 0;border-collapse:collapse;font-size:12px;width:auto;">';
                    html += '<tr style="background:#e2e8f0;"><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.name') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.address') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.healthUrl') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.host') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.active') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.passive') + '</th></tr>';
                    c.destinations.forEach(function(d) {
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;"><code>' + escapeHtml(d.name) + '</code></td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (d.address ? '<a href="' + escapeHtml(d.address) + '" target="_blank">' + escapeHtml(d.address) + '</a>' : '<span class="text-muted">-</span>') + '</td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (d.health ? escapeHtml(d.health) : '<span class="text-muted">-</span>') + '</td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (d.host ? escapeHtml(d.host) : '<span class="text-muted">-</span>') + '</td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + healthDot(d.activeHealth) + '</td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + healthDot(d.passiveHealth) + '</td></tr>';
                    });
                    html += '</table>';

                    // Destination metadata
                    c.destinations.forEach(function(d) {
                        if (d.metadata) {
                            var dmetaKeys = Object.keys(d.metadata);
                            if (dmetaKeys.length > 0) {
                                html += '<div style="margin-top:4px;margin-bottom:4px;"><strong>' + __('index.detail.metadata') + ' [' + d.name + ']:</strong></div>';
                                html += '<table style="margin:0 0 6px 20px;border-collapse:collapse;font-size:12px;width:auto;">';
                                html += '<tr style="background:#e2e8f0;"><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.key') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.value') + '</th></tr>';
                                for (var dmi = 0; dmi < dmetaKeys.length; dmi++) {
                                    var dmk = dmetaKeys[dmi];
                                    html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;"><code>' + escapeHtml(dmk) + '</code></td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + escapeHtml(d.metadata[dmk]) + '</td></tr>';
                                }
                                html += '</table>';
                            }
                        }
                    });
                }

                // Session Affinity
                if (c.sessionAffinity) {
                    var sa = c.sessionAffinity;
                    html += '<div style="margin-top:6px;margin-bottom:4px;"><strong>' + __('index.detail.sessionAffinity') + '</strong></div>';
                    html += '<table style="margin:0 0 6px 0;border-collapse:collapse;font-size:12px;width:auto;">';
                    html += '<tr style="background:#e2e8f0;"><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.property') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.value') + '</th></tr>';
                    html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Enabled</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.enabled ? 'true' : 'false') + '</td></tr>';
                    html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Policy</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.policy || '-') + '</td></tr>';
                    html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">FailurePolicy</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.failurePolicy || '-') + '</td></tr>';
                    html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">AffinityKeyName</td><td style="padding:2px 10px;border:1px solid #e2e8f0;"><code>' + escapeHtml(sa.affinityKeyName) + '</code></td></tr>';
                    if (sa.cookie) {
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Cookie.Domain</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + escapeHtml(sa.cookie.domain || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Cookie.Path</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + escapeHtml(sa.cookie.path || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Cookie.Expiration</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.cookie.expiration || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Cookie.MaxAge</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.cookie.maxAge || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Cookie.SecurePolicy</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.cookie.securePolicy || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Cookie.HttpOnly</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.cookie.httpOnly ? 'true' : 'false') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Cookie.SameSite</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.cookie.sameSite || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Cookie.IsEssential</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (sa.cookie.isEssential ? 'true' : 'false') + '</td></tr>';
                    }
                    html += '</table>';
                }

                // Health Check
                if (c.healthCheck) {
                    var hc = c.healthCheck;
                    html += '<div style="margin-top:6px;margin-bottom:4px;"><strong>' + __('index.detail.healthCheck') + '</strong></div>';
                    html += '<table style="margin:0 0 6px 0;border-collapse:collapse;font-size:12px;width:auto;">';
                    html += '<tr style="background:#e2e8f0;"><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.property') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;">' + __('index.detail.value') + '</th></tr>';
                    html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">AvailableDestinationsPolicy</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.availableDestinationsPolicy || '-') + '</td></tr>';
                    if (hc.active) {
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Active.Enabled</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.active.enabled ? 'true' : 'false') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Active.Interval</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.active.interval || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Active.Timeout</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.active.timeout || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Active.Policy</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.active.policy || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Active.Path</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.active.path || '-') + '</td></tr>';
                        if (hc.active.query)
                            html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Active.Query</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + escapeHtml(hc.active.query) + '</td></tr>';
                    }
                    if (hc.passive) {
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Passive.Enabled</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.passive.enabled ? 'true' : 'false') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Passive.Policy</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.passive.policy || '-') + '</td></tr>';
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">Passive.ReactivationPeriod</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (hc.passive.reactivationPeriod || '-') + '</td></tr>';
                    }
                    html += '</table>';
                }

                // HttpClient
                if (c.httpClient) {
                    var hcl = c.httpClient;
                    html += '<div style="margin-top:6px;margin-bottom:4px;"><strong>' + __('index.detail.httpClient') + '</strong></div>';
