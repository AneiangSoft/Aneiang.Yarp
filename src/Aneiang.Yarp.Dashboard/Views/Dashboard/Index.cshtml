@{
    ViewData["Title"] = (ViewBag.Locale as string) == "en-US" ? "Overview" : "总览";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Stat cards (visible on all tabs) -->
<div id="stat-bar" class="row g-3 mb-4">
    <!-- Gateway info -->
    <div class="col-12 mb-1">
        <div class="card-panel px-4 py-3 d-flex flex-wrap gap-4 align-items-center" style="font-size:13px;color:#475569;">
            <span><i class="bi bi-cpu me-1"></i><span data-i18n="index.label.version">版本：</span><strong id="info-version">-</strong></span>
            <span><i class="bi bi-cloud me-1"></i><span data-i18n="index.label.env">环境：</span><strong id="info-env">-</strong></span>
            <span><i class="bi bi-play-circle me-1"></i><span data-i18n="index.label.start">启动：</span><strong id="info-start">-</strong></span>
            <span><i class="bi bi-clock-history me-1"></i><span data-i18n="index.label.uptime">运行：</span><strong id="info-uptime">-</strong></span>
            <span><i class="bi bi-memory me-1"></i><span data-i18n="index.label.memory">内存：</span><strong id="info-memory">-</strong></span>
            <span><i class="bi bi-pc-display me-1"></i><span data-i18n="index.label.host">主机：</span><strong id="info-machine">-</strong></span>
            <span class="ms-auto">
                <button class="btn btn-sm btn-outline-primary" onclick="manualRefresh(this)">
                    <i class="bi bi-arrow-clockwise me-1"></i><span data-i18n="index.btn.refresh">刷新</span>
                </button>
            </span>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-clusters">-</div>
                    <div class="stat-label" data-i18n="index.stat.clusters">服务集群</div>
                </div>
                <div class="stat-icon" style="background:#eff6ff;color:#3b82f6;"><i class="bi bi-diagram-3"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-healthy" style="color:#22c55e;">-</div>
                    <div class="stat-label" data-i18n="index.stat.health">健康 / 未知 / 异常</div>
                </div>
                <div class="stat-icon" style="background:#f0fdf4;color:#22c55e;"><i class="bi bi-heart-pulse"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-routes">-</div>
                    <div class="stat-label" data-i18n="index.stat.routes">路由规则</div>
                </div>
                <div class="stat-icon" style="background:#fefce8;color:#eab308;"><i class="bi bi-signpost-split"></i></div>
            </div>
        </div>
    </div>
</div>

<!-- Cluster panel -->
<div id="cluster-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-hdd-stack me-2"></i><span data-i18n="index.cluster.title">集群 &amp; 目标节点状态</span></span>
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-sm btn-success" onclick="showAddClusterModal()">
                <i class="bi bi-plus-circle me-1"></i><span data-i18n="index.cluster.add">新增</span>
            </button>
            <span class="refresh-badge" id="cluster-refresh-time"></span>
            <button class="btn btn-sm btn-outline-secondary" onclick="manualRefresh(this)">
                <i class="bi bi-arrow-clockwise me-1"></i><span data-i18n="index.btn.refresh">刷新</span>
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width:20%"><span data-i18n="index.cluster.th.name">集群名称</span></th>
                    <th style="width:10%"><span data-i18n="index.cluster.th.dest">节点名</span></th>
                    <th style="width:25%"><span data-i18n="index.cluster.th.address">目标地址</span></th>
                    <th style="width:12%"><span data-i18n="index.cluster.th.active">主动健康</span></th>
                    <th style="width:12%"><span data-i18n="index.cluster.th.passive">被动健康</span></th>
                    <th style="width:8%"><span data-i18n="index.cluster.th.policy">均衡策略</span></th>
                    <th style="width:5%"><span data-i18n="index.cluster.th.actions">操作</span></th>
                </tr>
            </thead>
            <tbody id="cluster-tbody">
                <tr><td colspan="6" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Route panel -->
<div id="route-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2"></i><span data-i18n="index.route.title">路由规则列表</span></span>
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-sm btn-success" onclick="showAddRouteModal()">
                <i class="bi bi-plus-circle me-1"></i><span data-i18n="index.route.add">新增</span>
            </button>
            <span class="refresh-badge" id="route-refresh-time"></span>
            <button class="btn btn-sm btn-outline-secondary" onclick="manualRefresh(this)">
                <i class="bi bi-arrow-clockwise me-1"></i><span data-i18n="index.btn.refresh">刷新</span>
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width:8%"><span data-i18n="index.route.th.order">优先级</span></th>
                    <th style="width:22%"><span data-i18n="index.route.th.name">路由名称</span></th>
                    <th style="width:35%"><span data-i18n="index.route.th.path">匹配路径</span></th>
                    <th style="width:20%"><span data-i18n="index.route.th.cluster">关联集群</span></th>
                    <th style="width:10%"><span data-i18n="index.route.th.methods">允许方法</span></th>
                    <th style="width:5%"><span data-i18n="index.route.th.actions">操作</span></th>
                </tr>
            </thead>
            <tbody id="route-tbody">
                <tr><td colspan="5" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Log panel -->
<div id="log-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-journal-text me-2"></i><span data-i18n="index.log.title">YARP 实时日志</span></span>
        <div class="d-flex align-items-center flex-wrap" style="gap:6px 16px;">
            <!-- filter -->
            <label class="mb-0" style="cursor:pointer;user-select:none;">
                <input type="checkbox" id="log-gateway-only" onchange="onGatewayOnlyChange()" style="margin-right:4px;">
                <small data-i18n="index.log.gatewayOnly">仅请求日志</small>
            </label>
            <span class="refresh-badge" id="log-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.log.showing">显示 </span><strong id="log-display-count">0</strong><span data-i18n="index.log.of"> / </span><span id="log-total-count">0</span><span data-i18n="index.log.entries"> 条</span></span>
            <!-- action buttons -->
            <button class="btn btn-sm btn-outline-success" id="log-listen-btn" onclick="toggleListening()">
                <i class="bi bi-play-circle me-1"></i><span data-i18n="index.log.startListen">开启监听</span>
            </button>
            <button class="btn btn-sm btn-outline-secondary" onclick="loadLogs()">
                <i class="bi bi-arrow-clockwise me-1"></i><span data-i18n="index.btn.refresh">刷新</span>
            </button>
            <button class="btn btn-sm btn-outline-danger" onclick="clearLogs()">
                <i class="bi bi-trash me-1"></i><span data-i18n="index.log.clear">清空</span>
            </button>
        </div>
    </div>
    <div style="max-height:600px;overflow-y:auto;" id="log-scroll-container">
        <div id="log-entries" style="padding:0;">
            <div class="text-center text-muted py-4" data-i18n="index.log.empty">暂无日志</div>
        </div>
    </div>
</div>

@section Scripts {
<script src="/_content/Aneiang.Yarp.Dashboard/js/dashboard-core.js"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/dashboard-clusters.js"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/dashboard-routes.js"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/dashboard-logs.js"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/dashboard-modals.js"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/json-editor.js"></script>
<script>
    window.__dashboard = window.__dashboard || {};
    var dash = window.__dashboard;
    dash.basePath = '/' + '@ViewBag.DashboardRoutePrefix';
    dash.token = localStorage.getItem('dashboard_token');
    dash.CURRENT_LOCALE = '@ViewBag.Locale';
    dash.I18N = @Html.Raw(ViewBag.AllI18nJson ?? "{}");
    dash.logPanelEnabled = @(ViewBag.EnableProxyLogging != false ? "true" : "false");
    if (dash.logPanelEnabled) {
        dash.tabPanels.logs = ['log-panel'];
        dash.allPanels.push('log-panel');
    }
    (function() {
        var logPanelEnabled = dash.logPanelEnabled;
        window.refreshAll();
        if (logPanelEnabled) { window.loadLogs(); }
    })();
</script>
<style>
@@keyframes spin { to { transform: rotate(360deg); } }
.spin { display:inline-block; animation: spin .6s linear infinite; }
</style>
}