                    html += '<table style="margin:0 0 6px 0;border-collapse:collapse;font-size:12px;width:auto;">';
                    html += '<tr style="background:#e2e8f0;"><th style="padding:3px 10px;border:1px solid #cbd5e1;text-align:left;">' + __('index.detail.name') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;text-align:left;">' + __('index.detail.values') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;text-align:left;">' + __('index.detail.mode') + '</th></tr>';
                    r.headers.forEach(function(h) {
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;"><code>' + escapeHtml(h.name) + '</code></td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (h.values && h.values.length > 0 ? h.values.join(', ') : '<span class="text-muted">*</span>') + '</td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + h.mode + '</td></tr>';
                    });
                    html += '</table>';
                }

                // Query Parameters
                if (r.queryParameters && r.queryParameters.length > 0) {
                    html += '<div style="margin-top:6px;margin-bottom:4px;"><strong>' + __('index.detail.queryParams') + ' (' + r.queryParameters.length + '):</strong></div>';
                    html += '<table style="margin:0 0 6px 0;border-collapse:collapse;font-size:12px;width:auto;">';
                    html += '<tr style="background:#e2e8f0;"><th style="padding:3px 10px;border:1px solid #cbd5e1;text-align:left;">' + __('index.detail.name') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;text-align:left;">' + __('index.detail.values') + '</th><th style="padding:3px 10px;border:1px solid #cbd5e1;text-align:left;">' + __('index.detail.mode') + '</th></tr>';
                    r.queryParameters.forEach(function(q) {
                        html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;"><code>' + escapeHtml(q.name) + '</code></td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + (q.values && q.values.length > 0 ? q.values.join(', ') : '<span class="text-muted">*</span>') + '</td>';
                        html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + q.mode + '</td></tr>';
                    });
                    html += '</table>';
                }

                // Metadata
                if (r.metadata) {
                    html += '<div style="margin-top:6px;"><strong>' + __('index.detail.metadata') + ':</strong></div>';
                    var metaKeys = Object.keys(r.metadata);
                    if (metaKeys.length > 0) {
                        html += '<table style="margin:2px 0 0 0;border-collapse:collapse;font-size:12px;width:auto;">';
                        html += '<tr style="background:#e2e8f0;"><th style="padding:3px 10px;border:1px solid #cbd5e1;text-align:left;">Key</th><th style="padding:3px 10px;border:1px solid #cbd5e1;text-align:left;">Value</th></tr>';
                        for (var mi = 0; mi < metaKeys.length; mi++) {
                            var mk = metaKeys[mi];
                            html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;"><code>' + escapeHtml(mk) + '</code></td>';
                            html += '<td style="padding:2px 10px;border:1px solid #e2e8f0;">' + escapeHtml(r.metadata[mk]) + '</td></tr>';
                        }
                        html += '</table>';
                    }
                }

                html += '</div>';
                html += '</td>';
                html += '</tr>';
            });

            document.getElementById('route-tbody').innerHTML =
                html || '<tr><td colspan="5" class="text-center text-muted py-4">' + __('index.route.empty') + '</td></tr>';
            document.getElementById('route-refresh-time').textContent = __('index.route.updated') + timeStr();
            document.getElementById('stat-routes').textContent = routes.length;
        } catch (e) { console.error(__('index.js.loadRouteFailed'), e); }
