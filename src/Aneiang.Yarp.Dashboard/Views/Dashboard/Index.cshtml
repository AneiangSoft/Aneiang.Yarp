@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Overview" : "总览";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Stat cards (visible on all tabs) -->
<div id="stat-bar" class="row g-3 mb-3">
    <!-- Gateway info -->
    <div class="col-12">
        <div class="info-bar">
            <div class="info-bar-content">
                <span><i class="bi bi-cpu"></i><span data-i18n="index.label.version">版本：</span><strong id="info-version">-</strong></span>
                <span><i class="bi bi-cloud"></i><span data-i18n="index.label.env">环境：</span><strong id="info-env">-</strong></span>
                <span><i class="bi bi-play-circle"></i><span data-i18n="index.label.start">启动：</span><strong id="info-start">-</strong></span>
                <span><i class="bi bi-clock-history"></i><span data-i18n="index.label.uptime">运行：</span><strong id="info-uptime">-</strong></span>
                <span><i class="bi bi-memory"></i><span data-i18n="index.label.memory">内存：</span><strong id="info-memory">-</strong></span>
                <span><i class="bi bi-pc-display"></i><span data-i18n="index.label.host">主机：</span><strong id="info-machine">-</strong></span>
            </div>
            <div class="info-bar-actions">
                <button class="btn btn-icon btn-outline-primary" onclick="manualRefresh(this)" data-i18n-title="index.btn.refresh" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-clusters">-</div>
                    <div class="stat-label" data-i18n="index.stat.clusters">服务集群</div>
                </div>
                <div class="stat-icon" style="background:#eff6ff;color:#3b82f6;"><i class="bi bi-diagram-3"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-healthy" style="color:#22c55e;">-</div>
                    <div class="stat-label" data-i18n="index.stat.health">健康 / 未知 / 异常</div>
                </div>
                <div class="stat-icon" style="background:#f0fdf4;color:#22c55e;"><i class="bi bi-heart-pulse"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-routes">-</div>
                    <div class="stat-label" data-i18n="index.stat.routes">路由规则</div>
                </div>
                <div class="stat-icon" style="background:#fefce8;color:#eab308;"><i class="bi bi-signpost-split"></i></div>
            </div>
        </div>
    </div>
</div>



<!-- Cluster panel -->
<div id="cluster-panel" class="card-panel mb-3" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-hdd-stack me-2"></i><span data-i18n="index.cluster.title">集群 &amp; 目标节点状态</span></span>
        <div class="d-flex align-items-center" style="gap:6px 16px;white-space:nowrap;">
            <span class="refresh-badge" id="cluster-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.cluster.showing">显示 </span><strong id="cluster-display-count">0</strong><span data-i18n="index.cluster.of"> / </span><span id="cluster-total-count">0</span><span data-i18n="index.cluster.entries"> 个</span></span>
        </div>
    </div>
    
    <!-- Filter toolbar container -->
    <div id="cluster-filter-container"></div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle" style="table-layout:fixed;width:100%">
            <thead>
                <tr>
                    <th style="width:40px"></th>
                    <th style="width:15%"><span data-i18n="index.cluster.th.name">集群名称</span></th>
                    <th style="width:90px"><span data-i18n="index.cluster.th.source">来源</span></th>
                    <th style="width:10%"><span data-i18n="index.cluster.th.dest">节点名</span></th>
                    <th style="width:22%"><span data-i18n="index.cluster.th.address">目标地址</span></th>
                    <th style="width:9%"><span data-i18n="index.cluster.th.active">主动健康</span></th>
                    <th style="width:9%"><span data-i18n="index.cluster.th.passive">被动健康</span></th>
                    <th style="width:9%"><span data-i18n="index.cluster.th.policy">均衡策略</span></th>
                    <th style="width:80px"><span data-i18n="index.cluster.th.actions">操作</span></th>
                </tr>
            </thead>
            <tbody id="cluster-tbody">
                <tr><td colspan="9" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Route panel -->
<div id="route-panel" class="card-panel mb-3" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2"></i><span data-i18n="index.route.title">路由规则列表</span></span>
        <div class="d-flex align-items-center" style="gap:6px 16px;white-space:nowrap;">
            <span class="refresh-badge" id="route-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.route.showing">Showing </span><strong id="route-display-count">0</strong><span data-i18n="index.route.of"> / </span><span id="route-total-count">0</span><span data-i18n="index.route.entries"> entries</span></span>
        </div>
    </div>
    
    <!-- Filter toolbar container -->
    <div id="route-filter-container"></div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle" style="table-layout:fixed;width:100%">
            <thead>
                <tr>
                    <th style="width:40px"></th>
                    <th style="width:60px"><span data-i18n="index.route.th.order">优先级</span></th>
                    <th style="width:15%"><span data-i18n="index.route.th.name">路由名称</span></th>
                    <th style="width:90px"><span data-i18n="index.route.th.source">来源</span></th>
                    <th style="width:22%"><span data-i18n="index.route.th.path">匹配路径</span></th>
                    <th style="width:14%"><span data-i18n="index.route.th.cluster">关联集群</span></th>
                    <th style="width:14%"><span data-i18n="index.route.th.methods">允许方法</span></th>
                    <th style="width:80px"><span data-i18n="index.route.th.actions">操作</span></th>
                </tr>
            </thead>
            <tbody id="route-tbody">
                <tr><td colspan="8" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Log panel -->
<div id="log-panel" class="card-panel mb-3" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-journal-text me-2"></i><span data-i18n="index.log.title">YARP 实时日志</span></span>
        <div class="d-flex align-items-center" style="gap:6px 16px;white-space:nowrap;">
            <span class="refresh-badge" id="log-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.log.showing">显示 </span><strong id="log-display-count">0</strong><span data-i18n="index.log.of"> / </span><span id="log-total-count">0</span><span data-i18n="index.log.entries"> 条</span></span>
        </div>
    </div>
    
    <!-- Filter toolbar container -->
    <div id="log-filter-container"></div>
    
    <div style="max-height:600px;overflow-y:auto;" id="log-scroll-container">
        <div id="log-entries" class="log-entries-container">
            <div class="text-center text-muted py-4" data-i18n="index.log.empty">暂无日志</div>
        </div>
    </div>
</div>

@section Scripts {
@{ var v = typeof(Aneiang.Yarp.Dashboard.Models.LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
<!-- 1. Core Infrastructure -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-utils.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-api.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-state.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-dom.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-i18n.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-storage.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-core.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-modals.js?v=@v"></script>

<!-- 2. Schema Service (sync load) -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-schema-service.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-schema-validator.js?v=@v"></script>

<!-- 3. Monaco Editor (async load) -->
<script>
    // Configure Monaco Worker paths BEFORE loading loader
    window.MonacoEnvironment = {
        getWorkerUrl: function(workerId, label) {
            var workerPath = '/_content/Aneiang.Yarp.Dashboard/lib/monaco/';
            // Map worker labels to their specific worker files
            if (label === 'json') {
                return workerPath + 'language/json/jsonWorker.js';
            } else if (label === 'css') {
                return workerPath + 'language/css/cssWorker.js';
            } else if (label === 'html') {
                return workerPath + 'language/html/htmlWorker.js';
            } else if (label === 'typescript' || label === 'javascript') {
                return workerPath + 'language/typescript/tsWorker.js';
            }
            // Default editor worker
            return workerPath + 'editor/editor.worker.js';
        }
    }; 

    window.__monacoReady = new Promise(function(resolve) {
        window.__monacoResolve = resolve;
    });
</script>
<script src="/_content/Aneiang.Yarp.Dashboard/lib/monaco/loader.js?v=@v"></script>
<script>
    require.config({ paths: { vs: '/_content/Aneiang.Yarp.Dashboard/lib/monaco' } });
    require(['vs/editor/editor.main'], function() {
        window.__monacoResolve();
    });
</script>

<!-- 4. Editor Layer -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-monaco-editor.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-config-editor.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-form-builder.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-diff-panel.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/editors/dashboard-validation-panel.js?v=@v"></script>

<!-- 5. App Bootstrap & Events -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/app/dashboard-bootstrap.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/app/dashboard-events.js?v=@v"></script>

<!-- 6. Modules -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-home.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-clusters.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-routes.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-logs.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-config.js?v=@v"></script>

<script>
    // Initialize dashboard config
    window.__dashboard = window.__dashboard || {};
    var dash = window.__dashboard;
    dash.basePath = '/' + '@ViewBag.DashboardRoutePrefix';
    dash.token = localStorage.getItem('dashboard_token');
    dash.CURRENT_LOCALE = '@ViewBag.Locale';
    dash.I18N = @Html.Raw(ViewBag.AllI18nJson ?? "{}");
    dash.logPanelEnabled = @(ViewBag.EnableProxyLogging != false ? "true" : "false");
</script>

<style>
@@keyframes spin { to { transform: rotate(360deg); } }
.spin { display:inline-block; animation: spin .6s linear infinite; }
</style>
}