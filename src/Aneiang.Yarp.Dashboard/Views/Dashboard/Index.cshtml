@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Overview" : "总览";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Stat cards (visible on all tabs) -->
<div id="stat-bar" class="row g-3 mb-3">
    <!-- Gateway info -->
    <div class="col-12">
        <div class="info-bar">
            <div class="info-bar-content">
                <span><i class="bi bi-cpu"></i><span data-i18n="index.label.version">版本：</span><strong id="info-version">-</strong></span>
                <span><i class="bi bi-cloud"></i><span data-i18n="index.label.env">环境：</span><strong id="info-env">-</strong></span>
                <span><i class="bi bi-play-circle"></i><span data-i18n="index.label.start">启动：</span><strong id="info-start">-</strong></span>
                <span><i class="bi bi-clock-history"></i><span data-i18n="index.label.uptime">运行：</span><strong id="info-uptime">-</strong></span>
                <span><i class="bi bi-memory"></i><span data-i18n="index.label.memory">内存：</span><strong id="info-memory">-</strong></span>
                <span><i class="bi bi-pc-display"></i><span data-i18n="index.label.host">主机：</span><strong id="info-machine">-</strong></span>
            </div>
            <div class="info-bar-actions card-header-actions">
                <button class="btn btn-sm btn-outline-secondary btn-icon-only" onclick="manualRefresh(this)" data-i18n-title="index.btn.refresh" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="stat-card stat-card--blue" style="border-left: 3px solid #3b82f6;">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-card__icon"><i class="bi bi-diagram-3"></i></div>
                <div class="stat-card__body">
                    <div class="stat-card__value" id="stat-clusters">-</div>
                    <div class="stat-card__label" data-i18n="index.stat.clusters">服务集群</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="stat-card stat-card--green" style="border-left: 3px solid #22c55e;">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-card__icon"><i class="bi bi-heart-pulse"></i></div>
                <div class="stat-card__body">
                    <div class="stat-card__value" id="stat-healthy" style="color:#22c55e;">-</div>
                    <div class="stat-card__label" data-i18n="index.stat.health">健康状态</div>
                    <div class="stat-card__trend">
                        <span style="color:#22c55e;">●</span> 健康
                        <span style="color:#f59e0b;margin-left:6px;">●</span> 未知
                        <span style="color:#ef4444;margin-left:6px;">●</span> 异常
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="stat-card stat-card--amber" style="border-left: 3px solid #f59e0b;">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-card__icon"><i class="bi bi-signpost-split"></i></div>
                <div class="stat-card__body">
                    <div class="stat-card__value" id="stat-routes">-</div>
                    <div class="stat-card__label" data-i18n="index.stat.routes">路由规则</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="stat-card stat-card--purple" style="border-left: 3px solid #8b5cf6;">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-card__icon"><i class="bi bi-lightning-charge"></i></div>
                <div class="stat-card__body">
                    <div class="stat-card__value" id="stat-qps">-</div>
                    <div class="stat-card__label" data-i18n="index.stat.qps">当前 QPS</div>
                </div>
            </div>
        </div>
    </div>
</div>



<!-- Service tabs (clusters + routes) -->
<div id="service-panel" class="card-panel mb-3">
    <!-- Tab bar -->
    <div class="nav-tabs-bar">
        <button class="nav-tab-btn active" data-tab="clusters" onclick="ServiceTabs.switch('clusters')">
            <i class="bi bi-diagram-3"></i>
            <span data-i18n="index.serviceTab.clusters">服务集群</span>
        </button>
        <button class="nav-tab-btn" data-tab="routes" onclick="ServiceTabs.switch('routes')">
            <i class="bi bi-signpost-split"></i>
            <span data-i18n="index.serviceTab.routes">路由规则</span>
        </button>
        <div class="nav-tab-actions">
            <button class="btn btn-sm btn-outline-secondary btn-icon-only" id="service-refresh-btn" onclick="ServiceTabs.refresh()" data-i18n-title="index.btn.refresh" title="刷新">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
        <div class="nav-tab-actions" style="padding:0 0 0 8px;">
            <span class="refresh-badge" id="service-refresh-time"></span>
            <span class="refresh-badge" id="service-count-label"></span>
        </div>
    </div>

    <!-- Cluster tab content -->
    <div id="tab-clusters" class="service-tab-content">
        <!-- Filter toolbar container -->
        <div id="cluster-filter-container"></div>

        <!-- Batch operation bar -->
        <div class="batch-bar" id="cluster-batch-bar">
            <span class="batch-bar-info"><span id="cluster-batch-count">0</span> <span data-i18n="index.selected">已选择</span></span>
            <div class="batch-bar-actions">
                <button class="btn btn-sm btn-outline-danger" onclick="ClustersModule.batchDelete()"><i class="bi bi-trash me-1"></i><span data-i18n="index.batchDelete">批量删除</span></button>
                <button class="btn btn-sm btn-outline-secondary" onclick="ClustersModule.clearBatch()"><i class="bi bi-x me-1"></i><span data-i18n="index.cancelSelect">取消选择</span></button>
            </div>
        </div>

        <!-- Table view -->
        <div id="cluster-table-view">
            <div class="table-responsive">
                <table class="table table-hover table-striped-custom align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width:38px"><input type="checkbox" class="form-check-input" id="cluster-select-all" onchange="ClustersModule.toggleSelectAll(this.checked)"></th>
                            <th><span data-i18n="index.cluster.th.name">集群名称</span></th>
                            <th style="width:90px"><span data-i18n="index.source.filter">来源</span></th>
                            <th style="width:90px"><span data-i18n="index.cluster.health.filter">健康状态</span></th>
                            <th style="width:80px"><span data-i18n="index.cluster.destCount">节点数</span></th>
                            <th style="width:110px"><span data-i18n="index.cluster.loadBalancing">负载策略</span></th>
                            <th style="width:80px"><span data-i18n="index.cluster.th.actions">操作</span></th>
                        </tr>
                    </thead>
                    <tbody id="cluster-tbody">
                        <tr><td colspan="7" class="text-center py-4">
                            <div style="padding:4px 0;">
                                <div class="skeleton skeleton-line long"></div>
                                <div class="skeleton skeleton-line medium"></div>
                                <div class="skeleton skeleton-line short"></div>
                            </div>
                        </td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Route tab content -->
    <div id="tab-routes" class="service-tab-content" style="display:none;">
        <!-- Filter toolbar container -->
        <div id="route-filter-container"></div>

        <!-- Table view -->
        <div id="route-table-view">
            <div class="table-responsive">
                <table class="table table-hover table-striped-custom align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width:36px"></th>
                            <th style="width:80px;white-space:nowrap"><span data-i18n="index.route.orderCol">优先级</span></th>
                            <th style="width:22%"><span data-i18n="index.route.th.name">路由名称</span></th>
                            <th><span data-i18n="index.route.th.path">匹配路径</span></th>
                            <th style="width:140px"><span data-i18n="index.route.clusterCol">集群</span></th>
                            <th style="width:120px"><span data-i18n="index.route.methodCol">方法</span></th>
                            <th style="width:80px"><span data-i18n="index.route.th.actions">操作</span></th>
                        </tr>
                    </thead>
                    <tbody id="route-tbody">
                        <tr><td colspan="7" class="text-center py-4">
                            <div style="padding:4px 0;">
                                <div class="skeleton skeleton-line long"></div>
                                <div class="skeleton skeleton-line medium"></div>
                                <div class="skeleton skeleton-line short"></div>
                            </div>
                        </td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Log panel -->
<div id="log-panel" class="card-panel mb-3" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-journal-text me-2"></i><span data-i18n="index.log.title">YARP 实时日志</span></span>
        <div class="d-flex align-items-center" style="gap:6px 16px;white-space:nowrap;">
            <span class="refresh-badge" id="log-refresh-time"></span>
            <span class="refresh-badge"><span data-i18n="index.log.showing">显示 </span><strong id="log-display-count">0</strong><span data-i18n="index.log.of"> / </span><strong id="log-total-count">0</strong><span data-i18n="index.log.entries"> 条</span></span>
        </div>
    </div>
    
    <!-- Filter toolbar container -->
    <div id="log-filter-container"></div>
    
    <div style="max-height:600px;overflow-y:auto;" id="log-scroll-container">
        <div id="log-entries" class="log-entries-container">
            <div class="text-center text-muted py-4" data-i18n="index.log.empty">暂无日志</div>
        </div>
    </div>
</div>

<!-- Statistics panel -->
<div id="stats-panel" class="card-panel mb-3" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-bar-chart-line me-2"></i><span data-i18n="stats.title">访问统计</span></span>
        <div class="d-flex align-items-center" style="gap:12px;white-space:nowrap;">
            <button class="btn btn-sm btn-outline-secondary" onclick="StatsModule.loadStats()">
                <i class="bi bi-arrow-clockwise"></i> <span data-i18n="stats.refresh">刷新统计</span>
            </button>
        </div>
    </div>
    <div id="stats-content" class="card-body"></div>
</div>

<!-- History panel -->
<div id="history-panel" class="card-panel mb-3" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-clock-history me-2"></i><span data-i18n="history.title">配置变更历史</span></span>
        <button class="btn btn-sm btn-outline-secondary" onclick="HistoryModule.loadHistory()">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
    <div id="history-content" class="card-body"></div>
</div>

<!-- Audit log panel -->
<div id="audit-panel" class="card-panel mb-3" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-shield-check me-2"></i><span data-i18n="audit.title">审计日志</span></span>
        <button class="btn btn-sm btn-outline-secondary" onclick="window.AuditModule?.loadAuditLogs()">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
    <div id="audit-content" class="card-body"></div>
</div>

@section Scripts {
@{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-home.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-clusters.js?v=@v"></script>
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-routes.js?v=@v"></script>
<!-- Page config (must be available before DashboardApp.init()) -->
@await Html.PartialAsync("_DashboardPageInit")

<script>
    // Core initialization — must run before ServiceTabs triggers data loading
    (async function() {
            try {
                if (window.DashboardUtils) DashboardUtils.init();
                if (window.DashboardApi) DashboardApi.init();
                if (window.DashboardState) DashboardState.init();
            if (window.DashboardI18n) DashboardI18n.init();
            if (window.DashboardStorage) DashboardStorage.init();
            if (window.DashboardModals) DashboardModals.init();
            if (window.DashboardEvents) DashboardEvents.setup();


            // Initialize modules
            if (window.DashboardApp?.modules?.home?.init) await DashboardApp.modules.home.init();
            if (window.DashboardApp?.modules?.clusters?.init) await DashboardApp.modules.clusters.init();
            if (window.DashboardApp?.modules?.routes?.init) await DashboardApp.modules.routes.init();

            // Load gateway info and stat cards (also loads clusters + routes into state)
            if (window.DashboardApp?.modules?.home?.loadInfo) {
                await DashboardApp.modules.home.loadInfo();
            } else {
                console.warn('[Index] home.loadInfo not available, calling direct API');
            }

            // Direct fallback: always call APIs to populate stat cards and tables
            // (in case HomeModule.loadInfo didn't complete or doesn't exist)
            try {
                const [info, clusters, routes] = await Promise.all([
                    DashboardApi.endpoints.getInfo(),
                    DashboardApi.endpoints.getClusters(),
                    DashboardApi.endpoints.getRoutes()
                ]);

                // Render info bar
                if (info) {
                    const set = (id, val) => { const el = document.getElementById(id); if (el && val != null) el.textContent = val; };
                    set('info-version', info.version);
                    set('info-env', info.environment);
                    set('info-start', info.startTime);
                    set('info-uptime', info.uptime);
                    set('info-memory', info.memoryMb != null ? info.memoryMb.toFixed(1) + ' MB' : null);
                    set('info-machine', info.machineName);
                }

                // Render stat cards
                const clusterCount = (clusters || []).length;
                const routeCount = (routes || []).length;
                const healthy = (clusters || []).reduce((s, c) => s + (c.healthyCount || 0), 0);
                const unknown = (clusters || []).reduce((s, c) => s + (c.unknownCount || 0), 0);
                const unhealthy = (clusters || []).reduce((s, c) => s + (c.unhealthyCount || 0), 0);
                const setText = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
                setText('stat-clusters', clusterCount);
                setText('stat-healthy', healthy + ' / ' + unknown + ' / ' + unhealthy);
                setText('stat-routes', routeCount);

                // Store in state for ServiceTabs
                DashboardState.set('data.clusters', clusters || []);
                DashboardState.set('data.routes', routes || []);
            } catch (err) {
                console.error('[Index] Direct API fallback failed:', err);
            }

            // Now that data is in state, trigger ServiceTabs to render the active tab
            if (window.ServiceTabs) window.ServiceTabs.switch(window.ServiceTabs.current);

            document.dispatchEvent(new CustomEvent('dashboard:ready'));
        } catch (err) {
            console.error('[Index] Init failed:', err);
        }
    })();

    window.manualRefresh = async function(btn) {
        var original = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise spin"></i>';
        btn.disabled = true;
        try {
            if (window.DashboardApp?.modules?.home?.refresh) {
                await DashboardApp.modules.home.refresh();
            }
            if (window.ServiceTabs) window.ServiceTabs.switch(window.ServiceTabs.current);
        } finally {
            btn.innerHTML = original;
            btn.disabled = false;
        }
    };
</script>

<!-- Service tabs JS -->
<script>
(function() {
    // ServiceTabs: tab switching for clusters/routes on the overview page
    window.ServiceTabs = {
        current: localStorage.getItem('service_tab') || 'clusters',
        _clustersLoaded: false,
        _routesLoaded: false,

        switch: function(tab) {
            this.current = tab;
            localStorage.setItem('service_tab', tab);

            // Tab buttons
            document.querySelectorAll('.nav-tab-btn').forEach(function(btn) {
                btn.classList.toggle('active', btn.dataset.tab === tab);
            });

            // Tab content panels
            document.querySelectorAll('.service-tab-content').forEach(function(content) {
                content.style.display = content.id === 'tab-' + tab ? '' : 'none';
            });

            // Count label
            this._updateCountLabel(tab);

            // Render from state (data already loaded by HomeModule.loadInfo)
            if (tab === 'clusters') {
                if (window.DashboardApp?.modules?.clusters?.renderClusters) {
                    DashboardApp.modules.clusters.renderClusters();
                }
            } else if (tab === 'routes') {
                if (window.DashboardApp?.modules?.routes?.renderRoutes) {
                    DashboardApp.modules.routes.renderRoutes();
                }
            }
        },

        refresh: function() {
            var tab = this.current;
            var btn = document.getElementById('service-refresh-btn');
            if (!btn) return;
            var original = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-1"></i>';
            btn.disabled = true;
            Promise.resolve().then(function() {
                if (tab === 'clusters') {
                    return window.DashboardApp?.modules?.clusters?.loadClusters?.();
                } else {
                    return window.DashboardApp?.modules?.routes?.loadRoutes?.();
                }
            }).finally(function() {
                btn.innerHTML = original;
                btn.disabled = false;
            });
        },

        _updateCountLabel: function(tab) {
            var label = document.getElementById('service-count-label');
            if (!label) return;
            if (tab === 'clusters') {
                var total = (window.DashboardState?.get('data.clusters') || []).length;
                var filtered = (window.DashboardState?.getFilteredClusters?.() || []).length;
                label.innerHTML = '<span>' + filtered + ' / ' + total + ' <span data-i18n="index.cluster.entries">个</span></span>';
            } else {
                var total = (window.DashboardState?.get('data.routes') || []).length;
                var filtered = (window.DashboardState?.getFilteredRoutes?.() || []).length;
                label.innerHTML = '<span>' + filtered + ' / ' + total + ' entries</span>';
            }
        }
    };
})();


</script>

}