@{
    ViewData["Title"] = "总览";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- ========== 统计卡片（所有 Tab 均可见）========== -->
<div id="stat-bar" class="row g-3 mb-4">
    <!-- 网关信息 -->
    <div class="col-12 mb-1">
        <div class="card-panel px-4 py-3 d-flex flex-wrap gap-4 align-items-center" style="font-size:13px;color:#475569;">
            <span><i class="bi bi-cpu me-1"></i>版本：<strong id="info-version">-</strong></span>
            <span><i class="bi bi-cloud me-1"></i>环境：<strong id="info-env">-</strong></span>
            <span><i class="bi bi-play-circle me-1"></i>启动：<strong id="info-start">-</strong></span>
            <span><i class="bi bi-clock-history me-1"></i>运行：<strong id="info-uptime">-</strong></span>
            <span><i class="bi bi-memory me-1"></i>内存：<strong id="info-memory">-</strong></span>
            <span><i class="bi bi-pc-display me-1"></i>主机：<strong id="info-machine">-</strong></span>
            <span class="ms-auto">
                <button class="btn btn-sm btn-outline-primary" onclick="manualRefresh(this)">
                    <i class="bi bi-arrow-clockwise me-1"></i>刷新
                </button>
            </span>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-clusters">-</div>
                    <div class="stat-label">服务集群</div>
                </div>
                <div class="stat-icon" style="background:#eff6ff;color:#3b82f6;"><i class="bi bi-diagram-3"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-healthy" style="color:#22c55e;">-</div>
                    <div class="stat-label">健康 / 未知 / 异常</div>
                </div>
                <div class="stat-icon" style="background:#f0fdf4;color:#22c55e;"><i class="bi bi-heart-pulse"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-routes">-</div>
                    <div class="stat-label">路由规则</div>
                </div>
                <div class="stat-icon" style="background:#fefce8;color:#eab308;"><i class="bi bi-signpost-split"></i></div>
            </div>
        </div>
    </div>
</div>

<!-- ========== 服务集群面板 ========== -->
<div id="cluster-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-hdd-stack me-2"></i>集群 &amp; 目标节点状态</span>
        <div class="d-flex align-items-center gap-3">
            <span class="refresh-badge" id="cluster-refresh-time"></span>
            <button class="btn btn-sm btn-outline-secondary" onclick="manualRefresh(this)">
                <i class="bi bi-arrow-clockwise me-1"></i>刷新
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width:22%">集群名称</th>
                    <th style="width:12%">节点名</th>
                    <th style="width:28%">目标地址</th>
                    <th style="width:14%">主动健康</th>
                    <th style="width:14%">被动健康</th>
                    <th style="width:10%">均衡策略</th>
                </tr>
            </thead>
            <tbody id="cluster-tbody">
                <tr><td colspan="6" class="text-center text-muted py-4">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ========== 路由配置面板 ========== -->
<div id="route-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2"></i>路由规则列表</span>
        <div class="d-flex align-items-center gap-3">
            <span class="refresh-badge" id="route-refresh-time"></span>
            <button class="btn btn-sm btn-outline-secondary" onclick="manualRefresh(this)">
                <i class="bi bi-arrow-clockwise me-1"></i>刷新
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width:8%">优先级</th>
                    <th style="width:22%">路由名称</th>
                    <th style="width:35%">匹配路径</th>
                    <th style="width:20%">关联集群</th>
                    <th style="width:15%">允许方法</th>
                </tr>
            </thead>
            <tbody id="route-tbody">
                <tr><td colspan="5" class="text-center text-muted py-4">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ========== 日志面板 ========== -->
<div id="log-panel" class="card-panel mb-4" style="display:none;">
    <div class="card-header">
        <span><i class="bi bi-journal-text me-2"></i>YARP 实时日志</span>
        <div class="d-flex align-items-center gap-3">
            <span class="refresh-badge" id="log-refresh-time"></span>
            <button class="btn btn-sm btn-outline-success" id="log-listen-btn" onclick="toggleListening()">
                <i class="bi bi-play-circle me-1"></i>开启监听
            </button>
            <span class="refresh-badge">显示 <strong id="log-display-count">0</strong> / <span id="log-total-count">0</span> 条</span>
            <button class="btn btn-sm btn-outline-secondary" onclick="loadLogs()">
                <i class="bi bi-arrow-clockwise me-1"></i>刷新
            </button>
            <button class="btn btn-sm btn-outline-danger" onclick="clearLogs()">
                <i class="bi bi-trash me-1"></i>清空
            </button>
        </div>
    </div>
    <div style="max-height:600px;overflow-y:auto;" id="log-scroll-container">
        <div id="log-entries" style="padding:0;">
            <div class="text-center text-muted py-4">暂无日志</div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const basePath = '/' + '@ViewBag.DashboardRoutePrefix';
    const token = localStorage.getItem('dashboard_token');

    // Log listening state
    let listeningEnabled = true;
    let logPollTimer = null;

    // Fetch wrapper with JWT authorization + 401 redirect
    async function authFetch(url, options) {
        options = options || {};
        options.headers = options.headers || {};
        if (token) {
            options.headers['Authorization'] = 'Bearer ' + token;
            options.headers['X-Requested-With'] = 'XMLHttpRequest';
        }
        const res = await fetch(url, options);
        if (res.status === 401) {
            localStorage.removeItem('dashboard_token');
            window.location.href = basePath + '/login';
            throw new Error('Unauthorized');
        }
        return res;
    }

    // ===== Tab 对应显示的面板（stat-bar 始终显示）=====
    const tabPanels = {
        overview: [],
        services: ['cluster-panel'],
        routes:   ['route-panel'],
        logs:     ['log-panel']
    };
    const allPanels = ['cluster-panel', 'route-panel', 'log-panel'];

    function switchTab(tabName) {
        // 更新侧边栏激活状态
        document.querySelectorAll('.sidebar .nav-link[data-tab]').forEach(l => {
            l.classList.toggle('active', l.dataset.tab === tabName);
        });
        // 显示/隐藏面板
        allPanels.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.style.display = (tabPanels[tabName] || []).includes(id) ? '' : 'none';
        });
    }

    document.querySelectorAll('.sidebar .nav-link[data-tab]').forEach(link => {
        link.addEventListener('click', e => {
            e.preventDefault();
            switchTab(link.dataset.tab);
        });
    });

    // ===== 工具函数 =====
    function timeStr() {
        return new Date().toLocaleTimeString('zh-CN', { hour12: false });
    }

    function healthDot(status) {
        const s = (status || '').toLowerCase();
        if (s === 'healthy')   return '<span class="health-dot healthy"></span><span style="color:#22c55e;">Healthy</span>';
        if (s === 'unhealthy') return '<span class="health-dot unhealthy"></span><span style="color:#ef4444;">Unhealthy</span>';
        return '<span class="health-dot unknown"></span><span style="color:#f59e0b;">Unknown</span>';
    }

    // ===== 加载网关基本信息 =====
    async function loadInfo() {
        try {
            const res  = await authFetch(basePath + '/info');
            const json = await res.json();
            if (json.code !== 200) return;
            const d = json.data;
            document.getElementById('info-version').textContent = d.version;
            document.getElementById('info-env').textContent     = d.environment;
            document.getElementById('info-start').textContent   = d.startTime;
            document.getElementById('info-uptime').textContent  = d.uptime;
            document.getElementById('info-memory').textContent  = d.memoryMb + ' MB';
            document.getElementById('info-machine').textContent = d.machineName;
        } catch (e) { console.error('加载网关信息失败', e); }
    }

    // ===== 加载集群数据 =====
    async function loadClusters() {
        try {
            const res  = await authFetch(basePath + '/clusters');
            const json = await res.json();
            if (json.code !== 200) return;
            const clusters = json.data;

            let totalHealthy = 0, totalUnknown = 0, totalUnhealthy = 0;
            let html = '';
            clusters.forEach(c => {
                totalHealthy   += c.healthyCount   || 0;
                totalUnknown   += c.unknownCount   || 0;
                totalUnhealthy += c.unhealthyCount || 0;

                const rowspan = c.destinations.length || 1;
                c.destinations.forEach((d, i) => {
                    html += '<tr>';
                    if (i === 0) {
                        html += `<td rowspan="${rowspan}" style="font-weight:600;vertical-align:middle;">${c.clusterId}</td>`;
                    }
                    html += `<td><code>${d.name}</code></td>`;
                    html += `<td><a href="${d.address}" target="_blank" class="text-decoration-none">${d.address}</a></td>`;
                    html += `<td>${healthDot(d.health)}</td>`;
                    html += `<td>${healthDot(d.passive)}</td>`;
                    if (i === 0) {
                        html += `<td rowspan="${rowspan}" style="vertical-align:middle;"><span class="badge bg-secondary">${c.loadBalancingPolicy}</span></td>`;
                    }
                    html += '</tr>';
                });
            });

            document.getElementById('cluster-tbody').innerHTML =
                html || '<tr><td colspan="6" class="text-center text-muted py-4">暂无集群数据</td></tr>';
            document.getElementById('cluster-refresh-time').textContent = '更新于 ' + timeStr();

            // 更新统计卡片
            document.getElementById('stat-clusters').textContent = clusters.length;
            const healthLabel = totalUnhealthy > 0
                ? `<span style="color:#22c55e;">${totalHealthy}</span> / <span style="color:#f59e0b;">${totalUnknown}</span> / <span style="color:#ef4444;">${totalUnhealthy}</span>`
                : `<span style="color:#22c55e;">${totalHealthy}</span> / <span style="color:#f59e0b;">${totalUnknown}</span> / 0`;
            document.getElementById('stat-healthy').innerHTML = healthLabel;
        } catch (e) { console.error('加载集群数据失败', e); }
    }

    // ===== 加载路由数据 =====
    async function loadRoutes() {
        try {
            const res  = await authFetch(basePath + '/routes');
            const json = await res.json();
            if (json.code !== 200) return;
            const routes = json.data;

            let html = '';
            routes.forEach(r => {
                const orderColor = r.order <= 5 ? 'bg-primary' : r.order <= 20 ? 'bg-info' : 'bg-secondary';
                const methods    = r.methods ? r.methods.join(', ') : '<span class="text-muted">All</span>';
                html += `<tr>
                    <td><span class="badge ${orderColor} badge-order">${r.order ?? '-'}</span></td>
                    <td style="font-weight:600;">${r.routeId}</td>
                    <td><code style="color:#7c3aed;">${r.path || '-'}</code></td>
                    <td>${r.clusterId}</td>
                    <td>${methods}</td>
                </tr>`;
            });

            document.getElementById('route-tbody').innerHTML =
                html || '<tr><td colspan="5" class="text-center text-muted py-4">暂无路由数据</td></tr>';
            document.getElementById('route-refresh-time').textContent = '更新于 ' + timeStr();
            document.getElementById('stat-routes').textContent = routes.length;
        } catch (e) { console.error('加载路由数据失败', e); }
    }

    // ===== 加载日志数据 =====
    async function loadLogs() {
        try {
            const res  = await authFetch(basePath + '/logs?count=100');
            const json = await res.json();
            if (json.code !== 200) return;
            const snap = json.data;
            const entries = snap.entries || [];

            const container = document.getElementById('log-entries');
            const scrollEl = document.getElementById('log-scroll-container');

            // When listening, always snap to bottom; otherwise preserve scroll position
            const savedScrollTop = scrollEl.scrollTop;
            const savedScrollHeight = scrollEl.scrollHeight;

            // Save expanded state BEFORE DOM rebuild
            const expandedKeys = new Set();
            container.querySelectorAll('.log-item').forEach(function(item) {
                var detail = item.querySelector('.log-detail');
                var arrow = item.querySelector('.log-arrow');
                if (detail && arrow && detail.style.display !== 'none') {
                    var k = item.dataset.logKey;
                    if (k) expandedKeys.add(k);
                }
            });

            if (entries.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-4">暂无日志</div>';
            } else {
                // Use DocumentFragment to batch DOM insertion, reducing reflow
                const fragment = document.createDocumentFragment();
                const outerDiv = document.createElement('div');
                outerDiv.style.cssText = 'font-family:Consolas,monospace;font-size:13px;line-height:1.6;';

                for (let i = 0; i < entries.length; i++) {
                    const e = entries[i];
                    const ts = new Date(e.timestamp).toLocaleTimeString('zh-CN', { hour12: false });

                    // --- log-item container ---
                    const item = document.createElement('div');
                    item.className = 'log-item';
                    // Unique key: timestamp + level + message prefix (restored after DOM rebuild)
                    item.dataset.logKey = e.timestamp + '|' + e.level + '|' + (e.message || '').substring(0, 80);

                    // --- clickable row ---
                    const row = document.createElement('div');
                    row.className = 'log-row';
                    row.style.cssText = 'display:flex;gap:8px;padding:4px 16px;border-bottom:1px solid #f1f5f9;cursor:pointer;';
                    row.onmouseenter = function(){this.style.background='#f8fafc';};
                    row.onmouseleave = function(){this.style.background='';};
                    row.onclick = function(){ toggleLogDetail(this); };

                    const timeSpan = document.createElement('span');
                    timeSpan.style.cssText = 'color:#94a3b8;white-space:nowrap;min-width:80px;';
                    timeSpan.textContent = ts;

                    const badge = levelBadge(e.level);
                    const msgSpan = document.createElement('span');
                    msgSpan.style.cssText = 'color:#475569;flex:1;word-break:break-all;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';
                    msgSpan.textContent = e.message || '';

                    const arrowSpan = document.createElement('span');
                    arrowSpan.className = 'log-arrow';
                    arrowSpan.style.cssText = 'color:#94a3b8;font-size:10px;white-space:nowrap;min-width:14px;text-align:center;transition:transform .2s;';
                    arrowSpan.textContent = '\u25B6';  // ▶ collapsed

                    row.appendChild(timeSpan);
                    row.appendChild(badge);
                    row.appendChild(msgSpan);
                    row.appendChild(arrowSpan);

                    // --- expandable detail ---
                    const detail = document.createElement('div');
                    detail.className = 'log-detail';
                    detail.style.cssText = 'display:none;padding:8px 16px 12px;background:#f8fafc;border-bottom:1px solid #e2e8f0;font-size:12px;';

                    var dtHtml = '<div style="color:#64748b;margin-bottom:4px;">';
                    dtHtml += '<strong>Category:</strong> ' + (e.category || '') + '</div>';
                    dtHtml += '<div style="color:#334155;margin-bottom:4px;"><strong>Message:</strong><br>';
                    dtHtml += '<span style="color:#475569;word-break:break-all;">' + escapeHtml(e.message || '') + '</span></div>';
                    if (e.exception) {
                        dtHtml += '<div style="color:#dc2626;margin-top:6px;"><strong>Exception:</strong></div>';
                        dtHtml += '<pre style="background:#fef2f2;border:1px solid #fecaca;border-radius:4px;padding:8px;margin:4px 0 0;overflow-x:auto;white-space:pre-wrap;word-break:break-all;font-size:11px;color:#991b1b;line-height:1.5;">';
                        dtHtml += escapeHtml(e.exception) + '</pre>';
                    }
                    detail.innerHTML = dtHtml;

                    item.appendChild(row);
                    item.appendChild(detail);
                    outerDiv.appendChild(item);
                }

                fragment.appendChild(outerDiv);
                container.innerHTML = '';
                container.appendChild(fragment);

                // Restore expanded state after DOM rebuild
                if (expandedKeys.size > 0) {
                    container.querySelectorAll('.log-item').forEach(function(item) {
                        var k = item.dataset.logKey;
                        if (k && expandedKeys.has(k)) {
                            var detail = item.querySelector('.log-detail');
                            var arrow = item.querySelector('.log-arrow');
                            if (detail) detail.style.display = 'block';
                            if (arrow) arrow.textContent = '\u25BC';
                        }
                    });
                }
            }

            document.getElementById('log-display-count').textContent = entries.length;
            document.getElementById('log-total-count').textContent = snap.bufferSize || 0;
            document.getElementById('log-refresh-time').textContent = '更新于 ' + timeStr();

            // Auto-scroll to bottom when listening; preserve position otherwise
            if (listeningEnabled) {
                scrollEl.scrollTop = scrollEl.scrollHeight;
            } else if (scrollEl.scrollHeight > 0) {
                scrollEl.scrollTop = savedScrollTop + (scrollEl.scrollHeight - savedScrollHeight);
            }
        } catch (e) { /* silent */ }
    }

    // Toggle log detail expansion
    function toggleLogDetail(rowEl) {
        const item = rowEl.parentNode;
        const detail = item.querySelector('.log-detail');
        const arrow = rowEl.querySelector('.log-arrow');
        if (!detail || !arrow) return;
        const isOpen = detail.style.display !== 'none';
        detail.style.display = isOpen ? 'none' : 'block';
        arrow.textContent = isOpen ? '\u25B6' : '\u25BC';  // ▶ collapsed, ▼ expanded

        // When opening a detail, pause log listening so the view stays stable
        if (!isOpen) {
            stopLogPolling();
        }
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // ===== 日志监听控制 =====
    function startLogPolling() {
        if (logPollTimer) clearInterval(logPollTimer);
        listeningEnabled = true;
        updateListeningUI();
        loadLogs();  // immediate fetch
        logPollTimer = setInterval(loadLogs, 3000);
    }

    function stopLogPolling() {
        if (logPollTimer) {
            clearInterval(logPollTimer);
            logPollTimer = null;
        }
        listeningEnabled = false;
        updateListeningUI();
    }

    function toggleListening() {
        if (listeningEnabled) {
            stopLogPolling();
        } else {
            startLogPolling();
        }
    }

    function updateListeningUI() {
        var btn = document.getElementById('log-listen-btn');
        if (!btn) return;
        if (listeningEnabled) {
            btn.className = 'btn btn-sm btn-outline-warning';
            btn.innerHTML = '<i class="bi bi-pause-circle me-1"></i>监听中';
        } else {
            btn.className = 'btn btn-sm btn-outline-success';
            btn.innerHTML = '<i class="bi bi-play-circle me-1"></i>开启监听';
        }
    }

    function clearLogs() {
        authFetch(basePath + '/logs', { method: 'DELETE' }).catch(() => {});
        document.getElementById('log-entries').innerHTML = '<div class="text-center text-muted py-4">暂无日志</div>';
        document.getElementById('log-display-count').textContent = '0';
        document.getElementById('log-total-count').textContent = '0';
    }

    function levelBadge(level) {
        const l = (level || '').toLowerCase();
        const span = document.createElement('span');
        span.style.cssText = 'padding:1px 8px;border-radius:4px;font-size:11px;font-weight:600;white-space:nowrap;';
        span.textContent = level || '';
        if (l === 'error' || l === 'critical') {
            span.style.background = '#fef2f2';
            span.style.color = '#dc2626';
        } else if (l === 'warning') {
            span.style.background = '#fefce8';
            span.style.color = '#ca8a04';
        } else {
            span.style.background = '#f8fafc';
            span.style.color = '#64748b';
        }
        return span;
    }

    // ===== 手动刷新（带旋转动画）=====
    async function manualRefresh(btn) {
        if (btn) {
            btn.disabled = true;
            btn.querySelector('i')?.classList.add('spin');
        }
        await refreshAll();
        if (btn) {
            btn.disabled = false;
            btn.querySelector('i')?.classList.remove('spin');
        }
    }

    // ===== 全量刷新 =====
    async function refreshAll() {
        await Promise.all([loadInfo(), loadClusters(), loadRoutes()]);
    }

    // ===== 初始化 =====
    refreshAll();
    startLogPolling();  // starts auto-polling + immediate load
    setInterval(refreshAll, 30000);
</script>
<style>
@@keyframes spin { to { transform: rotate(360deg); } }
.spin { display:inline-block; animation: spin .6s linear infinite; }
</style>
}
