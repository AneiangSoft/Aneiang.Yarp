                    if (hr.activityTimeout) html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">ActivityTimeout</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + hr.activityTimeout + '</td></tr>';
