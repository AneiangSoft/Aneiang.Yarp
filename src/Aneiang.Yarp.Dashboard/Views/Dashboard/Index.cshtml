                    if (hcl.requestHeaderEncoding) html += '<tr><td style="padding:2px 10px;border:1px solid #e2e8f0;">RequestHeaderEncoding</td><td style="padding:2px 10px;border:1px solid #e2e8f0;">' + escapeHtml(hcl.requestHeaderEncoding) + '</td></tr>';
