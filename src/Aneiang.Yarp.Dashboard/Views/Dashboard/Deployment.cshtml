@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Deployment" : "运行模式";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div id="deployment-app">
    <!-- Page Header -->
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-rocket-takeoff me-2" style="color:#6366f1;"></i><span data-i18n="deployment.title">运行模式</span></span>
            <div>
                <span id="deployment-refresh-time" class="refresh-badge"></span>
                <button class="btn btn-sm btn-outline-primary" onclick="DashboardDeployment.refresh()" data-i18n-title="deployment.refresh" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i> <span data-i18n="deployment.refresh">刷新</span>
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <!-- Mode Card -->
                <div class="col-md-4">
                    <div class="border rounded-3 p-4 h-100 text-center" id="deployment-mode-card" style="border-left: 4px solid #6366f1 !important; background: linear-gradient(135deg, #f8fafc, #f1f5f9);">
                        <i class="bi bi-rocket-takeoff" style="font-size:32px;color:#6366f1;"></i>
                        <h5 class="mt-2 mb-1" id="deployment-mode-name">-</h5>
                        <small class="text-muted" id="deployment-mode-desc">-</small>
                    </div>
                </div>
                <!-- Summary -->
                <div class="col-md-8">
                    <div class="border rounded-3 p-4 h-100" style="background: linear-gradient(135deg, #f8fafc, #f1f5f9);">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" data-i18n="deployment.processStart">进程启动</span>
                                    <span class="small" id="deployment-process-start">-</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" data-i18n="deployment.uptime">运行时长</span>
                                    <span class="small" id="deployment-uptime">-</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2">
                                    <span class="text-muted" data-i18n="deployment.version">程序版本</span>
                                    <span class="small" id="deployment-version">-</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" data-i18n="deployment.env">环境</span>
                                    <span class="badge bg-light text-dark" id="deployment-env">-</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" data-i18n="deployment.hotReload">配置热更新</span>
                                    <span id="deployment-hotreload">-</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2">
                                    <span class="text-muted" data-i18n="deployment.healthCheck">健康检查</span>
                                    <span id="deployment-healthcheck">-</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Listening Endpoints -->
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-router me-2" style="color:#6366f1;"></i><span data-i18n="deployment.endpoints">监听端点</span></span>
            <span class="badge bg-secondary ms-2" id="deployment-endpoint-count">0</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr style="font-size:12px;">
                            <th data-i18n="deployment.colName">名称</th>
                            <th data-i18n="deployment.colAddress">监听地址</th>
                            <th data-i18n="deployment.colPort">端口</th>
                            <th data-i18n="deployment.colRole">角色</th>
                            <th data-i18n="deployment.colPublic">公网</th>
                            <th data-i18n="deployment.colStatus">状态</th>
                        </tr>
                    </thead>
                    <tbody id="deployment-endpoints-body">
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4" data-i18n="deployment.loading">加载中...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Hot Reload + Health Check -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card-panel h-100">
                <div class="card-header">
                    <span><i class="bi bi-arrow-repeat me-2" style="color:#22c55e;"></i><span data-i18n="deployment.hotReloadStatus">热更新状态</span></span>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.hotReloadEnabled">启用状态</span>
                        <span id="deployment-hotreload-enabled">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.watchedFiles">监听文件</span>
                        <span class="small" id="deployment-watched-files">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.debounceMs">防抖时间</span>
                        <span class="small" id="deployment-debounce">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.fallbackPoll">兜底轮询</span>
                        <span class="small" id="deployment-fallback">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span class="text-muted" data-i18n="deployment.rollbackOnFailure">失败回滚</span>
                        <span id="deployment-rollback">-</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card-panel h-100">
                <div class="card-header">
                    <span><i class="bi bi-heart-pulse me-2" style="color:#ef4444;"></i><span data-i18n="deployment.healthStatus">健康检查状态</span></span>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.healthEnabled">启用状态</span>
                        <span id="deployment-health-enabled">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.healthPaths">端点路径</span>
                        <span class="small" id="deployment-health-paths">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.healthAuth">鉴权方式</span>
                        <span class="small" id="deployment-health-auth">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span class="text-muted" data-i18n="deployment.healthChecks">检查项</span>
                        <span class="small" id="deployment-health-checks">-</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Security Warnings -->
    <div class="card-panel mb-4" id="deployment-security-card" style="display:none;">
        <div class="card-header" style="background: linear-gradient(90deg, #fef3c7, #fff);">
            <span><i class="bi bi-shield-exclamation me-2" style="color:#f59e0b;"></i><span data-i18n="deployment.securityWarnings">安全告警</span></span>
        </div>
        <div class="card-body">
            <div id="deployment-security-warnings"></div>
        </div>
    </div>

    <!-- Snapshots -->
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-clock-history me-2" style="color:#6366f1;"></i><span data-i18n="deployment.snapshots">配置快照</span></span>
            <span class="badge bg-secondary ms-2" id="deployment-snapshot-count">0</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr style="font-size:12px;">
                            <th data-i18n="deployment.colTime">时间</th>
                            <th data-i18n="deployment.colTrigger">触发</th>
                            <th data-i18n="deployment.colFile">文件</th>
                            <th data-i18n="deployment.colActions">操作</th>
                        </tr>
                    </thead>
                    <tbody id="deployment-snapshots-body">
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4" data-i18n="deployment.noSnapshots">暂无快照</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Manual Actions -->
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-tools me-2" style="color:#6366f1;"></i><span data-i18n="deployment.manualActions">手动操作</span></span>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-sm btn-primary" onclick="DashboardDeployment.reload()">
                    <i class="bi bi-arrow-repeat"></i> <span data-i18n="deployment.reloadConfig">重新加载配置</span>
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="DashboardDeployment.takeSnapshot()">
                    <i class="bi bi-camera"></i> <span data-i18n="deployment.takeSnapshot">创建快照</span>
                </button>
                <button class="btn btn-sm btn-outline-warning" onclick="DashboardDeployment.checkHealth()">
                    <i class="bi bi-heart-pulse"></i> <span data-i18n="deployment.checkHealth">健康检查</span>
                </button>
            </div>
            <div class="mt-3 small text-muted">
                <i class="bi bi-info-circle"></i> <span data-i18n="deployment.manualHelp">修改 appsettings.json 后会自动热更新；Kestrel 端口变更需要重启进程。</span>
            </div>
        </div>
    </div>

    <!-- Snapshot Detail Modal -->
    <div class="modal fade" id="snapshot-detail-modal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" data-i18n="deployment.snapshotDetail">快照详情</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <pre id="snapshot-detail-content" style="max-height:60vh;overflow:auto;background:#0f172a;color:#e2e8f0;padding:16px;border-radius:6px;font-size:12px;"></pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal" data-i18n="deployment.close">关闭</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
    <script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-deployment.js?v=@v"></script>

    @await Html.PartialAsync("_DashboardPageInit")

    <script>
        if (window.DashboardApi && typeof window.DashboardApi.init === 'function') {
            window.DashboardApi.init();
        }
    </script>
}
