@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Deployment" : "运行模式";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div id="deployment-app">
    <!-- Page Header -->
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-rocket-takeoff me-2" style="color:#6366f1;"></i><span data-i18n="deployment.title">运行模式</span></span>
            <div>
                <span id="deployment-refresh-time" class="refresh-badge"></span>
                <button class="btn btn-sm btn-outline-primary" onclick="DashboardDeployment.refresh()" data-i18n-title="deployment.refresh" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i> <span data-i18n="deployment.refresh">刷新</span>
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <!-- Mode Card -->
                <div class="col-md-4">
                    <div class="stat-card stat-card--purple h-100 text-center" style="border-left:3px solid #6366f1;">
                        <div class="stat-card__icon mx-auto" style="background:linear-gradient(135deg,#f5f3ff,#ede9fe);color:#6366f1;"><i class="bi bi-rocket-takeoff"></i></div>
                        <h5 class="mt-2 mb-1" id="deployment-mode-name">-</h5>
                        <small class="text-muted" id="deployment-mode-desc">-</small>
                    </div>
                </div>
                <!-- Summary -->
                <div class="col-md-8">
                    <div class="settings-card h-100">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" data-i18n="deployment.processStart">进程启动</span>
                                    <span class="small" id="deployment-process-start">-</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" data-i18n="deployment.uptime">运行时长</span>
                                    <span class="small" id="deployment-uptime">-</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2">
                                    <span class="text-muted" data-i18n="deployment.version">程序版本</span>
                                    <span class="small" id="deployment-version">-</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" data-i18n="deployment.env">环境</span>
                                    <span class="badge bg-light text-dark" id="deployment-env">-</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" data-i18n="deployment.healthCheck">健康检查</span>
                                    <span id="deployment-healthcheck">-</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Listening Endpoints -->
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-router me-2" style="color:#6366f1;"></i><span data-i18n="deployment.endpoints">监听端点</span></span>
            <span class="badge bg-secondary ms-2" id="deployment-endpoint-count">0</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr style="font-size:12px;">
                            <th data-i18n="deployment.colName">名称</th>
                            <th data-i18n="deployment.colAddress">监听地址</th>
                            <th data-i18n="deployment.colPort">端口</th>
                            <th data-i18n="deployment.colRole">角色</th>
                            <th data-i18n="deployment.colPublic">公网</th>
                            <th data-i18n="deployment.colStatus">状态</th>
                        </tr>
                    </thead>
                    <tbody id="deployment-endpoints-body">
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4" data-i18n="deployment.loading">加载中...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Health Check -->
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-heart-pulse me-2" style="color:#ef4444;"></i><span data-i18n="deployment.healthStatus">健康检查状态</span></span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.healthEnabled">启用状态</span>
                        <span id="deployment-health-enabled">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span class="text-muted" data-i18n="deployment.healthPaths">端点路径</span>
                        <span class="small" id="deployment-health-paths">-</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted" data-i18n="deployment.healthAuth">鉴权方式</span>
                        <span class="small" id="deployment-health-auth">-</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span class="text-muted" data-i18n="deployment.healthChecks">检查项</span>
                        <span class="small" id="deployment-health-checks">-</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Security Warnings -->
    <div class="card-panel mb-4" id="deployment-security-card" style="display:none;">
        <div class="card-header" style="background: linear-gradient(90deg, #fef3c7, #fff);">
            <span><i class="bi bi-shield-exclamation me-2" style="color:#f59e0b;"></i><span data-i18n="deployment.securityWarnings">安全告警</span></span>
        </div>
        <div class="card-body">
            <div id="deployment-security-warnings"></div>
        </div>
    </div>

</div>

@section Scripts {
    @{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
    <script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-deployment.js?v=@v"></script>

    @await Html.PartialAsync("_DashboardPageInit")

    <script>
        if (window.DashboardApi && typeof window.DashboardApi.init === 'function') {
            window.DashboardApi.init();
        }
    </script>
}
