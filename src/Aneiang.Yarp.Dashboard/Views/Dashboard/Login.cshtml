@{
    Layout = null;
    var prefix = ViewBag.DashboardRoutePrefix ?? "apigateway";
    var authMode = (int)(ViewBag.AuthMode ?? 0);
    var isEn = (ViewBag.Locale as string) == "en-US";
}

<!DOCTYPE html>
<html lang="@ViewBag.Locale">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isEn ? "Login - Gateway Dashboard" : "登录 - 网关仪表盘")</title>
    <link href="/_content/Aneiang.Yarp.Dashboard/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/_content/Aneiang.Yarp.Dashboard/lib/bootstrap-icons/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: #0f172a;
            height: 100vh; display: flex; align-items: center; justify-content: center;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            position: relative; overflow: hidden;
        }

        /* Subtle ambient glow */
        body::before {
            content: ''; position: absolute; width: 800px; height: 800px;
            border-radius: 50%; background: radial-gradient(circle, rgba(99,102,241,0.08), transparent 60%);
            top: -300px; right: -200px; pointer-events: none;
        }
        body::after {
            content: ''; position: absolute; width: 500px; height: 500px;
            border-radius: 50%; background: radial-gradient(circle, rgba(14,165,233,0.06), transparent 60%);
            bottom: -200px; left: -100px; pointer-events: none;
        }

        .login-wrapper {
            display: flex; align-items: stretch;
            position: relative; z-index: 1;
            border-radius: 16px; overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
            animation: cardEnter 0.5s ease-out;
        }
        @@keyframes cardEnter {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Left panel - branding */
        .login-brand-panel {
            width: 400px;
            background: linear-gradient(160deg, #1e293b 0%, #0f172a 100%);
            padding: 48px 40px;
            display: flex; flex-direction: column; justify-content: space-between;
            position: relative;
        }
        .login-brand-panel::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
            background: linear-gradient(90deg, #6366f1, #0ea5e9);
        }
        .brand-logo {
            display: flex; align-items: center; gap: 14px; margin-bottom: 6px;
        }
        .brand-logo-icon {
            display: inline-flex; align-items: center; justify-content: center;
            width: 44px; height: 44px; border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #4f46e5); color: #fff; font-size: 22px;
            box-shadow: 0 4px 12px rgba(99,102,241,0.3);
        }
        .brand-logo-text { color: #fff; font-size: 20px; font-weight: 700; letter-spacing: -0.3px; }
        .brand-tagline { color: #94a3b8; font-size: 13px; line-height: 1.6; margin-top: 8px; }

        .brand-features { margin-top: 40px; }
        .brand-feature { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 20px; }
        .brand-feature-icon {
            display: inline-flex; align-items: center; justify-content: center;
            width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0;
            background: rgba(99,102,241,0.12); color: #818cf8; font-size: 16px;
            border: 1px solid rgba(99,102,241,0.15);
        }
        .brand-feature-text { color: #94a3b8; font-size: 13px; line-height: 1.5; }
        .brand-feature-text strong { color: #e2e8f0; font-size: 14px; font-weight: 600; display: block; margin-bottom: 2px; }

        .brand-footer {
            color: #475569; font-size: 11px;
            margin-top: auto; padding-top: 24px;
            border-top: 1px solid rgba(148,163,184,0.08);
            display: flex; align-items: center; gap: 6px;
        }

        /* Right panel - form */
        .login-card {
            background: #ffffff; padding: 48px 40px;
            width: 420px;
            display: flex; flex-direction: column; justify-content: center;
        }
        .login-card .login-title { font-size: 22px; font-weight: 700; color: #0f172a; margin-bottom: 4px; letter-spacing: -0.3px; }
        .login-card .login-subtitle { font-size: 14px; color: #64748b; margin-bottom: 32px; }
        .login-card .form-label { font-weight: 600; color: #334155; font-size: 13px; margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
        .login-card .form-control {
            border-radius: 8px; padding: 10px 14px; border: 1px solid #cbd5e1; font-size: 14px;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .login-card .form-control:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.08); }
        .login-card .btn-primary {
            padding: 11px; font-weight: 600; border-radius: 8px; font-size: 14px;
            background: #4f46e5; border: none;
            transition: background 0.15s;
        }
        .login-card .btn-primary:hover { background: #4338ca; }
        .login-card .btn-primary:active { background: #3730a3; }
        .login-card .alert { border-radius: 8px; font-size: 13px; margin-bottom: 16px; display: none; }
        .login-card .input-icon { color: #6366f1; font-size: 14px; }

        .login-meta { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: 20px; }
        .login-meta-item { display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 12px; }
        .login-meta-dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; }
        .login-meta a { text-decoration: none; cursor: pointer; color: #94a3b8; }
        .login-meta a:hover { color: #64748b; }

        @@media (max-width: 860px) {
            .login-wrapper { flex-direction: column; }
            .login-brand-panel { width: 420px; padding: 32px 40px; }
            .login-card { width: 420px; }
            .brand-features { display: none; }
        }
        @@media (max-width: 480px) {
            .login-brand-panel, .login-card { width: 100%; padding: 32px 24px; }
            .login-wrapper { width: 100%; border-radius: 0; }
            body { padding: 0; }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <!-- Left: Brand Panel -->
        <div class="login-brand-panel">
            <div>
                <div class="brand-logo">
                    <span class="brand-logo-icon"><i class="bi bi-hdd-rack"></i></span>
                    <span class="brand-logo-text" data-i18n="login.brand">网关仪表盘</span>
                </div>
                <div class="brand-tagline" data-i18n="login.tagline">企业级 API 网关运维管理平台</div>

                <div class="brand-features">
                    <div class="brand-feature">
                        <span class="brand-feature-icon"><i class="bi bi-shield-check"></i></span>
                        <div class="brand-feature-text">
                            <strong data-i18n="login.feature.security">安全防护</strong>
                            <span data-i18n="login.feature.securityDesc">WAF、熔断、限流、IP 黑白名单一体化</span>
                        </div>
                    </div>
                    <div class="brand-feature">
                        <span class="brand-feature-icon"><i class="bi bi-diagram-3"></i></span>
                        <div class="brand-feature-text">
                            <strong data-i18n="login.feature.routing">动态路由</strong>
                            <span data-i18n="login.feature.routingDesc">运行时路由/集群管理，配置热更新</span>
                        </div>
                    </div>
                    <div class="brand-feature">
                        <span class="brand-feature-icon"><i class="bi bi-graph-up-arrow"></i></span>
                        <div class="brand-feature-text">
                            <strong data-i18n="login.feature.monitoring">实时监控</strong>
                            <span data-i18n="login.feature.monitoringDesc">流量可视化、日志追踪、告警通知</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="brand-footer">
                <i class="bi bi-shield-lock"></i><span data-i18n="login.secure">Secure Gateway Control Plane</span>
            </div>
        </div>

        <!-- Right: Login Form -->
        <div class="login-card">
            <div class="login-title" data-i18n="login.welcome">欢迎回来</div>
            <div class="login-subtitle" data-i18n="login.subtitle">请登录以继续管理您的网关</div>
            <div class="alert alert-danger" id="error-msg" role="alert"></div>
            <form id="login-form">
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-person input-icon"></i><span data-i18n="login.username">用户名</span></label>
                    <input type="text" class="form-control" id="username" data-i18n-placeholder="login.username.placeholder" placeholder="请输入用户名" required autofocus />
                </div>
                <div class="mb-4">
                    <label class="form-label"><i class="bi bi-lock input-icon"></i><span data-i18n="login.password">密码</span></label>
                    <input type="password" class="form-control" id="password" data-i18n-placeholder="login.password.placeholder" placeholder="请输入密码" required />
                </div>
                <button type="submit" class="btn btn-primary w-100" id="login-btn">
                    <span id="btn-text" data-i18n="login.submit">登 录</span>
                    <span id="btn-spinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
            </form>
            <div class="login-meta">
                <div class="login-meta-item">
                    <span class="login-meta-dot"></span>
                    <span data-i18n="login.systemOnline">系统在线</span>
                </div>
                <a href="#" onclick="switchLocale();return false;" title="@(isEn ? "切换到中文" : "Switch to English")">
                    <i class="bi bi-translate"></i><span data-i18n="layout.lang.switch">@(isEn ? "中文" : "English")</span>
                </a>
            </div>
        </div>
    </div>

    <script>
        var I18N = @Html.Raw(ViewBag.AllI18nJson ?? "{}");
        var CURRENT_LOCALE = '@ViewBag.Locale';
        function __(key) { return I18N[key] || key; }
        function switchLocale() {
            var next = CURRENT_LOCALE === 'en-US' ? 'zh-CN' : 'en-US';
            document.cookie = 'dashboard_locale=' + next + ';path=/;max-age=' + (365*86400);
            localStorage.setItem('dashboard_locale', next);
            location.reload();
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[data-i18n]').forEach(function(el) {
                var key = el.getAttribute('data-i18n');
                if (key && I18N[key]) el.textContent = I18N[key];
            });
            document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
                var key = el.getAttribute('data-i18n-placeholder');
                if (key && I18N[key]) el.placeholder = I18N[key];
            });
            document.querySelectorAll('[data-i18n-title]').forEach(function(el) {
                var key = el.getAttribute('data-i18n-title');
                if (key && I18N[key]) el.title = I18N[key];
            });
        });
    </script>
    <script>
        const basePath = '/' + '@prefix';

        document.getElementById('login-form').addEventListener('submit', async e => {
            e.preventDefault();
            const btn = document.getElementById('login-btn');
            const text = document.getElementById('btn-text');
            const spinner = document.getElementById('btn-spinner');
            const errorMsg = document.getElementById('error-msg');

            btn.disabled = true;
            text.textContent = __('login.submitting');
            spinner.classList.remove('d-none');
            errorMsg.style.display = 'none';

            try {
                const res = await fetch(basePath + '/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        username: document.getElementById('username').value.trim(),
                        password: document.getElementById('password').value
                    })
                });
                const json = await res.json();
                if (json.code === 200 && json.token) {
                    localStorage.setItem('dashboard_token', json.token);
                    window.location.href = basePath + '/';
                } else {
                    errorMsg.textContent = json.message || __('login.failed');
                    errorMsg.style.display = 'block';
                }
            } catch (err) {
                errorMsg.textContent = __('login.networkError');
                errorMsg.style.display = 'block';
            } finally {
                btn.disabled = false;
                text.textContent = __('login.submit');
                spinner.classList.add('d-none');
            }
        });
    </script>
</body>
</html>
