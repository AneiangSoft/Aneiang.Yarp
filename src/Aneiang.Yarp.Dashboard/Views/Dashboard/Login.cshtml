@{
    Layout = null;
    var prefix = ViewBag.DashboardRoutePrefix ?? "apigateway";
    var authMode = (int)(ViewBag.AuthMode ?? 0);
    var isEn = (ViewBag.Locale as string) == "en-US";
}

<!DOCTYPE html>
<html lang="@ViewBag.Locale">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isEn ? "Login - Gateway Dashboard" : "登录 - 网关仪表盘")</title>
    <link href="/_content/Aneiang.Yarp.Dashboard/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/_content/Aneiang.Yarp.Dashboard/lib/bootstrap-icons/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="/_content/Aneiang.Yarp.Dashboard/styles/inter-font.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --brand-1: #4f46e5;
            --brand-2: #6366f1;
            --brand-3: #8b5cf6;
            --brand-4: #0ea5e9;
        }
        body {
            background: #f8fafc;
            height: 100vh; display: flex; align-items: center; justify-content: center;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            position: relative; overflow: hidden;
        }

        /* ===== Small Bubbles Rising Background ===== */
        .bg-canvas {
            position: absolute; inset: 0; pointer-events: none; z-index: 0; overflow: hidden;
        }
        .bubble {
            position: absolute; bottom: -20px; border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.6), var(--b-color) 60%, transparent 100%);
            box-shadow: inset 0 0 4px rgba(255,255,255,0.4);
            opacity: 0;
            will-change: transform, opacity;
            animation: rise var(--b-dur, 15s) linear infinite;
            animation-delay: var(--b-delay, 0s);
        }
        @@keyframes rise {
            0% { transform: translate3d(0, 0, 0) scale(0.6); opacity: 0; }
            8% { opacity: var(--b-opacity, 0.55); }
            50% { transform: translate3d(var(--b-sway-mid, 15px), -50vh, 0) scale(1); }
            92% { opacity: var(--b-opacity, 0.55); }
            100% { transform: translate3d(var(--b-sway-end, -10px), -115vh, 0) scale(1.1); opacity: 0; }
        }

        /* ===== Login Card ===== */
        .login-wrapper {
            position: relative; z-index: 1;
            width: 880px; max-width: calc(100vw - 40px);
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-radius: 24px; overflow: hidden;
            border: 1px solid rgba(255,255,255,0.6);
            box-shadow: 0 24px 64px rgba(15,23,42,0.1), 0 2px 8px rgba(15,23,42,0.04);
            display: flex;
            animation: cardIn 0.7s cubic-bezier(0.16,1,0.3,1);
        }
        @@keyframes cardIn {
            from { opacity: 0; transform: translateY(28px) scale(0.97); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        /* ===== Left: Brand Panel ===== */
        .brand-panel {
            width: 440px; flex-shrink: 0;
            background: linear-gradient(160deg, #4f46e5 0%, #6366f1 35%, #7c3aed 70%, #0ea5e9 100%);
            padding: 48px 40px;
            display: flex; flex-direction: column; justify-content: space-between;
            position: relative; overflow: hidden;
        }
        /* Decorative circles inside brand panel */
        .brand-panel::before {
            content: ''; position: absolute; width: 300px; height: 300px;
            border-radius: 50%; background: rgba(255,255,255,0.06);
            top: -100px; right: -80px;
        }
        .brand-panel::after {
            content: ''; position: absolute; width: 200px; height: 200px;
            border-radius: 50%; background: rgba(255,255,255,0.04);
            bottom: -60px; left: -40px;
        }

        .brand-logo {
            display: flex; align-items: center; gap: 14px;
            position: relative; z-index: 1;
        }
        .brand-logo-icon {
            width: 46px; height: 46px; border-radius: 12px;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.25);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 22px;
        }
        .brand-logo-text { color: #fff; font-size: 20px; font-weight: 700; letter-spacing: -0.3px; }
        .brand-tagline { color: rgba(255,255,255,0.75); font-size: 13px; line-height: 1.6; margin-top: 10px; position: relative; z-index: 1; }

        .brand-features { margin-top: 40px; position: relative; z-index: 1; }
        .brand-feature { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 22px; }
        .brand-feature-icon {
            width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.15);
            display: flex; align-items: center; justify-content: center;
            color: rgba(255,255,255,0.9); font-size: 16px;
        }
        .brand-feature-text { color: rgba(255,255,255,0.7); font-size: 12.5px; line-height: 1.5; }
        .brand-feature-text strong { color: #fff; font-size: 14px; font-weight: 600; display: block; margin-bottom: 3px; }

        .brand-footer {
            color: rgba(255,255,255,0.4); font-size: 11px;
            margin-top: auto; padding-top: 24px;
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex; align-items: center; gap: 6px;
            position: relative; z-index: 1; letter-spacing: 0.3px;
        }

        /* ===== Right: Form Panel ===== */
        .form-panel {
            flex: 1; padding: 48px 44px;
            display: flex; flex-direction: column; justify-content: center;
        }
        .form-title { font-size: 24px; font-weight: 700; color: #0f172a; margin-bottom: 6px; letter-spacing: -0.3px; }
        .form-subtitle { font-size: 14px; color: #64748b; margin-bottom: 32px; }

        .form-group { margin-bottom: 20px; }
        .form-label { font-weight: 600; color: #334155; font-size: 13px; margin-bottom: 7px; display: flex; align-items: center; gap: 6px; }
        .form-control {
            width: 100%; border-radius: 10px; padding: 12px 16px;
            border: 1.5px solid #e2e8f0; font-size: 14px;
            background: #f8fafc; color: #0f172a;
            transition: all 0.2s ease;
            font-family: inherit;
        }
        .form-control:focus { outline: none; border-color: var(--brand-2); box-shadow: 0 0 0 4px rgba(99,102,241,0.1); background: #fff; }
        .form-control::placeholder { color: #cbd5e1; }
        .input-icon { color: var(--brand-2); font-size: 14px; }

        .alert { border-radius: 10px; font-size: 13px; margin-bottom: 16px; display: none; padding: 10px 14px; }
        .alert-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }

        .btn-login {
            width: 100%; padding: 13px; border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600; color: #fff; cursor: pointer;
            background: linear-gradient(135deg, var(--brand-1), var(--brand-2));
            box-shadow: 0 4px 14px rgba(79,70,229,0.3);
            transition: all 0.2s ease;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-login:hover { background: linear-gradient(135deg, #4338ca, var(--brand-1)); box-shadow: 0 6px 20px rgba(79,70,229,0.4); transform: translateY(-1px); }
        .btn-login:active { transform: translateY(0); }
        .btn-login:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

        .form-meta { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: 24px; }
        .form-meta-item { display: flex; align-items: center; gap: 6px; color: #94a3b8; font-size: 12px; }
        .meta-dot { width: 7px; height: 7px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,0.4); animation: pulse 2s ease-in-out infinite; }
        @@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
        .form-meta a { text-decoration: none; cursor: pointer; color: #94a3b8; font-size: 12px; display: flex; align-items: center; gap: 4px; }
        .form-meta a:hover { color: #64748b; }

        /* Footer */
        .login-footer {
            position: absolute; bottom: 20px; left: 0; right: 0;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            color: rgba(100, 116, 139, 0.6); font-size: 11.5px; z-index: 1;
            letter-spacing: 0.2px;
        }
        .footer-sep { opacity: 0.4; }

        .twofactor-hint { font-size: 12px; color: #94a3b8; margin-top: 6px; }

        /* ===== Responsive ===== */
        @@media (max-width: 860px) {
            .login-wrapper { flex-direction: column; width: 420px; }
            .brand-panel { width: 100%; padding: 32px 36px; }
            .brand-features { display: none; }
            .form-panel { padding: 36px; }
        }
        @@media (max-width: 480px) {
            .login-wrapper { width: 100%; border-radius: 0; }
            .brand-panel, .form-panel { padding: 28px 22px; }
            body { padding: 0; }
        }
    </style>
</head>
<body>
    <!-- Animated Background -->
    <div class="bg-canvas" id="bg-canvas"></div>

    <div class="login-wrapper">
        <!-- Left: Brand Panel -->
        <div class="brand-panel">
            <div>
                <div class="brand-logo">
                    <span class="brand-logo-icon"><i class="bi bi-hdd-rack-fill"></i></span>
                    <span class="brand-logo-text" data-i18n="login.brand">网关仪表盘</span>
                </div>
                <div class="brand-tagline" data-i18n="login.tagline">企业级 API 网关运维管理平台</div>

                <div class="brand-features">
                    <div class="brand-feature">
                        <span class="brand-feature-icon"><i class="bi bi-shield-check"></i></span>
                        <div class="brand-feature-text">
                            <strong data-i18n="login.feature.security">安全防护</strong>
                            <span data-i18n="login.feature.securityDesc">WAF、熔断、限流、IP 黑白名单一体化</span>
                        </div>
                    </div>
                    <div class="brand-feature">
                        <span class="brand-feature-icon"><i class="bi bi-diagram-3"></i></span>
                        <div class="brand-feature-text">
                            <strong data-i18n="login.feature.routing">动态路由</strong>
                            <span data-i18n="login.feature.routingDesc">运行时路由/集群管理，配置热更新</span>
                        </div>
                    </div>
                    <div class="brand-feature">
                        <span class="brand-feature-icon"><i class="bi bi-graph-up-arrow"></i></span>
                        <div class="brand-feature-text">
                            <strong data-i18n="login.feature.monitoring">实时监控</strong>
                            <span data-i18n="login.feature.monitoringDesc">流量可视化、日志追踪、告警通知</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="brand-footer">
                <i class="bi bi-shield-lock"></i><span data-i18n="login.secure">Secure Gateway Control Plane</span>
            </div>
        </div>

        <!-- Right: Form Panel -->
        <div class="form-panel">
            <div class="form-title" data-i18n="login.welcome">欢迎回来</div>
            <div class="form-subtitle" data-i18n="login.subtitle">请登录以继续管理您的网关</div>

            <div class="alert alert-danger" id="error-msg" role="alert"></div>
            <div class="alert alert-info d-none" id="info-msg" role="alert"></div>

            <form id="login-form">
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-person input-icon"></i><span data-i18n="login.username">用户名</span></label>
                    <input type="text" class="form-control" id="username" data-i18n-placeholder="login.username.placeholder" placeholder="请输入用户名" required autofocus />
                </div>
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-lock input-icon"></i><span data-i18n="login.password">密码</span></label>
                    <input type="password" class="form-control" id="password" data-i18n-placeholder="login.password.placeholder" placeholder="请输入密码" required />
                </div>
                <div class="form-group d-none" id="twofactor-group">
                    <label class="form-label"><i class="bi bi-shield-lock input-icon"></i><span data-i18n="login.twofactor">两步验证码</span></label>
                    <input type="text" class="form-control" id="twofactor-code" data-i18n-placeholder="login.twofactor.placeholder" placeholder="输入 6 位验证码" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" />
                    <div class="twofactor-hint" data-i18n="login.twofactorHint">请打开验证器应用获取 6 位验证码</div>
                </div>
                <button type="submit" class="btn-login" id="login-btn">
                    <span id="btn-text" data-i18n="login.submit">登 录</span>
                    <span id="btn-spinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
            </form>

            <div class="form-meta">
                <span></span>
                <a href="#" onclick="switchLocale();return false;" title="@(isEn ? "切换到中文" : "Switch to English")">
                    <i class="bi bi-translate"></i><span data-i18n="layout.lang.switch">@(isEn ? "中文" : "English")</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Footer: version + copyright -->
    @{
        var loginVersion = typeof(Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models.LogEntry).Assembly.GetName().Version?.ToString(3) ?? "1.0.0";
    }
    <div class="login-footer">
        <span>v@(loginVersion)</span>
        <span class="footer-sep">·</span>
        <span>MIT License</span>
        <span class="footer-sep">·</span>
        <span>&copy; 2026 Aneiang.Yarp</span>
    </div>

    <script>
        // Generate small rising bubbles
        (function() {
            var container = document.getElementById('bg-canvas');
            if (!container) return;
            var colors = [
                'rgba(99,102,241,0.5)',   // indigo
                'rgba(139,92,246,0.45)',  // violet
                'rgba(14,165,233,0.5)',   // sky
                'rgba(59,130,246,0.45)',  // blue
                'rgba(168,85,247,0.4)',   // purple
                'rgba(236,72,153,0.35)'   // pink
            ];
            for (var i = 0; i < 24; i++) {
                var b = document.createElement('div');
                b.className = 'bubble';
                // Small sizes 4-14px
                var size = 4 + Math.random() * 10;
                b.style.width = size + 'px';
                b.style.height = size + 'px';
                b.style.left = (Math.random() * 100) + '%';
                b.style.setProperty('--b-color', colors[i % colors.length]);
                b.style.setProperty('--b-opacity', 0.35 + Math.random() * 0.3);
                b.style.setProperty('--b-sway-mid', (Math.random() * 60 - 30) + 'px');
                b.style.setProperty('--b-sway-end', (Math.random() * 60 - 30) + 'px');
                b.style.setProperty('--b-dur', (10 + Math.random() * 14) + 's');
                b.style.setProperty('--b-delay', (Math.random() * 18) + 's');
                container.appendChild(b);
            }
        })();
    </script>
    <script>
        var I18N = @Html.Raw(ViewBag.AllI18nJson ?? "{}");
        var CURRENT_LOCALE = '@ViewBag.Locale';
        function __(key) { return I18N[key] || key; }
        function switchLocale() {
            var next = CURRENT_LOCALE === 'en-US' ? 'zh-CN' : 'en-US';
            document.cookie = 'dashboard_locale=' + next + ';path=/;max-age=' + (365*86400);
            localStorage.setItem('dashboard_locale', next);
            location.reload();
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[data-i18n]').forEach(function(el) {
                var key = el.getAttribute('data-i18n');
                if (key && I18N[key]) el.textContent = I18N[key];
            });
            document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
                var key = el.getAttribute('data-i18n-placeholder');
                if (key && I18N[key]) el.placeholder = I18N[key];
            });
        });
    </script>
    <script>
        const basePath = '/' + '@prefix';

        document.getElementById('login-form').addEventListener('submit', async e => {
            e.preventDefault();
            const btn = document.getElementById('login-btn');
            const text = document.getElementById('btn-text');
            const spinner = document.getElementById('btn-spinner');
            const errorMsg = document.getElementById('error-msg');
            const infoMsg = document.getElementById('info-msg');
            const twofaGroup = document.getElementById('twofactor-group');
            const isTwofaVisible = twofaGroup && !twofaGroup.classList.contains('d-none');

            btn.disabled = true;
            text.textContent = isTwofaVisible ? __('login.verifying') : __('login.submitting');
            spinner.classList.remove('d-none');
            errorMsg.style.display = 'none';
            infoMsg.style.display = 'none';

            try {
                const res = await fetch(basePath + '/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        username: document.getElementById('username').value.trim(),
                        password: document.getElementById('password').value,
                        twoFactorCode: (document.getElementById('twofactor-code') || {}).value || null
                    })
                });
                const json = await res.json();
                if (json.code === 200 && json.token) {
                    localStorage.setItem('dashboard_token', json.token);
                    window.location.href = basePath + '/';
                } else if (json.code === 202 && json.requiresTwoFactor) {
                    if (twofaGroup) {
                        twofaGroup.classList.remove('d-none');
                        var twofaInput = document.getElementById('twofactor-code');
                        if (twofaInput) twofaInput.focus();
                    }
                    infoMsg.textContent = __('login.twofactorRequired');
                    infoMsg.style.display = 'block';
                    text.textContent = __('login.verify');
                } else {
                    errorMsg.textContent = json.message || __('login.failed');
                    errorMsg.style.display = 'block';
                    if (isTwofaVisible) {
                        text.textContent = __('login.verify');
                    }
                }
            } catch (err) {
                errorMsg.textContent = __('login.networkError');
                errorMsg.style.display = 'block';
            } finally {
                btn.disabled = false;
                if (!isTwofaVisible && !document.getElementById('twofactor-group').classList.contains('d-none')) {
                    text.textContent = __('login.verify');
                } else if (document.getElementById('twofactor-group').classList.contains('d-none')) {
                    text.textContent = __('login.submit');
                }
                spinner.classList.add('d-none');
            }
        });
    </script>
</body>
</html>
