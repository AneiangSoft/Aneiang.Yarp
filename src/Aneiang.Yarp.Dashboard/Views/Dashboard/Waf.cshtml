@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "WAF Firewall" : "WAF 防火墙";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    /* ── Unified Card System ── */
    .waf-card {
        border-left: 3px solid #cbd5e1;
        border-radius: 6px;
        background: #f8fafc;
        padding: 14px 18px 16px;
        margin-bottom: 14px;
    }
    .waf-card-head {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12.5px;
        font-weight: 600;
        color: #475569;
        letter-spacing: .02em;
        text-transform: uppercase;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid #e2e8f0;
    }
    .waf-card-head .waf-icon {
        width: 22px; height: 22px;
        border-radius: 5px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: #fff;
        flex-shrink: 0;
    }
    .waf-row { display: flex; gap: 16px; flex-wrap: wrap; }
    .waf-cell { flex: 1 1 0; min-width: 180px; }
    .waf-cell-2 { flex: 2 1 0; }
    .waf-lbl {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: #334155;
        margin-bottom: 5px;
        line-height: 1.3;
        min-height: 16px;
    }
    .waf-ctrl { min-height: 31px; display: flex; align-items: center; }
    .waf-desc {
        font-size: 11px;
        color: #94a3b8;
        line-height: 1.45;
        margin-top: 5px;
    }
    .waf-unit {
        font-size: 11px;
        color: #64748b;
        min-width: 38px;
        text-align: center;
    }

    /* ── Switch ── */
    .waf-sw {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .waf-sw .form-check-input {
        width: 36px; height: 18px;
        cursor: pointer;
        flex-shrink: 0;
        margin: 0;
    }
    .waf-sw .form-check-label {
        font-size: 12px;
        color: #475569;
        cursor: pointer;
        line-height: 1.3;
    }

    /* ── Status Banner ── */
    .waf-banner {
        border-radius: 8px;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all 0.3s ease;
        margin-bottom: 14px;
    }
    .waf-banner.on {
        background: linear-gradient(135deg, #059669 0%, #10b981 100%);
        color: #fff;
    }
    .waf-banner.off {
        background: linear-gradient(135deg, #475569 0%, #64748b 100%);
        color: #fff;
    }
    .waf-banner .form-check-input {
        width: 3em; height: 1.5em;
        cursor: pointer;
    }
    .waf-banner.off .form-check-input {
        background-color: rgba(255,255,255,0.3);
        border-color: rgba(255,255,255,0.4);
    }

    /* ── Flow Pipeline ── */
    .waf-flow {
        display: flex;
        align-items: flex-start;
        gap: 0;
        overflow-x: auto;
        padding: 10px 0 6px;
    }
    .waf-flow-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 80px;
        flex-shrink: 0;
        position: relative;
    }
    .waf-flow-dot {
        width: 36px; height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        border: 2px solid #e2e8f0;
        background: #fff;
        color: #94a3b8;
        margin-bottom: 6px;
        transition: all .25s;
        position: relative;
        z-index: 1;
    }
    .waf-flow-dot.hit {
        border-color: #ef4444;
        background: #fef2f2;
        color: #dc2626;
        box-shadow: 0 0 0 3px rgba(239,68,68,.1);
    }
    .waf-flow-lbl {
        font-size: 11px;
        color: #64748b;
        text-align: center;
        line-height: 1.2;
        white-space: nowrap;
    }
    .waf-flow-cnt {
        font-size: 10px;
        color: #cbd5e1;
        margin-top: 2px;
        font-variant-numeric: tabular-nums;
    }
    .waf-flow-cnt.hit { color: #dc2626; font-weight: 600; }
    .waf-flow-line {
        flex-shrink: 0;
        width: 28px;
        height: 2px;
        background: #e2e8f0;
        margin-top: 18px;
    }
    .waf-flow-line.hit { background: #ef4444; }

    /* ── Rule Cards ── */
    .waf-rule {
        border: 1px solid #e2e8f0;
        border-left: 3px solid #cbd5e1;
        border-radius: 6px;
        padding: 14px 16px;
        height: 100%;
        display: flex;
        flex-direction: column;
        background: #fff;
        transition: box-shadow .2s;
    }
    .waf-rule:hover { box-shadow: 0 2px 8px rgba(0,0,0,.05); }
    .waf-rule-title {
        font-size: 13px;
        font-weight: 600;
        color: #334155;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .waf-rule-desc {
        font-size: 11.5px;
        color: #64748b;
        line-height: 1.45;
        margin-bottom: 8px;
    }
    .waf-rule-code {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 4px;
        padding: 6px 10px;
        font-family: 'Cascadia Code','Fira Code','Consolas',monospace;
        font-size: 11px;
        color: #dc2626;
        margin-bottom: 10px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .waf-rule-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 10px;
        border-top: 1px solid #f1f5f9;
    }
    .waf-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 500;
        white-space: nowrap;
    }
    .waf-badge.hit { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .waf-badge.clean { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }

    /* ── Sub-panel (events) ── */
    .waf-sub {
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        background: #fff;
        padding: 12px 14px;
        height: 100%;
    }
    .waf-sub-head {
        font-size: 12px;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* ── Event entries ── */
    .waf-ev {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 7px 10px;
        border-radius: 6px;
        background: #fafafa;
        border: 1px solid #f1f5f9;
        transition: background .15s;
        font-size: 12px;
    }
    .waf-ev:hover { background: #f1f5f9; }
    .waf-ev + .waf-ev { margin-top: 4px; }
    .waf-ev .ev-time { color: #94a3b8; font-variant-numeric: tabular-nums; white-space: nowrap; min-width: 50px; font-size: 11px; }
    .waf-ev .ev-type { min-width: 68px; text-align: center; }
    .waf-ev .ev-ip { color: #374151; font-family: 'Cascadia Code','Fira Code',monospace; font-size: 11px; min-width: 105px; }
    .waf-ev .ev-target { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #64748b; font-size: 11px; }
    .waf-ev .ev-target code { font-size: 11px; background: none; padding: 0; color: inherit; }

    /* ── IP Bar ── */
    .waf-ipbar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 3px 0;
        font-size: 12px;
    }
    .waf-ipbar .ip-addr { font-family: 'Cascadia Code','Fira Code',monospace; font-size: 11px; min-width: 115px; color: #374151; }
    .waf-ipbar .ip-track { flex: 1; height: 5px; background: #f1f5f9; border-radius: 3px; overflow: hidden; }
    .waf-ipbar .ip-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, #ef4444, #f97316); transition: width .5s; }
    .waf-ipbar .ip-cnt { min-width: 28px; text-align: right; color: #64748b; font-variant-numeric: tabular-nums; font-size: 11px; }

    /* ── Empty state ── */
    .waf-empty {
        padding: 20px 0;
        text-align: center;
        color: #cbd5e1;
        font-size: 12px;
    }

    /* ── Hint ── */
    .waf-hint {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 8px 0;
        font-size: 12px;
        color: #64748b;
        border-left: 3px solid #3b82f6;
        padding-left: 12px;
        margin: 4px 0 14px;
    }
    .waf-hint i { color: #3b82f6; margin-top: 1px; flex-shrink: 0; }
</style>

<div class="card-panel mb-4">
    <div class="card-header">
        <span><i class="bi bi-shield-lock me-2" style="color:#ef4444;"></i><span data-i18n="waf.title">WAF 防火墙设置</span></span>
        <div class="card-header-actions">
            <button class="btn btn-sm btn-primary px-4" onclick="DashboardWafSettings.save()">
                <i class="bi bi-check-lg"></i> <span data-i18n="waf.save">保存设置</span>
            </button>
        </div>
    </div>
    <div class="card-body" id="waf-settings-body">
        <div class="loading-state" id="waf-loading">
            <div class="loading-spinner"></div>
            <div class="loading-text" data-i18n="security.loading">加载中...</div>
        </div>

        <div id="waf-content" style="display:none;">
            <!-- Status Banner -->
            <div id="waf-status-banner"></div>

            <!-- Check Flow Pipeline -->
            <div class="waf-card" style="border-left-color:#3b82f6">
                <div class="waf-card-head">
                    <span class="waf-icon" style="background:#3b82f6"><i class="bi bi-diagram-3"></i></span>
                    <span data-i18n="waf.flowTitle">检查流水线</span>
                </div>
                <p class="waf-desc" style="margin-bottom:8px" data-i18n="waf.flowDesc">请求到达时，WAF 按以下顺序依次执行 7 层安全检查，任意一层拦截即阻断请求</p>
                <div class="waf-flow" id="waf-flow-steps"></div>
            </div>

            <!-- Rule Cards -->
            <div class="waf-card" style="border-left-color:#ef4444">
                <div class="waf-card-head">
                    <span class="waf-icon" style="background:#ef4444"><i class="bi bi-shield-exclamation"></i></span>
                    <span data-i18n="waf.detectionRules">威胁检测规则</span>
                </div>
                <div class="row g-3" id="waf-rule-cards"></div>
            </div>

            <!-- Request Limits -->
            <div class="waf-card" style="border-left-color:#8b5cf6">
                <div class="waf-card-head">
                    <span class="waf-icon" style="background:#8b5cf6"><i class="bi bi-rulers"></i></span>
                    <span data-i18n="waf.requestLimits">请求限制</span>
                </div>
                <div class="waf-row">
                    <div class="waf-cell">
                        <label class="waf-lbl" for="waf-max-body" data-i18n="waf.maxBodySize">请求体大小上限 (MB)</label>
                        <div class="waf-ctrl">
                            <div class="input-group input-group-sm">
                                <input type="number" class="form-control" id="waf-max-body" min="1" value="10">
                                <span class="input-group-text waf-unit">MB</span>
                            </div>
                        </div>
                    </div>
                    <div class="waf-cell">
                        <label class="waf-lbl" for="waf-max-headers" data-i18n="waf.maxHeaderCount">请求头数量上限</label>
                        <div class="waf-ctrl">
                            <input type="number" class="form-control form-control-sm" id="waf-max-headers" min="1" value="64">
                        </div>
                    </div>
                    <div class="waf-cell">
                        <label class="waf-lbl" for="waf-max-header-size" data-i18n="waf.maxHeaderSize">单个请求头大小上限 (字节)</label>
                        <div class="waf-ctrl">
                            <div class="input-group input-group-sm">
                                <input type="number" class="form-control" id="waf-max-header-size" min="256" value="8192">
                                <span class="input-group-text waf-unit">bytes</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- IP Lists -->
            <div class="waf-card" style="border-left-color:#f59e0b">
                <div class="waf-card-head">
                    <span class="waf-icon" style="background:#f59e0b"><i class="bi bi-geo-alt"></i></span>
                    <span data-i18n="waf.ipWhitelist">IP 白名单</span> / <span data-i18n="waf.ipBlacklist">IP 黑名单</span>
                </div>
                <div class="waf-row">
                    <div class="waf-cell">
                        <label class="waf-lbl"><i class="bi bi-shield-check me-1" style="color:#22c55e"></i><span data-i18n="waf.ipWhitelist">IP 白名单</span></label>
                        <div class="waf-ctrl">
                            <textarea class="form-control form-control-sm" id="waf-whitelist" rows="4" style="font-family:'Cascadia Code','Fira Code',monospace;font-size:12px" data-i18n="waf.ipWhitelist.help" placeholder="每行一个 IP 或 CIDR，如 192.168.1.0/24"></textarea>
                        </div>
                    </div>
                    <div class="waf-cell">
                        <label class="waf-lbl"><i class="bi bi-slash-circle me-1" style="color:#ef4444"></i><span data-i18n="waf.ipBlacklist">IP 黑名单</span></label>
                        <div class="waf-ctrl">
                            <textarea class="form-control form-control-sm" id="waf-blacklist" rows="4" style="font-family:'Cascadia Code','Fira Code',monospace;font-size:12px" data-i18n="waf.ipBlacklist.help" placeholder="每行一个 IP 或 CIDR"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Route Override Hint -->
            <div class="waf-hint">
                <i class="bi bi-info-circle"></i>
                <span data-i18n="waf.routeOverrideHint">提示：路由级 WAF 设置可覆盖全局配置（在路由策略中配置）</span>
            </div>

            <!-- Security Events Panel -->
            <div class="waf-card" style="border-left-color:#ef4444">
                <div class="waf-card-head">
                    <span class="waf-icon" style="background:#ef4444"><i class="bi bi-shield-fill-exclamation"></i></span>
                    <span data-i18n="waf.recentEvents">实时安全事件</span>
                    <button class="btn btn-sm btn-outline-danger ms-2" id="waf-test-event-btn" title="生成测试事件" style="font-size:11px;padding:2px 10px;">
                        <i class="bi bi-bug"></i> <span data-i18n="waf.testEvent">模拟攻击</span>
                    </button>
                    <span class="badge bg-secondary ms-2" id="waf-event-badge" style="font-size:10px;display:none;"></span>
                    <span class="text-muted ms-2" id="waf-event-refresh-time" style="font-size:10px;margin-left:auto;"></span>
                </div>
                <p class="waf-desc" style="margin-bottom:10px" data-i18n="waf.recentEventsDesc">以下展示最新触发的安全事件，与安全事件页面实时同步</p>
                <div class="row g-3">
                    <div class="col-lg-8">
                        <div class="waf-sub">
                            <div class="waf-sub-head"><i class="bi bi-shield-x" style="color:#ef4444"></i> <span data-i18n="waf.recentBlocks">最近拦截</span> <span class="text-muted" id="waf-event-summary-total" style="margin-left:auto;font-weight:400"></span></div>
                            <div id="waf-recent-events"><div class="waf-empty"><i class="bi bi-shield-check me-1"></i><span data-i18n="waf.noRecentEvents">暂无安全事件，发动一次模拟攻击试试</span></div></div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="waf-sub">
                            <div class="waf-sub-head"><i class="bi bi-bar-chart" style="color:#f59e0b"></i> <span data-i18n="security.topIps">Top 攻击源IP</span></div>
                            <div id="waf-top-ips"><div class="waf-empty"><i class="bi bi-info-circle me-1"></i><span data-i18n="waf.noIpData">暂无数据</span></div></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }

<script>
window.DashboardWafSettings = {
    _data: null,
    _eventCounts: null,

    _steps: [
        { key:'ip', icon:'bi-geo-alt',     eventTypes:['IpBlocked'] },
        { key:'requestSize', icon:'bi-file-earmark', eventTypes:['RequestSizeBlocked'] },
        { key:'headers', icon:'bi-card-heading',     eventTypes:['MalformedHeadersBlocked'] },
        { key:'uriLength', icon:'bi-link-45deg',     eventTypes:['UriTooLongBlocked'] },
        { key:'pathTraversal', icon:'bi-folder2-open', eventTypes:['PathTraversalBlocked','PathTraversalInQueryBlocked'] },
        { key:'sqlInjection', icon:'bi-database',    eventTypes:['SqlInjectionBlocked','SqlInjectionValueBlocked'] },
        { key:'xss', icon:'bi-code-slash',           eventTypes:['XssBlocked'] }
    ],

    _rules: [
        { key:'sqli',    icon:'bi-database',   titleKey:'waf.sqlInjection',     descKey:'waf.sqlInjection.desc',     exampleKey:'waf.sqlInjection.example',     id:'waf-sqli',    dataField:'enableSqlInjectionDetection',  eventTypes:['SqlInjectionBlocked','SqlInjectionValueBlocked'] },
        { key:'xss',     icon:'bi-code-slash', titleKey:'waf.xss',              descKey:'waf.xss.desc',              exampleKey:'waf.xss.example',              id:'waf-xss',     dataField:'enableXssDetection',            eventTypes:['XssBlocked'] },
        { key:'path',    icon:'bi-folder2-open',titleKey:'waf.pathTraversal',   descKey:'waf.pathTraversal.desc',    exampleKey:'waf.pathTraversal.example',    id:'waf-path',    dataField:'enablePathTraversalDetection',  eventTypes:['PathTraversalBlocked','PathTraversalInQueryBlocked'] },
        { key:'ip',      icon:'bi-geo-alt',    titleKey:'waf.ipCheck',          descKey:'waf.ipCheck.desc',          exampleKey:'waf.ipCheck.example',          id:'waf-ip-check', dataField:'enableIpCheck',                 eventTypes:['IpBlocked'] }
    ],

    init: async function() {
        try {
            var results = await Promise.all([
                DashboardApi.endpoints.getWafSettings(),
                DashboardApi.endpoints.getSecurityEventSummary(),
                DashboardApi.endpoints.getSecurityEvents(20)
            ]);
            this._data = results[0] || {};
            var summary = results[1];
            var eventsResult = results[2] || {};
            this._eventCounts = (summary && summary.typeCounts) ? summary.typeCounts : {};
            this._recentEvents = eventsResult.entries || [];
            this._topIps = (summary && summary.topIps) ? summary.topIps : {};
            this.render();
            this._startAutoRefresh();
            this._bindEventButtons();
        } catch (e) {
            console.error('[WafSettings] Load failed:', e);
            document.getElementById('waf-loading').style.display = 'none';
            document.getElementById('waf-settings-body').innerHTML = '<div class="alert alert-danger m-3">' + __('waf.loadFailed') + '</div>';
        }
    },

    render: function() {
        document.getElementById('waf-loading').style.display = 'none';
        document.getElementById('waf-content').style.display = 'block';
        this._renderStatusBanner();
        this._renderFlowSteps();
        this._renderRuleCards();
        this._fillFormFields();
    },

    _getCount: function(eventTypes) {
        var counts = this._eventCounts || {};
        var total = 0;
        for (var i = 0; i < eventTypes.length; i++) {
            total += counts[eventTypes[i]] || 0;
        }
        return total;
    },

    _renderStatusBanner: function() {
        var d = this._data || {};
        var enabled = d.enabled !== false;
        document.getElementById('waf-status-banner').innerHTML =
            '<div class="waf-banner ' + (enabled ? 'on' : 'off') + '">' +
                '<div style="display:flex;align-items:center;gap:12px;">' +
                    '<i class="bi bi-' + (enabled ? 'shield-check' : 'shield-slash') + '" style="font-size:22px;"></i>' +
                    '<div>' +
                        '<div style="font-weight:600;font-size:14px;">' + __('waf.globalSwitch') + '</div>' +
                        '<div style="font-size:12px;opacity:.8;">' + (enabled ? __('waf.globalSwitch.on') : __('waf.globalSwitch.off')) + '</div>' +
                    '</div>' +
                '</div>' +
                '<div class="waf-sw">' +
                    '<span class="waf-sw-txt" style="color:rgba(255,255,255,.7);font-size:11px;">' + (enabled ? 'ON' : 'OFF') + '</span>' +
                    '<div class="form-check form-switch mb-0">' +
                        '<input class="form-check-input" type="checkbox" id="waf-enabled" ' + (enabled ? 'checked' : '') + ' style="width:3em;height:1.5em;cursor:pointer;">' +
                    '</div>' +
                '</div>' +
            '</div>';

        document.getElementById('waf-enabled').addEventListener('change', function() {
            DashboardWafSettings._data.enabled = this.checked;
            DashboardWafSettings._renderStatusBanner();
        });
    },

    _renderFlowSteps: function() {
        var html = '';
        var steps = this._steps;
        for (var i = 0; i < steps.length; i++) {
            var s = steps[i];
            var cnt = this._getCount(s.eventTypes);
            var hasCount = cnt > 0;
            html +=
                '<div class="waf-flow-node">' +
                    '<div class="waf-flow-dot' + (hasCount ? ' hit' : '') + '">' +
                        '<i class="bi ' + s.icon + '"></i>' +
                    '</div>' +
                    '<div class="waf-flow-lbl">' + __('waf.step.' + s.key) + '</div>' +
                    '<div class="waf-flow-cnt' + (hasCount ? ' hit' : '') + '">' +
                        (hasCount ? cnt + 'x blocked' : '\u2014') +
                    '</div>' +
                '</div>';
            if (i < steps.length - 1) {
                var nextCnt = this._getCount(steps[i + 1].eventTypes);
                html += '<div class="waf-flow-line' + ((hasCount || nextCnt > 0) ? ' hit' : '') + '"></div>';
            }
        }
        document.getElementById('waf-flow-steps').innerHTML = html;
    },

    _ruleColors: { sqli: '#ef4444', xss: '#f59e0b', path: '#3b82f6', ip: '#22c55e' },

    _renderRuleCards: function() {
        var html = '';
        var rules = this._rules;
        for (var i = 0; i < rules.length; i++) {
            var r = rules[i];
            var cnt = this._getCount(r.eventTypes);
            var hasCount = cnt > 0;
            var d = this._data || {};
            var checked = d[r.dataField] !== false;
            var color = this._ruleColors[r.key] || '#cbd5e1';
            var onTxt = checked ? '<span style="font-size:10px;color:#16a34a;font-weight:600;">ON</span>' : '<span style="font-size:10px;color:#94a3b8;font-weight:600;">OFF</span>';
            html +=
                '<div class="col-md-6 col-lg-3">' +
                    '<div class="waf-rule" style="border-left-color:' + color + '">' +
                        '<div class="waf-rule-title">' +
                            '<i class="bi ' + r.icon + '" style="color:' + color + ';"></i>' + __('' + r.titleKey) +
                        '</div>' +
                        '<div class="waf-rule-desc">' + __('' + r.descKey) + '</div>' +
                        '<div class="waf-rule-code" title="' + __('' + r.exampleKey) + '">' +
                            '<i class="bi bi-lightning-fill" style="color:#f59e0b;font-size:10px;margin-right:4px;"></i>' + __('' + r.exampleKey) +
                        '</div>' +
                        '<div class="waf-rule-foot">' +
                            '<div class="waf-sw">' +
                                '<div class="form-check form-switch mb-0">' +
                                    '<input class="form-check-input" type="checkbox" id="' + r.id + '" ' + (checked ? 'checked' : '') + ' style="width:36px;height:18px;cursor:pointer;margin:0;">' +
                                '</div>' +
                                onTxt +
                            '</div>' +
                            '<span class="waf-badge ' + (hasCount ? 'hit' : 'clean') + '">' +
                                '<i class="bi bi-' + (hasCount ? 'exclamation-circle' : 'check-circle') + '"></i> ' +
                                (hasCount ? __('waf.triggerCount').replace('{count}', cnt) : __('waf.neverTriggered')) +
                            '</span>' +
                        '</div>' +
                    '</div>' +
                '</div>';
        }
        document.getElementById('waf-rule-cards').innerHTML = html;
    },

    _fillFormFields: function() {
        var d = this._data || {};
        var mb = Math.round((d.maxRequestBodySize || 10485760) / (1024 * 1024));
        var el = document.getElementById('waf-max-body');
        if (el) el.value = mb;
        el = document.getElementById('waf-max-headers');
        if (el) el.value = d.maxHeaderCount || 64;
        el = document.getElementById('waf-max-header-size');
        if (el) el.value = d.maxHeaderSize || 8192;
        el = document.getElementById('waf-whitelist');
        if (el) el.value = this._listToText(d.ipWhitelist);
        el = document.getElementById('waf-blacklist');
        if (el) el.value = this._listToText(d.ipBlacklist);
    },

    _listToText: function(arr) {
        if (!arr || !arr.length) return '';
        return arr.join('\n');
    },

    save: async function() {
        var mbVal = parseInt(document.getElementById('waf-max-body').value) || 10;
        var data = {
            enabled: document.getElementById('waf-enabled').checked,
            enableIpCheck: document.getElementById('waf-ip-check').checked,
            ipWhitelist: this._textToList(document.getElementById('waf-whitelist').value),
            ipBlacklist: this._textToList(document.getElementById('waf-blacklist').value),
            enableRequestSizeValidation: true,
            maxRequestBodySize: mbVal * 1024 * 1024,
            maxHeaderCount: parseInt(document.getElementById('waf-max-headers').value) || 64,
            maxHeaderSize: parseInt(document.getElementById('waf-max-header-size').value) || 8192,
            enableSqlInjectionDetection: document.getElementById('waf-sqli').checked,
            enableXssDetection: document.getElementById('waf-xss').checked,
            enablePathTraversalDetection: document.getElementById('waf-path').checked
        };

        var btn = document.querySelector('[onclick="DashboardWafSettings.save()"]');
        if (btn) { btn.disabled = true; var sp = btn.querySelector('span'); if (sp) sp.textContent = __('waf.saving'); }

        try {
            await DashboardApi.endpoints.saveWafSettings(data);
            this._data = data;
            if (window.DashboardModals) DashboardModals.showToast(__('waf.saved'), 'success');
        } catch (e) {
            console.error('[WafSettings] Save failed:', e);
            if (window.DashboardModals) DashboardModals.showError(__('waf.saveFailed'));
        } finally {
            if (btn) { btn.disabled = false; var sp = btn.querySelector('span'); if (sp) sp.textContent = __('waf.save'); }
        }
    },

    _textToList: function(text) {
        if (!text) return [];
        return text.split('\n').map(function(l) { return l.trim(); }).filter(function(l) { return l.length > 0; });
    },

    // --- Security Event Panel ---
    _recentEvents: [],
    _topIps: {},
    _refreshTimer: null,

    _eventTypeLabels: {
        SqlInjectionBlocked: { label: 'SQLi', cls: 'bg-danger', icon: 'bi-database' },
        SqlInjectionValueBlocked: { label: 'SQLi', cls: 'bg-danger', icon: 'bi-database' },
        XssBlocked: { label: 'XSS', cls: 'bg-warning text-dark', icon: 'bi-code-slash' },
        PathTraversalBlocked: { label: 'PathTrav', cls: 'bg-info', icon: 'bi-folder2-open' },
        PathTraversalInQueryBlocked: { label: 'PathTrav', cls: 'bg-info', icon: 'bi-folder2-open' },
        IpBlocked: { label: 'IP Block', cls: 'bg-dark', icon: 'bi-geo-alt' },
        RequestSizeBlocked: { label: 'Size', cls: 'bg-secondary', icon: 'bi-file-earmark' },
        MalformedHeadersBlocked: { label: 'Headers', cls: 'bg-secondary', icon: 'bi-card-heading' },
        UriTooLongBlocked: { label: 'URI', cls: 'bg-secondary', icon: 'bi-link-45deg' }
    },

    _getTypeInfo: function(eventType) {
        return this._eventTypeLabels[eventType] || { label: eventType, cls: 'bg-secondary', icon: 'bi-shield' };
    },

    _startAutoRefresh: function() {
        this._stopAutoRefresh();
        var self = this;
        this._refreshTimer = setInterval(function() { self._refreshEvents(); }, 10000);
    },

    _stopAutoRefresh: function() {
        if (this._refreshTimer) { clearInterval(this._refreshTimer); this._refreshTimer = null; }
    },

    _refreshEvents: async function() {
        try {
            var results = await Promise.all([
                DashboardApi.endpoints.getSecurityEventSummary(),
                DashboardApi.endpoints.getSecurityEvents(20)
            ]);
            var summary = results[0];
            var eventsResult = results[1] || {};
            if (summary) {
                this._eventCounts = summary.typeCounts || {};
                this._topIps = summary.topIps || {};
            }
            this._recentEvents = eventsResult.entries || [];
            this._updateEventPanel();
            this._renderFlowSteps();
            this._renderRuleCards();
        } catch (e) { /* Silently refresh */ }
    },

    _updateEventPanel: function() {
        this._renderEventTotal();
        this._renderTopIps();
        var container = document.getElementById('waf-recent-events');
        if (!container) return;
        var events = this._recentEvents || [];
        if (events.length === 0) {
            container.innerHTML = '<div class="waf-empty"><i class="bi bi-shield-check me-1"></i><span data-i18n="waf.noRecentEvents">暂无安全事件，发动一次模拟攻击试试</span></div>';
            return;
        }
        var html = '';
        var showCount = Math.min(events.length, 10);
        for (var i = 0; i < showCount; i++) {
            var ev = events[i];
            var ti = this._getTypeInfo(ev.eventType);
            var timeStr = this._fmtRelTime(ev.timestamp);
            html +=
                '<div class="waf-ev">' +
                    '<span class="ev-time" title="' + this._eH(ev.timestamp) + '">' + timeStr + '</span>' +
                    '<span class="ev-type"><span class="badge ' + ti.cls + '" style="font-size:10px;">' + ti.label + '</span></span>' +
                    '<span class="ev-ip"><i class="bi bi-geo-alt" style="font-size:9px;color:#9ca3af;margin-right:3px;"></i>' + this._eH(ev.clientIp) + '</span>' +
                    '<span class="ev-target"><code>' + this._eH(ev.requestMethod || 'GET') + ' ' + this._eH(this._truncate(ev.requestUri, 50)) + '</code></span>' +
                '</div>';
        }
        container.innerHTML = html;
    },

    _renderTopIps: function() {
        var container = document.getElementById('waf-top-ips');
        if (!container) return;
        var ips = this._topIps || {};
        var keys = Object.keys(ips);
        if (keys.length === 0) {
            container.innerHTML = '<div class="waf-empty"><i class="bi bi-info-circle me-1"></i><span data-i18n="waf.noIpData">暂无数据</span></div>';
            return;
        }
        var maxCount = ips[keys[0]] || 1;
        var html = '';
        var showKeys = keys.slice(0, 8);
        for (var i = 0; i < showKeys.length; i++) {
            var ip = showKeys[i];
            var cnt = ips[ip];
            var pct = Math.min(100, (cnt / maxCount) * 100);
            html +=
                '<div class="waf-ipbar">' +
                    '<span class="ip-addr"><i class="bi bi-geo-alt" style="font-size:9px;color:#9ca3af;margin-right:3px;"></i>' + this._eH(ip) + '</span>' +
                    '<div class="ip-track"><div class="ip-fill" style="width:' + pct + '%"></div></div>' +
                    '<span class="ip-cnt">' + cnt + '</span>' +
                '</div>';
        }
        container.innerHTML = html;
    },

    _renderEventTotal: function() {
        var badge = document.getElementById('waf-event-badge');
        var refreshTime = document.getElementById('waf-event-refresh-time');
        if (badge) {
            var total = 0;
            var counts = this._eventCounts || {};
            var keys = Object.keys(counts);
            for (var k = 0; k < keys.length; k++) total += counts[keys[k]] || 0;
            if (total > 0) {
                badge.textContent = total + ' total';
                badge.style.display = 'inline-block';
            } else {
                badge.style.display = 'none';
            }
        }
        if (refreshTime) {
            refreshTime.textContent = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
    },

    _fmtRelTime: function(timestamp) {
        if (!timestamp) return '-';
        var diff = Math.floor((Date.now() - new Date(timestamp).getTime()) / 1000);
        if (diff < 5) return '\u521a\u521a';
        if (diff < 60) return diff + 's';
        if (diff < 3600) return Math.floor(diff / 60) + 'm';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h';
        return Math.floor(diff / 86400) + 'd';
    },

    _eH: function(str) {
        if (typeof str !== 'string') return str || '';
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    },

    _truncate: function(str, maxLen) {
        if (!str) return '';
        return str.length <= maxLen ? str : str.substring(0, maxLen) + '...';
    },

    _bindEventButtons: function() {
        var btn = document.getElementById('waf-test-event-btn');
        if (btn) {
            btn.addEventListener('click', function() { DashboardWafSettings._fireTestEvent(); });
        }
    },

    _fireTestEvent: async function() {
        var types = ['SqlInjection', 'Xss', 'PathTraversal'];
        var uris = ['/api/users?id=1%27%20UNION%20SELECT%20*%20FROM%20users--', '/search?q=%3Cscript%3Ealert(1)%3C/script%3E', '/../../../etc/passwd'];
        var methods = ['GET', 'GET', 'GET'];
        var matchedValues = ["1' UNION SELECT * FROM users--", '<scr' + 'ipt>alert(1)<' + '/scr' + 'ipt>', '../../../etc/passwd'];
        var idx = Math.floor(Math.random() * types.length);
        var btn = document.getElementById('waf-test-event-btn');
        if (btn) btn.disabled = true;
        try {
            var payload = {
                clientIp: '192.168.' + Math.floor(Math.random() * 255) + '.' + Math.floor(Math.random() * 255),
                eventType: types[idx],
                uri: uris[idx],
                method: methods[idx],
                matchedValue: matchedValues[idx]
            };
            await DashboardApi.post('/api/security-events/test', payload);
            await this._refreshEvents();
            if (window.DashboardModals) DashboardModals.showToast(__('waf.eventGenerated'), 'success');
        } catch (e) {
            console.error('[WafSettings] Test event failed:', e);
        } finally {
            if (btn) btn.disabled = false;
        }
    }
};
</script>

@await Html.PartialAsync("_DashboardPageInit")

<script>
    (async function() {
        if (window.DashboardUtils) DashboardUtils.init();
        if (window.DashboardApi) DashboardApi.init();
        if (window.DashboardState) DashboardState.init();
        if (window.DashboardI18n) DashboardI18n.init();
        if (window.DashboardStorage) DashboardStorage.init();
        if (window.DashboardModals) DashboardModals.init();
        if (window.DashboardEvents) DashboardEvents.setup();

        document.dispatchEvent(new CustomEvent('dashboard:ready'));

        try { await DashboardWafSettings.init(); } catch (e) { console.error('[Waf] Load failed:', e); }
    })();
</script>
}
