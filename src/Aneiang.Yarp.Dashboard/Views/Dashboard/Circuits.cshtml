@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Circuit Breaker" : "熔断状态";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div id="circuits-app">
    <div class="card-panel mb-4">
        <div class="card-header">
            <span><i class="bi bi-lightning-charge me-2" style="color:#f59e0b;"></i><span data-i18n="circuit.title">熔断状态</span></span>
            <div>
                <span id="circuit-refresh-time" class="refresh-badge"></span>
                <button class="btn btn-sm btn-outline-primary" onclick="CircuitModule.load()" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger" onclick="CircuitModule.resetAll()" title="重置">
                    <i class="bi bi-x-circle"></i> <span data-i18n="circuit.reset">全部重置</span>
                </button>
            </div>
        </div>
        <div id="circuit-content" class="card-body">
            <div class="loading-state">
                <div class="loading-spinner"></div>
                <div class="loading-text" data-i18n="circuit.loading">加载中...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@{ var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString(); }
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-circuits.js?v=@v"></script>

<script>
    window.__dashboard = window.__dashboard || {};
    var dash = window.__dashboard;
    dash.basePath = '/' + '@ViewBag.DashboardRoutePrefix';
    dash.token = localStorage.getItem('dashboard_token');
    dash.CURRENT_LOCALE = '@ViewBag.Locale';
    dash.I18N = @Html.Raw(ViewBag.AllI18nJson ?? "{}");
    dash.currentPage = '@ViewBag.CurrentPage';
</script>

<script>
    (async function() {
        if (window.DashboardUtils) DashboardUtils.init();
        if (window.DashboardApi) DashboardApi.init();
        if (window.DashboardState) DashboardState.init();
        if (window.DashboardI18n) DashboardI18n.init();
        if (window.DashboardStorage) DashboardStorage.init();
        if (window.DashboardModals) DashboardModals.init();
        if (window.DashboardEvents) DashboardEvents.setup();
        if (window.DashboardApp && window.DashboardApp.modules && window.DashboardApp.modules.circuit) {
            await DashboardApp.modules.circuit.init();
        }
        await CircuitModule.load();
        document.dispatchEvent(new CustomEvent('dashboard:ready'));
    })();
</script>
}
