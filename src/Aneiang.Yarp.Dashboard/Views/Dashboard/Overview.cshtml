@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Overview" : "总览";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var prefix = ViewBag.DashboardRoutePrefix as string ?? "apigateway";
}

<!-- Alert Summary Bar - 运维告警摘要 -->
<div id="alert-summary-bar" class="row g-3 mb-3">
    <div class="col-md-3 col-sm-6">
        <div class="stat-card" style="border-left: 4px solid #ef4444;">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="alert-unhealthy" style="color:#ef4444;">-</div>
                    <div class="stat-label" data-i18n="overview.alert.unhealthy">异常节点</div>
                </div>
                <div class="stat-icon" style="background:#fef2f2;color:#ef4444;"><i class="bi bi-heartbreak"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card" style="border-left: 4px solid #f59e0b;">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="alert-circuit" style="color:#f59e0b;">-</div>
                    <div class="stat-label" data-i18n="overview.alert.circuit">熔断中</div>
                </div>
                <div class="stat-icon" style="background:#fffbeb;color:#f59e0b;"><i class="bi bi-lightning-slash"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card" style="border-left: 4px solid #3b82f6;">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="alert-rate-limit">-</div>
                    <div class="stat-label" data-i18n="overview.alert.rateLimit">限流触发</div>
                </div>
                <div class="stat-icon" style="background:#eff6ff;color:#3b82f6;"><i class="bi bi-speedometer2"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card" style="border-left: 4px solid #8b5cf6;">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="alert-events">-</div>
                    <div class="stat-label" data-i18n="overview.alert.events">未处理事件</div>
                </div>
                <div class="stat-icon" style="background:#f5f3ff;color:#8b5cf6;"><i class="bi bi-bell"></i></div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions Bar - 快捷运维操作 -->
<div class="card-panel mb-3">
    <div class="card-body py-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small"><i class="bi bi-lightning-charge me-1"></i><span data-i18n="overview.quickActions.title">快捷操作</span></span>
            </div>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <button class="btn btn-sm btn-outline-danger" onclick="OpsModule.emergencyDisable()">
                    <i class="bi bi-shield-exclamation"></i> <span data-i18n="overview.quickActions.emergency">紧急禁用</span>
                </button>
                <button class="btn btn-sm btn-outline-success" onclick="OpsModule.emergencyEnable()">
                    <i class="bi bi-shield-check"></i> <span data-i18n="overview.quickActions.emergencyEnable">紧急启用</span>
                </button>
                <button class="btn btn-sm btn-outline-warning" onclick="OpsModule.refreshHealth()">
                    <i class="bi bi-arrow-clockwise"></i> <span data-i18n="overview.quickActions.health">刷新健康</span>
                </button>
                <button class="btn btn-sm btn-outline-primary" onclick="OpsModule.exportSnapshot()">
                    <i class="bi bi-download"></i> <span data-i18n="overview.quickActions.export">导出快照</span>
                </button>
                <button class="btn btn-sm btn-outline-secondary" onclick="overviewRefresh(this)">
                    <i class="bi bi-arrow-repeat"></i> <span data-i18n="overview.quickActions.refresh">刷新全部</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Stat cards -->
<div id="stat-bar" class="row g-3 mb-3">
    <div class="col-12">
        <div class="info-bar">
            <div class="info-bar-content">
                <span><i class="bi bi-cpu"></i><span data-i18n="index.label.version">版本：</span><strong id="info-version">-</strong></span>
                <span><i class="bi bi-cloud"></i><span data-i18n="index.label.env">环境：</span><strong id="info-env">-</strong></span>
                <span><i class="bi bi-play-circle"></i><span data-i18n="index.label.start">启动：</span><strong id="info-start">-</strong></span>
                <span><i class="bi bi-clock-history"></i><span data-i18n="index.label.uptime">运行：</span><strong id="info-uptime">-</strong></span>
                <span><i class="bi bi-memory"></i><span data-i18n="index.label.memory">内存：</span><strong id="info-memory">-</strong></span>
                <span><i class="bi bi-pc-display"></i><span data-i18n="index.label.host">主机：</span><strong id="info-machine">-</strong></span>
            </div>
            <div class="info-bar-actions">
                <button class="btn btn-icon btn-outline-primary" onclick="overviewRefresh(this)" data-i18n-title="index.btn.refresh" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-clusters">-</div>
                    <div class="stat-label" data-i18n="index.stat.clusters">服务集群</div>
                </div>
                <a href="/@prefix/clusters" class="stat-icon text-decoration-none" style="background:#eff6ff;color:#3b82f6;"><i class="bi bi-diagram-3"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-healthy" style="color:#22c55e;">-</div>
                    <div class="stat-label" data-i18n="index.stat.health">健康 / 未知 / 异常</div>
                </div>
                <div class="stat-icon" style="background:#f0fdf4;color:#22c55e;"><i class="bi bi-heart-pulse"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="stat-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value" id="stat-routes">-</div>
                    <div class="stat-label" data-i18n="index.stat.routes">路由规则</div>
                </div>
                <a href="/@prefix/routes" class="stat-icon text-decoration-none" style="background:#fefce8;color:#eab308;"><i class="bi bi-signpost-split"></i></a>
            </div>
        </div>
    </div>
</div>

<!-- Real-time Traffic Chart - 实时流量图 -->
<div class="card-panel mb-3">
    <div class="card-header">
        <span><i class="bi bi-graph-up-arrow me-2"></i><span data-i18n="overview.chart.traffic">实时流量趋势 (QPS)</span></span>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-success" id="current-qps">0 req/s</span>
            <select class="form-select form-select-sm" id="chart-time-range" style="width:100px;" onchange="OpsModule.changeTimeRange(this.value)">
                <option value="5">5分钟</option>
                <option value="15" selected>15分钟</option>
                <option value="60">1小时</option>
            </select>
        </div>
    </div>
    <div class="card-body">
        <div style="height:250px;position:relative;">
            <canvas id="traffic-chart"></canvas>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <!-- Top Error Routes - 异常路由排行 -->
    <div class="col-md-6">
        <div class="card-panel">
            <div class="card-header">
                <span><i class="bi bi-exclamation-triangle me-2"></i><span data-i18n="overview.top.errorRoutes">Top 异常路由</span></span>
                <span class="badge bg-danger" id="error-routes-count">0</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                        <thead>
                            <tr>
                                <th style="width:50%;padding:10px 16px;"><span data-i18n="overview.top.th.route">路由</span></th>
                                <th style="width:25%;padding:10px 16px;"><span data-i18n="overview.top.th.errors">错误数</span></th>
                                <th style="width:25%;padding:10px 16px;"><span data-i18n="overview.top.th.rate">错误率</span></th>
                            </tr>
                        </thead>
                        <tbody id="error-routes-tbody">
                            <tr><td colspan="3" class="text-center text-muted py-4" data-i18n="overview.top.empty">暂无数据</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Top Latency Clusters - 高延迟集群排行 -->
    <div class="col-md-6">
        <div class="card-panel">
            <div class="card-header">
                <span><i class="bi bi-stopwatch me-2"></i><span data-i18n="overview.top.slowClusters">Top 延迟集群</span></span>
                <span class="badge bg-warning" id="slow-clusters-count">0</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                        <thead>
                            <tr>
                                <th style="width:50%;padding:10px 16px;"><span data-i18n="overview.top.th.cluster">集群</span></th>
                                <th style="width:25%;padding:10px 16px;"><span data-i18n="overview.top.th.avgLatency">平均延迟</span></th>
                                <th style="width:25%;padding:10px 16px;"><span data-i18n="overview.top.th.p99">P99延迟</span></th>
                            </tr>
                        </thead>
                        <tbody id="slow-clusters-tbody">
                            <tr><td colspan="3" class="text-center text-muted py-4" data-i18n="overview.top.empty">暂无数据</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Cluster preview -->
<div id="cluster-preview-panel" class="card-panel mb-3">
    <div class="card-header">
        <span><i class="bi bi-hdd-stack me-2"></i><span data-i18n="index.cluster.title">服务集群概览</span></span>
        <a href="/@prefix/clusters" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-arrow-right"></i> <span data-i18n="home.viewAll">查看全部</span>
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle" style="table-layout:fixed;width:100%">
            <thead>
                <tr>
                    <th style="width:50%"><span data-i18n="index.cluster.th.name">集群名称</span></th>
                    <th style="width:50%"><span data-i18n="index.cluster.th.health">健康状态</span></th>
                </tr>
            </thead>
            <tbody id="cluster-preview-tbody">
                <tr><td colspan="2" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Route preview -->
<div id="route-preview-panel" class="card-panel mb-3">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2"></i><span data-i18n="index.route.title">路由规则概览</span></span>
        <a href="/@prefix/routes" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-arrow-right"></i> <span data-i18n="home.viewAll">查看全部</span>
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle" style="table-layout:fixed;width:100%">
            <thead>
                <tr>
                    <th style="width:50%"><span data-i18n="index.route.th.name">路由名称</span></th>
                    <th style="width:50%"><span data-i18n="index.route.th.cluster">关联集群</span></th>
                </tr>
            </thead>
            <tbody id="route-preview-tbody">
                <tr><td colspan="2" class="text-center text-muted py-4" data-i18n="index.loading">加载中...</td></tr>
            </tbody>
        </table>
    </div>
</div>

