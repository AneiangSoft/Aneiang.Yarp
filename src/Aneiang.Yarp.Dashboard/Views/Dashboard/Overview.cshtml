@{
    ViewData["Title"] = ((ViewBag.Locale as string) == "en-US") ? "Overview" : "总览";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var prefix = ViewBag.DashboardRoutePrefix as string ?? "apigateway";
}

<!-- Stat cards -->
<div id="stat-bar" class="row g-3 mb-3">
    <div class="col-12">
        <div class="info-bar">
            <div class="info-bar-content">
                <span><i class="bi bi-cpu"></i><span data-i18n="index.label.version">版本：</span><strong id="info-version">-</strong></span>
                <span><i class="bi bi-cloud"></i><span data-i18n="index.label.env">环境：</span><strong id="info-env">-</strong></span>
                <span><i class="bi bi-play-circle"></i><span data-i18n="index.label.start">启动：</span><strong id="info-start">-</strong></span>
                <span><i class="bi bi-clock-history"></i><span data-i18n="index.label.uptime">运行：</span><strong id="info-uptime">-</strong></span>
                <span><i class="bi bi-memory"></i><span data-i18n="index.label.memory">内存：</span><strong id="info-memory">-</strong></span>
                <span><i class="bi bi-pc-display"></i><span data-i18n="index.label.host">主机：</span><strong id="info-machine">-</strong></span>
            </div>
            <div class="info-bar-actions card-header-actions">
                <span id="signalr-status" class="signalr-indicator signalr-off" title="SignalR 断开">
                    <span class="signalr-dot"></span>
                </span>
                <button class="btn btn-sm btn-outline-secondary btn-icon-only" onclick="overviewRefresh(this)" data-i18n-title="index.btn.refresh" title="刷新">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="stat-card stat-card--blue" style="border-left: 3px solid #3b82f6;">
            <div class="d-flex align-items-center gap-3">
                <a href="/@prefix/clusters" class="stat-card__icon text-decoration-none"><i class="bi bi-diagram-3"></i></a>
                <div class="stat-card__body">
                    <div class="stat-card__value stat-value-animated" id="stat-clusters">-</div>
                    <div class="stat-card__label" data-i18n="index.stat.clusters">服务集群</div>
                    <div class="stat-card__trend"><span class="stat-trend neutral" id="trend-clusters"><i class="bi bi-dash"></i> --</span></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="stat-card stat-card--green" style="border-left: 3px solid #22c55e;">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-card__icon"><i class="bi bi-heart-pulse"></i></div>
                <div class="stat-card__body">
                    <div class="stat-card__value stat-value-animated" id="stat-healthy" style="color:#22c55e;">-</div>
                    <div class="stat-card__label" data-i18n="index.stat.health">健康状态</div>
                    <div class="stat-card__trend">
                        <span style="color:#22c55e;"><span class="health-dot">●</span> <span id="stat-healthy-count">0</span></span>
                        <span style="color:#f59e0b;margin-left:8px;"><span class="health-dot">●</span> <span id="stat-unknown-count">0</span></span>
                        <span style="color:#ef4444;margin-left:8px;"><span class="health-dot">●</span> <span id="stat-unhealthy-count">0</span></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="stat-card stat-card--amber" style="border-left: 3px solid #f59e0b;">
            <div class="d-flex align-items-center gap-3">
                <a href="/@prefix/routes" class="stat-card__icon text-decoration-none"><i class="bi bi-signpost-split"></i></a>
                <div class="stat-card__body">
                    <div class="stat-card__value stat-value-animated" id="stat-routes">-</div>
                    <div class="stat-card__label" data-i18n="index.stat.routes">路由规则</div>
                    <div class="stat-card__trend"><span class="stat-trend neutral" id="trend-routes"><i class="bi bi-dash"></i> --</span></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="stat-card stat-card--purple" style="border-left: 3px solid #8b5cf6;">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-card__icon"><i class="bi bi-lightning-charge"></i></div>
                <div class="stat-card__body">
                    <div class="stat-card__value stat-value-animated" id="stat-qps">-</div>
                    <div class="stat-card__label" data-i18n="overview.stat.qps">当前 QPS</div>
                    <div class="stat-card__trend"><span class="stat-trend neutral" id="trend-qps"><i class="bi bi-dash"></i> --</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Config Health Score Card -->
<div class="row g-3 mb-3">
    <div class="col-12">
        <div id="config-health-card"></div>
    </div>
</div>

<!-- System Health Panel -->
<div class="card-panel mb-4">
    <div class="card-header">
        <span><i class="bi bi-activity me-2" style="color:#10b981;"></i><span data-i18n="overview.systemHealth">系统健康</span></span>
        <div class="card-header-actions">
            <span class="badge bg-success" id="sys-health-status" data-i18n="overview.healthy">健康</span>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3 col-sm-6">
                <div class="border rounded-3 p-3 h-100" style="background:#f8fafc;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-database text-primary"></i>
                        <span class="fw-semibold small" data-i18n="overview.dbStatus">数据库</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="health-dot healthy"></span>
                        <span class="small text-muted" id="sys-db-status" data-i18n="overview.connected">已连接</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="border rounded-3 p-3 h-100" style="background:#f8fafc;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-cpu text-warning"></i>
                        <span class="fw-semibold small" data-i18n="overview.cpuUsage">CPU 使用率</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height:6px;">
                            <div class="progress-bar bg-warning" id="sys-cpu-bar" style="width:0%"></div>
                        </div>
                        <span class="small text-muted" id="sys-cpu-value">--</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="border rounded-3 p-3 h-100" style="background:#f8fafc;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-memory text-info"></i>
                        <span class="fw-semibold small" data-i18n="overview.memUsage">内存使用</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height:6px;">
                            <div class="progress-bar bg-info" id="sys-mem-bar" style="width:0%"></div>
                        </div>
                        <span class="small text-muted" id="sys-mem-value">--</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="border rounded-3 p-3 h-100" style="background:#f8fafc;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-hdd-network text-success"></i>
                        <span class="fw-semibold small" data-i18n="overview.gcCount">GC 次数</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="small text-muted" id="sys-gc-value">--</span>
                        <span class="small text-muted" data-i18n="overview.threadCount">线程</span>
                        <span class="small text-muted" id="sys-thread-value">--</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Real-time Traffic Chart - 实时流量图 -->
<div class="card-panel mb-4">
    <div class="card-header">
        <span><i class="bi bi-graph-up-arrow me-2"></i><span data-i18n="overview.chart.traffic">实时流量趋势 (QPS)</span></span>
        <div class="card-header-actions">
            <span class="pulse-dot me-1"></span>
            <span class="badge bg-success" id="current-qps">0 req/s</span>
            <select class="form-select form-select-sm" id="chart-time-range" style="width:110px;" onchange="OpsModule.changeTimeRange(this.value)">
                <option value="5" data-i18n="overview.chart.timeRange.5min">5分钟</option>
                <option value="15" selected data-i18n="overview.chart.timeRange.15min">15分钟</option>
                <option value="60" data-i18n="overview.chart.timeRange.1hour">1小时</option>
            </select>
        </div>
    </div>
    <div class="card-body">
        <div style="height:260px;position:relative;">
            <canvas id="traffic-chart"></canvas>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Top Error Routes - 异常路由排行 -->
    <div class="col-md-6">
        <div class="card-panel h-100">
            <div class="card-header">
                <span><i class="bi bi-exclamation-triangle me-2" style="color:#ef4444;"></i><span data-i18n="overview.top.errorRoutes">Top 异常路由</span></span>
                <span class="badge bg-danger" id="error-routes-count">0</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped-custom align-middle mb-0" style="font-size:13px;">
                        <thead>
                            <tr>
                                <th style="width:50%;padding:10px 16px;"><span data-i18n="overview.top.th.route">路由</span></th>
                                <th style="width:25%;padding:10px 16px;"><span data-i18n="overview.top.th.errors">错误数</span></th>
                                <th style="width:25%;padding:10px 16px;"><span data-i18n="overview.top.th.rate">错误率</span></th>
                            </tr>
                        </thead>
                        <tbody id="error-routes-tbody">
                            <tr><td colspan="3" class="text-center py-4"><div class="empty-state"><div class="empty-state-icon"><i class="bi bi-shield-check"></i></div><div class="empty-state-title" data-i18n="overview.top.empty">暂无数据</div><div class="empty-state-desc" data-i18n="overview.top.emptyDesc">一切正常，没有异常路由</div></div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Top Latency Clusters - 高延迟集群排行 -->
    <div class="col-md-6">
        <div class="card-panel h-100">
            <div class="card-header">
                <span><i class="bi bi-stopwatch me-2" style="color:#f59e0b;"></i><span data-i18n="overview.top.slowClusters">Top 延迟集群</span></span>
                <span class="badge bg-warning text-dark" id="slow-clusters-count">0</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped-custom align-middle mb-0" style="font-size:13px;">
                        <thead>
                            <tr>
                                <th style="width:50%;padding:10px 16px;"><span data-i18n="overview.top.th.cluster">集群</span></th>
                                <th style="width:25%;padding:10px 16px;"><span data-i18n="overview.top.th.avgLatency">平均延迟</span></th>
                                <th style="width:25%;padding:10px 16px;"><span data-i18n="overview.top.th.p99">P99延迟</span></th>
                            </tr>
                        </thead>
                        <tbody id="slow-clusters-tbody">
                            <tr><td colspan="3" class="text-center py-4"><div class="empty-state"><div class="empty-state-icon"><i class="bi bi-speedometer2"></i></div><div class="empty-state-title" data-i18n="overview.top.empty">暂无数据</div><div class="empty-state-desc" data-i18n="overview.top.latencyEmptyDesc">延迟数据采集中</div></div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Cluster preview -->
<div id="cluster-preview-panel" class="card-panel mb-4">
    <div class="card-header">
        <span><i class="bi bi-hdd-stack me-2" style="color:#3b82f6;"></i><span data-i18n="index.cluster.title">服务集群概览</span></span>
        <a href="/@prefix/clusters" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-arrow-right"></i> <span data-i18n="home.viewAll">查看全部</span>
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-striped-custom align-middle" style="table-layout:fixed;width:100%">
            <thead>
                <tr>
                    <th style="width:50%"><span data-i18n="index.cluster.th.name">集群名称</span></th>
                    <th style="width:50%"><span data-i18n="index.cluster.th.health">健康状态</span></th>
                </tr>
            </thead>
            <tbody id="cluster-preview-tbody">
                <tr><td colspan="2" class="text-center py-4">
                    <div style="padding:8px 16px;">
                        <div class="skeleton skeleton-line medium"></div>
                        <div class="skeleton skeleton-line short"></div>
                        <div class="skeleton skeleton-line long"></div>
                    </div>
                </td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Route preview -->
<div id="route-preview-panel" class="card-panel mb-4">
    <div class="card-header">
        <span><i class="bi bi-signpost-split me-2" style="color:#eab308;"></i><span data-i18n="index.route.title">路由规则概览</span></span>
        <a href="/@prefix/routes" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-arrow-right"></i> <span data-i18n="home.viewAll">查看全部</span>
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-striped-custom align-middle" style="table-layout:fixed;width:100%">
            <thead>
                <tr>
                    <th style="width:50%"><span data-i18n="index.route.th.name">路由名称</span></th>
                    <th style="width:50%"><span data-i18n="index.route.th.cluster">关联集群</span></th>
                </tr>
            </thead>
            <tbody id="route-preview-tbody">
                <tr><td colspan="2" class="text-center py-4">
                    <div style="padding:8px 16px;">
                        <div class="skeleton skeleton-line medium"></div>
                        <div class="skeleton skeleton-line short"></div>
                        <div class="skeleton skeleton-line long"></div>
                    </div>
                </td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<!-- Page config (shared scripts now in _DashboardLayout.cshtml) -->
@await Html.PartialAsync("_DashboardPageInit")

<!-- Chart.js for traffic chart -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/vendor/chart.umd.min.js"></script>
<!-- SignalR client for real-time overview push -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/vendor/signalr.min.js"></script>

<!-- Home module (for stat bar — version, clusters, routes, QPS) -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-home.js"></script>
<!-- Operations module (for overview charts) -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-operations.js"></script>
<!-- Config Health Score -->
<script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-health-score.js"></script>

<script>
    var _signalrConnected = false;
    var _signalrConnection = null;
    var _pollingFallbackId = null;
    var _prefix = '@(prefix)';

    (async function() {
        try {
            if (window.DashboardApi) DashboardApi.init();

            // Init modules
            if (window.DashboardApp?.modules?.home?.init) await DashboardApp.modules.home.init();
            if (window.DashboardApp?.modules?.stats?.init) await DashboardApp.modules.stats.init();
            if (window.OpsModule?.init) await OpsModule.init();

            // Direct API calls as primary path (most reliable)
            try {
                const [info, clusters, routes, traffic] = await Promise.all([
                    DashboardApi.endpoints.getInfo().catch(() => null),
                    DashboardApi.endpoints.getClusters().catch(() => []),
                    DashboardApi.endpoints.getRoutes().catch(() => []),
                    (window.DashboardApi.endpoints.getTrafficData?.(15) || Promise.resolve(null)).catch(() => null)
                ]);

                // Render info bar
                if (info) {
                    const set = (id, val) => { const el = document.getElementById(id); if (el && val != null) el.textContent = val; };
                    set('info-version', info.version);
                    set('info-env', info.environment);
                    set('info-start', info.startTime);
                    set('info-uptime', info.uptime);
                    set('info-memory', info.memoryMb != null ? info.memoryMb.toFixed(1) + ' MB' : null);
                    set('info-machine', info.machineName);

                    // Store in state
                    if (window.DashboardState) {
                        DashboardState.set('data.info', info);
                        DashboardState.set('data.clusters', clusters || []);
                        DashboardState.set('data.routes', routes || []);
                    }
                }

                // Render stat cards
                const setText = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
                setText('stat-clusters', (clusters || []).length);
                const healthy = (clusters || []).reduce((s, c) => s + (c.healthyCount || 0), 0);
                const unknown = (clusters || []).reduce((s, c) => s + (c.unknownCount || 0), 0);
                const unhealthy = (clusters || []).reduce((s, c) => s + (c.unhealthyCount || 0), 0);
                setText('stat-healthy', healthy + ' / ' + unknown + ' / ' + unhealthy);
                setText('stat-routes', (routes || []).length);
                if (traffic && traffic.currentQps != null) {
                    setText('stat-qps', traffic.currentQps);
                }
            } catch (e) {
                console.error('[Overview] Direct API failed:', e);
            }

            // Load additional overview charts
            if (window.DashboardApp?.modules?.home?.loadInfo) await DashboardApp.modules.home.loadInfo();
            if (window.DashboardApp?.modules?.stats?.loadStats) await DashboardApp.modules.stats.loadStats();
            if (window.OpsModule?.loadAlertSummary) await OpsModule.loadAlertSummary();
            if (window.OpsModule?.loadTrafficChart) await OpsModule.loadTrafficChart();
            if (window.OpsModule?.loadTopErrors) await OpsModule.loadTopErrors();
            if (window.OpsModule?.loadSystemHealth) await OpsModule.loadSystemHealth();

            // Start periodic chart updates (every 10s)
            if (window.OpsModule?.startAutoRefresh) OpsModule.startAutoRefresh();

            document.dispatchEvent(new CustomEvent('dashboard:ready'));

            // --- SignalR real-time push ---
            initSignalR();
        } catch (err) {
            console.error('[Overview] Init failed:', err);
        }
    })();

    /**
     * Initialize SignalR connection for real-time overview updates.
     * Falls back to HTTP polling if SignalR is unavailable.
     */
    function initSignalR() {
        if (!window.signalR) {
            console.warn('[Overview] SignalR client not loaded, starting polling fallback');
            startPollingFallback();
            return;
        }

        var hubUrl = '/' + _prefix + '/hubs/overview';
        var connection = new signalR.HubConnectionBuilder()
            .withUrl(hubUrl)
            .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
            .build();

        _signalrConnection = connection;

        connection.on('OverviewUpdate', function(snapshot) {
            if (snapshot) updateOverviewFromSnapshot(snapshot);
        });

        connection.onreconnected(function() {
            console.log('[Overview] SignalR reconnected');
            setSignalRStatus(true);
            stopPollingFallback();
        });

        connection.onreconnecting(function() {
            console.warn('[Overview] SignalR reconnecting...');
            setSignalRStatus(false);
            startPollingFallback();
        });

        connection.onclose(function() {
            console.warn('[Overview] SignalR closed');
            setSignalRStatus(false);
            startPollingFallback();
        });

        connection.start()
            .then(function() {
                console.log('[Overview] SignalR connected to', hubUrl);
                setSignalRStatus(true);
                stopPollingFallback();
            })
            .catch(function(err) {
                console.warn('[Overview] SignalR unavailable, falling back to polling:', err.message);
                setSignalRStatus(false);
                startPollingFallback();
            });
    }

    function setSignalRStatus(connected) {
        _signalrConnected = connected;
        var el = document.getElementById('signalr-status');
        if (!el) return;
        el.classList.remove('signalr-on', 'signalr-off');
        el.classList.add(connected ? 'signalr-on' : 'signalr-off');
        el.title = connected ? 'SignalR 实时连接' : 'SignalR 断开，轮询中';
    }

    /**
     * Update all overview DOM elements from a server-pushed snapshot.
     */
    function updateOverviewFromSnapshot(s) {
        var setText = function(id, val) { var el = document.getElementById(id); if (el) el.textContent = val; };

        // Stat cards
        setText('stat-clusters', s.clusterCount);
        setText('stat-healthy', s.healthyCount + ' / ' + s.unknownCount + ' / ' + s.unhealthyCount);
        setText('stat-routes', s.routeCount);
        if (s.currentQps != null) setText('stat-qps', s.currentQps);

        // QPS badge in chart header
        var qpsBadge = document.getElementById('current-qps');
        if (qpsBadge && s.currentQps != null) qpsBadge.textContent = s.currentQps + ' req/s';

        // System health panel
        if (s.cpuUsage != null) {
            setText('sys-cpu-value', s.cpuUsage + '%');
            var cpuBar = document.getElementById('sys-cpu-bar');
            if (cpuBar) cpuBar.style.width = Math.min(100, s.cpuUsage) + '%';
        }
        if (s.memoryMb != null) {
            setText('sys-mem-value', s.memoryMb + ' MB');
            var memBar = document.getElementById('sys-mem-bar');
            if (memBar) memBar.style.width = Math.min(100, Math.round(s.memoryMb / 80)) + '%';
        }
        if (s.gcCount != null) setText('sys-gc-value', s.gcCount);
        if (s.threadCount != null) setText('sys-thread-value', s.threadCount);

        // System health status badge
        var healthBadge = document.getElementById('sys-health-status');
        if (healthBadge) {
            var hasIssue = s.unhealthyCount > 0 || s.cpuUsage > 80;
            healthBadge.className = 'badge ' + (hasIssue ? 'bg-warning text-dark' : 'bg-success');
            healthBadge.textContent = hasIssue ? '注意' : '健康';
        }

        // Top error routes table
        var errTbody = document.getElementById('error-routes-tbody');
        var errBadge = document.getElementById('error-routes-count');
        if (errTbody && s.topErrorRoutes) {
            if (errBadge) errBadge.textContent = s.topErrorRoutes.length;
            if (s.topErrorRoutes.length === 0) {
                errTbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-4">' +
                    (window.I18N && I18N['overview.top.empty'] ? I18N['overview.top.empty'] : '暂无数据') + '</td></tr>';
            } else {
                var html = '';
                s.topErrorRoutes.forEach(function(r) {
                    var cls = r.errorRate >= 50 ? 'text-danger' : r.errorRate >= 20 ? 'text-warning' : 'text-muted';
                    html += '<tr>' +
                        '<td style="padding:10px 16px;"><code>' + escapeHtml(r.routeId) + '</code></td>' +
                        '<td style="padding:10px 16px;"><span class="badge bg-danger">' + r.errorCount + '</span></td>' +
                        '<td style="padding:10px 16px;"><span class="' + cls + '">' + r.errorRate + '%</span></td>' +
                        '</tr>';
                });
                errTbody.innerHTML = html;
            }
        }

        // Top slow clusters table
        var slowTbody = document.getElementById('slow-clusters-tbody');
        var slowBadge = document.getElementById('slow-clusters-count');
        if (slowTbody && s.topSlowClusters) {
            if (slowBadge) slowBadge.textContent = s.topSlowClusters.length;
            if (s.topSlowClusters.length === 0) {
                slowTbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-4">' +
                    (window.I18N && I18N['overview.top.empty'] ? I18N['overview.top.empty'] : '暂无数据') + '</td></tr>';
            } else {
                var slowHtml = '';
                s.topSlowClusters.forEach(function(c) {
                    var p99Cls = c.p99Latency >= 1000 ? 'text-danger' : c.p99Latency >= 500 ? 'text-warning' : 'text-muted';
                    slowHtml += '<tr>' +
                        '<td style="padding:10px 16px;"><code>' + escapeHtml(c.clusterId) + '</code></td>' +
                        '<td style="padding:10px 16px;">' + c.avgLatency.toFixed(0) + 'ms</td>' +
                        '<td style="padding:10px 16px;"><span class="' + p99Cls + '">' + c.p99Latency.toFixed(0) + 'ms</span></td>' +
                        '</tr>';
                });
                slowTbody.innerHTML = slowHtml;
            }
        }
    }

    function escapeHtml(text) {
        if (!text) return '';
        var d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
    }

    /**
     * Polling fallback: re-fetch stat cards + system health via HTTP every 10s.
     * Only active when SignalR is not connected.
     */
    function startPollingFallback() {
        if (_pollingFallbackId) return;
        _pollingFallbackId = setInterval(async function() {
            if (_signalrConnected) { stopPollingFallback(); return; }
            try {
                if (window.OpsModule?.loadTrafficChart) await OpsModule.loadTrafficChart();
                if (window.OpsModule?.loadAlertSummary) await OpsModule.loadAlertSummary();
                if (window.OpsModule?.loadSystemHealth) await OpsModule.loadSystemHealth();
            } catch (_) { /* ignore */ }
        }, 10000);
    }

    function stopPollingFallback() {
        if (_pollingFallbackId) {
            clearInterval(_pollingFallbackId);
            _pollingFallbackId = null;
        }
    }

    window.overviewRefresh = async function(btn) {
        var originalText = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-1"></i>';
        btn.disabled = true;
        try {
            await Promise.all([
                window.DashboardApp?.modules?.home?.loadInfo?.(),
                window.DashboardApp?.modules?.stats?.loadStats?.(),
                window.OpsModule?.loadAlertSummary?.(),
                window.OpsModule?.loadTrafficChart?.(),
                window.OpsModule?.loadTopErrors?.()
            ]);
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    };

    // Init config health score card
    if (window.DashboardHealthScore) {
        DashboardHealthScore.init('config-health-card');
    }

</script>
}