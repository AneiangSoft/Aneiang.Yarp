@using Aneiang.Yarp.Dashboard.Modules.ProxyLog.Models
<!DOCTYPE html>
<html lang="@ViewBag.Locale">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @((ViewBag.Locale as string) == "en-US" ? "Gateway Dashboard" : "网关维护仪表盘")</title>
    <script>
        window.addEventListener('pageshow', function(event) {
            if (event.persisted || performance.getEntriesByType('navigation')[0]?.type === 'back_forward') {
                window.location.reload();
            }
        });
    </script>
    <link href="/_content/Aneiang.Yarp.Dashboard/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/_content/Aneiang.Yarp.Dashboard/lib/bootstrap-icons/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="/_content/Aneiang.Yarp.Dashboard/styles/dashboard-editor.css" rel="stylesheet" />
    <link href="/_content/Aneiang.Yarp.Dashboard/styles/inter-font.css" rel="stylesheet">
    <link href="/_content/Aneiang.Yarp.Dashboard/styles/ai-chat.css" rel="stylesheet">
    <link href="/_content/Aneiang.Yarp.Dashboard/styles/dashboard-layout.css?v=@(typeof(LogEntry).Assembly.GetName().Version)" rel="stylesheet" />
</head>
<body>
    <!-- Toast Notification Container -->
    <div class="toast-container" id="toast-container"></div>

    <!-- Mobile Top Bar -->
    <div class="mobile-topbar" id="mobile-topbar">
        <div class="mobile-topbar-brand">
            <i class="bi bi-hdd-rack"></i>
            <span data-i18n="layout.brand">@((ViewBag.Locale as string) == "en-US" ? "Gateway Dashboard" : "网关维护仪表盘")</span>
        </div>
        <button class="hamburger-btn" id="hamburger-btn" onclick="toggleMobileSidebar()">
            <span></span><span></span><span></span>
        </button>
    </div>

    <!-- Sidebar Overlay (Mobile) -->
    <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleMobileSidebar(false)"></div>

    @await Html.PartialAsync("_Sidebar")

    <div class="main-content">
        @if (ViewBag.CurrentPage as string != "login")
        {
            var pgName = ViewBag.CurrentPage as string ?? "overview";
            var pgPrefix = ViewBag.DashboardRoutePrefix as string ?? "apigateway";
            var pgIsEn = (ViewBag.Locale as string) == "en-US";
            var pageTitles = new System.Collections.Generic.Dictionary<string, string>
            {
                {"overview", pgIsEn ? "Overview" : "总览"},
                {"clusters", pgIsEn ? "Clusters" : "服务集群"},
                {"routes", pgIsEn ? "Routes" : "路由配置"},
                {"stats", pgIsEn ? "Statistics" : "访问统计"},
                {"logs", pgIsEn ? "Logs" : "日志"},
                {"circuits", pgIsEn ? "Circuit Breaker" : "熔断状态"},
                {"notifications", pgIsEn ? "Notification Center" : "通知中心"},
                {"healthcheck", pgIsEn ? "Health Check" : "健康检查"},
                {"waf", pgIsEn ? "WAF Firewall" : "WAF 防火墙"},
                {"policies", pgIsEn ? "Policy Management" : "策略管理"},
                {"plugins", pgIsEn ? "Plugin Management" : "插件管理"},
                {"history", pgIsEn ? "Configuration History" : "配置历史"},
                {"audit", pgIsEn ? "Audit Log" : "审计日志"},
                {"deployment", pgIsEn ? "Deployment" : "运行模式"},
                {"settings", pgIsEn ? "Settings" : "设置"},
                {"ai", pgIsEn ? "AI Assistant" : "AI 助手"}
            };
            var pageIcons = new System.Collections.Generic.Dictionary<string, string>
            {
                {"overview", "bi-speedometer2"}, {"clusters", "bi-diagram-3"}, {"routes", "bi-signpost-split"},
                {"stats", "bi-bar-chart-line"}, {"logs", "bi-journal-text"}, {"circuits", "bi-lightning-charge"},
                {"notifications", "bi-bell"}, {"healthcheck", "bi-heart-pulse"}, {"waf", "bi-shield-lock"},
                {"policies", "bi-sliders"}, {"plugins", "bi-puzzle"}, {"history", "bi-clock-history"},
                {"audit", "bi-shield-check"}, {"deployment", "bi-rocket-takeoff"}, {"settings", "bi-gear"}, {"ai", "bi-robot"}
            };
            var pageTitle = pageTitles.ContainsKey(pgName) ? pageTitles[pgName] : pgName;
            var pageIcon = pageIcons.ContainsKey(pgName) ? pageIcons[pgName] : "bi-app-indicator";
            var parentGroup = "";
            if (new[] { "clusters", "routes" }.Contains(pgName)) parentGroup = pgIsEn ? "Gateway" : "网关管理";
            if (pgName == "overview") parentGroup = "";
            if (new[] { "stats", "logs", "circuits", "notifications", "healthcheck" }.Contains(pgName)) parentGroup = pgIsEn ? "Monitoring" : "监控运维";
            if (new[] { "waf", "policies", "plugins" }.Contains(pgName)) parentGroup = pgIsEn ? "Security" : "安全策略";
            if (new[] { "history", "audit", "settings" }.Contains(pgName)) parentGroup = pgIsEn ? "System" : "系统管理";

            <div class="page-header">
                <div class="page-header-row">
                    <div class="page-header-left">
                        <div class="page-breadcrumb">
                            <a href="/@pgPrefix/">@((ViewBag.Locale as string) == "en-US" ? "Dashboard" : "仪表盘")</a>
                            @if (!string.IsNullOrEmpty(parentGroup))
                            {
                                <span class="separator"><i class="bi bi-chevron-right"></i></span>
                                <span>@parentGroup</span>
                            }
                            <span class="separator"><i class="bi bi-chevron-right"></i></span>
                            <span class="current">@pageTitle</span>
                        </div>
                        <h1 class="page-title"><i class="bi @pageIcon"></i> @pageTitle</h1>
                    </div>
                    <div class="page-header-right">
                        <span class="pulse-dot" title="@((ViewBag.Locale as string) == "en-US" ? "Live" : "在线")"></span>
                        <span class="refresh-badge" style="font-size:12px;">@((ViewBag.Locale as string) == "en-US" ? "Live" : "实时")</span>
                    </div>
                </div>
            </div>
        }
        <div class="main-content-inner">
            @RenderBody()
        </div>
        @if (ViewBag.CurrentPage as string != "login")
        {
            <div class="dashboard-footer">
                <span>@($"Aneiang.Yarp v{typeof(LogEntry).Assembly.GetName().Version} · © 2024-2026")</span>
                <span><span class="pulse-dot me-1"></span>@((ViewBag.Locale as string) == "en-US" ? "System Running" : "系统运行中")</span>
            </div>
        }
    </div>

    <!-- AI Chat Widget (floating) -->
    @if (ViewBag.CurrentPage as string != "login")
    {
        <button id="ai-chat-fab" class="ai-chat-fab" onclick="AIChat.toggle()" title="AI Assistant (Ctrl+/)">
            <i class="bi bi-robot"></i>
        </button>
        <div id="ai-chat-window" class="ai-chat-window">
            <div class="ai-chat-header">
                <div class="ai-chat-header-left">
                    <div class="ai-chat-header-avatar"><i class="bi bi-robot"></i></div>
                    <div class="ai-chat-header-info">
                        <div class="ai-chat-header-title" data-i18n="ai.chatTitle">AI 助手</div>
                        <div class="ai-chat-header-status"><span class="dot"></span><span data-i18n="ai.status.online">在线</span></div>
                    </div>
                </div>
                <div class="ai-chat-header-actions">
                    <button onclick="AIChat.clearSession()" title="New conversation" data-i18n-title="ai.btn.newChat"><i class="bi bi-plus-lg"></i></button>
                    <button onclick="AIChat.showHistory()" title="History" data-i18n-title="ai.btn.history"><i class="bi bi-clock-history"></i></button>
                    <button onclick="AIChat.close()" title="Close"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
            <div id="ai-chat-messages" class="ai-chat-messages"></div>
            <div class="ai-chat-input-area">
                <div class="ai-chat-input-wrap">
                    <textarea id="ai-chat-input" class="ai-chat-input" rows="1" data-i18n-placeholder="ai.input.placeholder" placeholder="输入问题…" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();AIChat.send();}" oninput="AIChat._autoResize(this)"></textarea>
                    <button id="ai-chat-send" class="ai-chat-send" onclick="AIChat.send()"><i class="bi bi-send-fill"></i></button>
                </div>
                <div class="ai-input-hint" data-i18n="ai.input.hint">Enter 发送 · Shift+Enter 换行</div>
            </div>
        </div>
    }

    <script>
        // Inline config - must be set before external scripts load
        var I18N = @Html.Raw(ViewBag.AllI18nJson ?? "{}");
        var CURRENT_LOCALE = '@ViewBag.Locale';
        window.__dashboard = {
            routePrefix: '@ViewBag.DashboardRoutePrefix',
            currentPage: '@ViewBag.CurrentPage',
            locale: '@ViewBag.Locale',
            I18N: I18N,
            CURRENT_LOCALE: CURRENT_LOCALE
        };
        window.DashboardApp = window.DashboardApp || { version: '2.3.0', modules: {} };
        window.DashboardApp.registerModule = function(name, module) { this.modules[name] = module; };
    </script>
    <script src="/_content/Aneiang.Yarp.Dashboard/lib/bootstrap/js/bootstrap.bundle.min.js"></script>

    @{
        var v = typeof(LogEntry).Assembly.GetName().Version?.ToString() ?? DateTime.Now.Ticks.ToString();
    }
    <!-- 1. Core Infrastructure -->
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-utils.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-api.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-loading.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-state.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-dom.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-i18n.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-storage.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-core.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-modals.js?v=@v"></script>
    <!-- 2. Performance Optimizations -->
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-performance.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-indexeddb.js?v=@v"></script>
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-worker.js?v=@v"></script>
    <!-- 3. Layout Functions -->
    <script src="/_content/Aneiang.Yarp.Dashboard/js/core/dashboard-layout.js?v=@v"></script>
    <!-- 4. Events -->
    <script src="/_content/Aneiang.Yarp.Dashboard/js/app/dashboard-events.js?v=@v"></script>
    <!-- 5. AI Chat Widget -->
    <script src="/_content/Aneiang.Yarp.Dashboard/js/modules/dashboard-ai-chat.js?v=@v"></script>
    <!-- 6. Page-specific modules & editors - loaded per page via Scripts section -->

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        if (window.DashboardLoading && window.DashboardLoading.initNetworkStatus) {
            window.DashboardLoading.initNetworkStatus();
        }
        if (window.AIChat && window.AIChat.init) {
            window.AIChat.init();
        }
    </script>
</body>
</html>
