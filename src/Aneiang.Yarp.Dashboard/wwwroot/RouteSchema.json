{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "YARP Route Configuration",
  "description": "YARP Reverse Proxy Route Configuration Schema for Monaco Editor",
  "type": "object",
  "properties": {
    "ClusterId": {
      "type": "string",
      "description": "Name of the cluster this route points to. Must match a cluster defined in Clusters."
    },
    "Order": {
      "type": ["number", "null"],
      "description": "Order value for this route. Routes with lower numbers take precedence over higher numbers."
    },
    "MaxRequestBodySize": {
      "type": ["number", "null"],
      "description": "An optional override for how large request bodies can be in bytes."
    },
    "AuthorizationPolicy": {
      "type": ["string", "null"],
      "description": "Specifies which authorization policy applies. 'Default' = require auth, 'Anonymous' = no auth."
    },
    "RateLimiterPolicy": {
      "type": ["string", "null"],
      "description": "The name of the RateLimiterPolicy to apply to this route."
    },
    "OutputCachePolicy": {
      "type": ["string", "null"],
      "description": "The name of the OutputCachePolicy to apply to this route."
    },
    "Timeout": {
      "type": ["string", "null"],
      "pattern": "^\\d*?\\.?\\d\\d?:\\d\\d?:\\d\\d?\\.?\\d{0,7}$",
      "description": "The Timeout to apply to this route. Format: 'hh:mm:ss'. Mutually exclusive with TimeoutPolicy."
    },
    "TimeoutPolicy": {
      "type": ["string", "null"],
      "description": "Specifies which timeout policy applies. Mutually exclusive with Timeout."
    },
    "CorsPolicy": {
      "type": ["string", "null"],
      "description": "Specifies which CORS policy applies, e.g. 'Default' or 'Disable'."
    },
    "Match": {
      "type": "object",
      "description": "Request matching conditions (required).",
      "properties": {
        "Path": {
          "type": ["string", "null"],
          "description": "Path pattern using ASP.NET route template syntax, e.g. '/api/{**remainder}'."
        },
        "Hosts": {
          "type": ["array", "null"],
          "description": "Only match requests with the given Host header. Supports wildcards and ports.",
          "items": { "type": "string" }
        },
        "Methods": {
          "type": ["array", "null"],
          "description": "Allowed HTTP methods.",
          "items": {
            "type": "string",
            "enum": ["DELETE", "GET", "HEAD", "OPTIONS", "PATCH", "POST", "PUT", "TRACE"]
          }
        },
        "Headers": {
          "type": ["array", "null"],
          "description": "List of header match conditions.",
          "items": {
            "type": "object",
            "properties": {
              "Name": {
                "type": "string",
                "description": "Header name."
              },
              "Values": {
                "type": "array",
                "description": "Matches against any of these values.",
                "items": { "type": "string" }
              },
              "Mode": {
                "type": "string",
                "description": "How the header values should be matched.",
                "enum": ["ExactHeader", "HeaderPrefix", "Contains", "NotContains", "Exists", "NotExists"]
              },
              "IsCaseSensitive": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "enum": ["true", "false", "True", "False"] }
                ]
              }
            },
            "required": ["Name"],
            "additionalProperties": false
          }
        },
        "QueryParameters": {
          "type": ["array", "null"],
          "description": "List of query string match conditions.",
          "items": {
            "type": "object",
            "properties": {
              "Name": {
                "type": "string",
                "description": "Name of the query parameter."
              },
              "Values": {
                "type": "array",
                "description": "Matches against any of these values.",
                "items": { "type": "string" }
              },
              "Mode": {
                "type": "string",
                "description": "How the query parameter values should be matched.",
                "enum": ["Exact", "Contains", "NotContains", "Prefix", "Exists"]
              },
              "IsCaseSensitive": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "enum": ["true", "false", "True", "False"] }
                ]
              }
            },
            "required": ["Name"],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["Path"] },
        { "required": ["Hosts"] }
      ]
    },
    "Metadata": {
      "type": ["object", "null"],
      "description": "Arbitrary key-value pairs for custom route logic.",
      "additionalProperties": {
        "type": ["null", "number", "string", "boolean"]
      }
    },
    "Transforms": {
      "type": ["array", "null"],
      "description": "List of transform objects for request/response customization.",
      "items": {
        "description": "A single transform definition.",
        "anyOf": [
          {
            "type": ["object", "null"],
            "$comment": "Fallback for custom user-defined transforms.",
            "properties": {
              "RequestHeadersCopy": { "not": {} },
              "RequestHeaderOriginalHost": { "not": {} },
              "RequestHeader": { "not": {} },
              "PathRemovePrefix": { "not": {} },
              "PathSet": { "not": {} },
              "PathPrefix": { "not": {} },
              "QueryRouteParameter": { "not": {} },
              "PathPattern": { "not": {} },
              "QueryValueParameter": { "not": {} },
              "QueryRemoveParameter": { "not": {} },
              "HttpMethodChange": { "not": {} },
              "RequestHeaderRouteValue": { "not": {} },
              "RequestHeaderRemove": { "not": {} },
              "RequestHeadersAllowed": { "not": {} },
              "X-Forwarded": { "not": {} },
              "Forwarded": { "not": {} },
              "ClientCert": { "not": {} },
              "ResponseHeadersCopy": { "not": {} },
              "ResponseHeader": { "not": {} },
              "ResponseHeaderRemove": { "not": {} },
              "ResponseHeadersAllowed": { "not": {} },
              "ResponseTrailersCopy": { "not": {} },
              "ResponseTrailer": { "not": {} },
              "ResponseTrailerRemove": { "not": {} },
              "ResponseTrailersAllowed": { "not": {} }
            }
          },
          {
            "type": "object",
            "description": "Copy all incoming request headers to outbound request.",
            "properties": {
              "RequestHeadersCopy": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "enum": ["true", "false", "True", "False"] }
                ]
              }
            },
            "additionalProperties": false,
            "required": ["RequestHeadersCopy"]
          },
          {
            "type": "object",
            "description": "Preserve the original Host header instead of using destination's host.",
            "properties": {
              "RequestHeaderOriginalHost": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "enum": ["true", "false", "True", "False"] }
                ]
              }
            },
            "additionalProperties": false,
            "required": ["RequestHeaderOriginalHost"]
          },
          {
            "type": "object",
            "description": "Set, append, or remove a request header.",
            "properties": {
              "RequestHeader": {
                "type": "string",
                "description": "The header name to operate on."
              },
              "Set": {
                "type": "string",
                "description": "Value to set the header to."
              },
              "Append": {
                "type": "string",
                "description": "Value to append to the header."
              },
              "Remove": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "enum": ["true", "false", "True", "False"] }
                ]
              }
            },
            "additionalProperties": false,
            "anyOf": [
              { "required": ["RequestHeader", "Set"] },
              { "required": ["RequestHeader", "Append"] },
              { "required": ["RequestHeader", "Remove"] }
            ]
          },
          {
            "type": "object",
            "description": "Remove a prefix from the request path.",
            "properties": {
              "PathRemovePrefix": {
                "type": "string",
                "description": "Prefix to remove from the existing request path."
              }
            },
            "additionalProperties": false,
            "required": ["PathRemovePrefix"]
          },
          {
            "type": "object",
            "description": "Replace the entire request path with a specified value.",
            "properties": {
              "PathSet": {
                "type": "string",
                "description": "Sets the request path to this value."
              }
            },
            "additionalProperties": false,
            "required": ["PathSet"]
          },
          {
            "type": "object",
            "description": "Add a prefix to the request path.",
            "properties": {
              "PathPrefix": {
                "type": "string",
                "description": "Path prefix to add."
              }
            },
            "additionalProperties": false,
            "required": ["PathPrefix"]
          },
          {
            "type": "object",
            "description": "Replace path using a pattern template, replacing {} segments with route values.",
            "properties": {
              "PathPattern": {
                "type": "string",
                "description": "A path template starting with '/', e.g. '/api/{**remainder}'."
              }
            },
            "additionalProperties": false,
            "required": ["PathPattern"]
          },
          {
            "type": "object",
            "description": "Add or replace a query parameter with a route value.",
            "properties": {
              "QueryRouteParameter": {
                "type": "string",
                "description": "Query parameter name to add or replace."
              },
              "Set": {
                "type": "string",
                "description": "Route parameter name to set the query parameter to."
              },
              "Append": {
                "type": "string",
                "description": "Route parameter name to append."
              }
            },
            "additionalProperties": false,
            "anyOf": [
              { "required": ["QueryRouteParameter", "Set"] },
              { "required": ["QueryRouteParameter", "Append"] }
            ]
          },
          {
            "type": "object",
            "description": "Add or replace a query parameter with a specified value.",
            "properties": {
              "QueryValueParameter": {
                "type": "string",
                "description": "Query parameter name."
              },
              "Set": {
                "type": "string",
                "description": "Value to set."
              },
              "Append": {
                "type": "string",
                "description": "Value to append."
              }
            },
            "additionalProperties": false,
            "anyOf": [
              { "required": ["QueryValueParameter", "Set"] },
              { "required": ["QueryValueParameter", "Append"] }
            ]
          },
          {
            "type": "object",
            "description": "Remove a query parameter.",
            "properties": {
              "QueryRemoveParameter": {
                "type": "string",
                "description": "Query parameter name to remove."
              }
            },
            "additionalProperties": false,
            "required": ["QueryRemoveParameter"]
          },
          {
            "type": "object",
            "description": "Change the HTTP method of the request.",
            "properties": {
              "HttpMethodChange": {
                "anyOf": [
                  { "type": "string", "enum": ["DELETE", "GET", "HEAD", "OPTIONS", "PATCH", "POST", "PUT", "TRACE"] },
                  { "type": "string" }
                ]
              },
              "Set": {
                "type": "string",
                "description": "The new HTTP method."
              }
            },
            "additionalProperties": false,
            "required": ["HttpMethodChange", "Set"]
          },
          {
            "type": "object",
            "description": "Remove a request header.",
            "properties": {
              "RequestHeaderRemove": {
                "type": "string",
                "description": "The header name to remove."
              }
            },
            "additionalProperties": false,
            "required": ["RequestHeaderRemove"]
          },
          {
            "type": "object",
            "description": "Allow only specified request headers through.",
            "properties": {
              "RequestHeadersAllowed": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9!#$%&'*+-.^_`|~;]+$",
                "description": "Semicolon separated list of allowed header names."
              }
            },
            "additionalProperties": false,
            "required": ["RequestHeadersAllowed"]
          },
          {
            "type": "object",
            "description": "Add X-Forwarded-* headers with client request information.",
            "properties": {
              "X-Forwarded": {
                "type": "string",
                "description": "Default action for all X-Forwarded-* headers.",
                "enum": ["Set", "Append", "Remove", "Off"]
              },
              "For": {
                "type": "string",
                "description": "Action for 'For' header.",
                "enum": ["Set", "Append", "Remove", "Off"]
              },
              "Proto": {
                "type": "string",
                "description": "Action for 'Proto' header.",
                "enum": ["Set", "Append", "Remove", "Off"]
              },
              "Host": {
                "type": "string",
                "description": "Action for 'Host' header.",
                "enum": ["Set", "Append", "Remove", "Off"]
              },
              "Prefix": {
                "type": "string",
                "description": "Action for 'Prefix' header.",
                "enum": ["Set", "Append", "Remove", "Off"]
              },
              "HeaderPrefix": {
                "type": "string",
                "default": "X-Forwarded-"
              }
            },
            "additionalProperties": false,
            "required": ["X-Forwarded"]
          },
          {
            "type": "object",
            "description": "Add RFC 7239 Forwarded header.",
            "properties": {
              "Forwarded": {
                "type": "string",
                "pattern": "^(?:(?:for|by|proto|host),?)+$",
                "description": "Comma separated list: 'for,by,proto,host'."
              },
              "ForFormat": {
                "type": "string",
                "enum": ["Random", "RandomAndPort", "RandomAndRandomPort", "Unknown", "UnknownAndPort", "UnknownAndRandomPort", "Ip", "IpAndPort", "IpAndRandomPort"]
              },
              "ByFormat": {
                "type": "string",
                "enum": ["Random", "RandomAndPort", "RandomAndRandomPort", "Unknown", "UnknownAndPort", "UnknownAndRandomPort", "Ip", "IpAndPort", "IpAndRandomPort"]
              },
              "Action": {
                "type": "string",
                "enum": ["Set", "Append", "Remove", "Off"]
              }
            },
            "additionalProperties": false,
            "required": ["Forwarded"]
          },
          {
            "type": "object",
            "description": "Forward client certificate as a header.",
            "properties": {
              "ClientCert": {
                "type": "string",
                "description": "Header name for the forwarded client certificate."
              }
            },
            "additionalProperties": false,
            "required": ["ClientCert"]
          },
          {
            "type": "object",
            "description": "Control copying of response headers from destination.",
            "properties": {
              "ResponseHeadersCopy": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "enum": ["true", "false", "True", "False"] }
                ]
              }
            },
            "additionalProperties": false,
            "required": ["ResponseHeadersCopy"]
          },
          {
            "type": "object",
            "description": "Set, append, or remove a response header.",
            "properties": {
              "ResponseHeader": {
                "type": "string",
                "description": "The header name."
              },
              "Set": {
                "type": "string",
                "description": "Value to set."
              },
              "Append": {
                "type": "string",
                "description": "Value to append."
              },
              "When": {
                "type": "string",
                "description": "When to apply: Success, Always, or Failure.",
                "enum": ["Success", "Always", "Failure"]
              }
            },
            "additionalProperties": false,
            "anyOf": [
              { "required": ["ResponseHeader", "Set"] },
              { "required": ["ResponseHeader", "Append"] }
            ]
          },
          {
            "type": "object",
            "description": "Remove a response header.",
            "properties": {
              "ResponseHeaderRemove": {
                "type": "string",
                "description": "The header name to remove."
              },
              "When": {
                "type": "string",
                "enum": ["Success", "Always", "Failure"]
              }
            },
            "additionalProperties": false,
            "required": ["ResponseHeaderRemove"]
          },
          {
            "type": "object",
            "description": "Allow only specified response headers through.",
            "properties": {
              "ResponseHeadersAllowed": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9!#$%&'*+-.^_`|~;]+$",
                "description": "Semicolon separated list of allowed header names."
              }
            },
            "additionalProperties": false,
            "required": ["ResponseHeadersAllowed"]
          },
          {
            "type": "object",
            "description": "Control copying of response trailers from destination.",
            "properties": {
              "ResponseTrailersCopy": {
                "anyOf": [
                  { "type": "boolean" },
                  { "type": "string", "enum": ["true", "false", "True", "False"] }
                ]
              }
            },
            "additionalProperties": false,
            "required": ["ResponseTrailersCopy"]
          },
          {
            "type": "object",
            "description": "Set or append a response trailer.",
            "properties": {
              "ResponseTrailer": {
                "type": "string",
                "description": "The trailer name."
              },
              "Set": {
                "type": "string",
                "description": "Value to set."
              },
              "Append": {
                "type": "string",
                "description": "Value to append."
              },
              "When": {
                "type": "string",
                "enum": ["Success", "Always", "Failure"]
              }
            },
            "additionalProperties": false,
            "anyOf": [
              { "required": ["ResponseTrailer", "Set"] },
              { "required": ["ResponseTrailer", "Append"] }
            ]
          },
          {
            "type": "object",
            "description": "Remove a response trailer.",
            "properties": {
              "ResponseTrailerRemove": {
                "type": "string",
                "description": "The trailer name to remove."
              },
              "When": {
                "type": "string",
                "enum": ["Success", "Always", "Failure"]
              }
            },
            "additionalProperties": false,
            "required": ["ResponseTrailerRemove"]
          },
          {
            "type": "object",
            "description": "Allow only specified response trailers through.",
            "properties": {
              "ResponseTrailersAllowed": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9!#$%&'*+-.^_`|~;]+$",
                "description": "Semicolon separated list of allowed trailer names."
              }
            },
            "additionalProperties": false,
            "required": ["ResponseTrailersAllowed"]
          }
        ]
      }
    }
  },
  "required": ["ClusterId", "Match"],
  "additionalProperties": false
}