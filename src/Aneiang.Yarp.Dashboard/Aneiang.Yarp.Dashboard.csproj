<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFrameworks>net6.0;net7.0;net8.0;net9.0</TargetFrameworks>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet 包元数据（部分属性继承自 src/Directory.Build.props） -->
    <PackageId>Aneiang.Yarp.Dashboard</PackageId>
    <Description>Aneiang YARP dashboard. Provides gateway monitoring and operations UI with real-time cluster/routes visualization.</Description>
    <PackageTags>yarp;reverse-proxy;gateway;dashboard;monitoring;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Aneiang.Yarp\Aneiang.Yarp.csproj" />
  </ItemGroup>

</Project>
